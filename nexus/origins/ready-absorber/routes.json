{
  "_meta": {
    "description": "ready → 본체 프로젝트 라우팅 맵",
    "created": "2026-04-04",
    "version": 1
  },
  "routes": {
    "TECS-L": {
      "dest": "~/Dev/TECS-L",
      "keywords": ["characterization", "proof", "theorem", "hypothesis", "math", "atlas", "constant", "formula"],
      "file_patterns": ["docs/hypotheses/**", "math/**", "data/**", "engines/**", "calc/**"],
      "priority": "high"
    },
    "n6-architecture": {
      "dest": "~/Dev/n6-architecture",
      "keywords": ["BT-", "technique", "chip", "energy", "DSE", "semiconductor", "battery", "solar", "fusion", "robot"],
      "file_patterns": ["docs/**", "techniques/**", "experiments/**", "tools/**"],
      "priority": "high"
    },
    "anima": {
      "dest": "~/Dev/anima",
      "keywords": ["consciousness", "purefield", "law", "hexad", "repulsion", "decoder", "meta_law"],
      "file_patterns": ["anima/**", "docs/**", "consciousness_laws*", "anima-physics/**"],
      "priority": "high"
    },
    "nexus": {
      "dest": "~/Dev/nexus",
      "keywords": ["lens", "telescope", "scan", "ouroboros", "growth", "discovery"],
      "file_patterns": ["src/**", "shared/**", "scripts/**"],
      "priority": "high"
    },
    "sedi": {
      "dest": "~/Dev/sedi",
      "keywords": ["seti", "signal", "r-spectrum", "anomaly", "ligo", "cmb", "breakthrough_listen"],
      "file_patterns": ["docs/**", "data/**", "scripts/**"],
      "priority": "medium"
    },
    "hexa-lang": {
      "dest": "~/Dev/hexa-lang",
      "keywords": ["compiler", "lexer", "parser", "codegen", "hexa", "keyword", "operator"],
      "file_patterns": ["src/**", "examples/**", "self/**", "playground/**"],
      "priority": "medium"
    },
    "papers": {
      "dest": "~/Dev/papers",
      "keywords": ["paper", "arxiv", "zenodo", "manuscript", "doi", "draft"],
      "file_patterns": ["*.pdf", "*.tex", "tecs-l/**", "anima/**", "sedi/**"],
      "priority": "medium"
    },
    "invest": {
      "dest": "~/Dev/invest",
      "keywords": ["trading", "strategy", "backtest", "sharpe", "portfolio", "scalper"],
      "file_patterns": ["backend/**", "scalper/**", "docs/**"],
      "priority": "medium"
    },
    "brainwire": {
      "dest": "~/Dev/brainwire",
      "keywords": ["bci", "eeg", "neural", "stimulation", "tdcs", "tms"],
      "file_patterns": ["brainwire/**", "docs/**"],
      "priority": "low"
    },
    "ph-training": {
      "dest": "~/Dev/ph-training",
      "keywords": ["persistent_homology", "betti", "topology", "training", "lr_search"],
      "file_patterns": ["src/**", "tests/**"],
      "priority": "low"
    },
    "conscious-lm": {
      "dest": "~/Dev/conscious-lm",
      "keywords": ["language_model", "mitosis", "700m", "byte_level"],
      "file_patterns": ["*.py", "docs/**"],
      "priority": "low"
    },
    "golden-moe": {
      "dest": "~/Dev/golden-moe",
      "keywords": ["golden_zone", "moe", "inhibition", "1/e"],
      "file_patterns": ["*.py"],
      "priority": "low"
    },
    "fathom": {
      "dest": "~/Dev/fathom",
      "keywords": ["terminal", "tui", "shell", "emulator"],
      "file_patterns": ["src/**", "scripts/**"],
      "priority": "low"
    },
    "contact": {
      "dest": "~/Dev/contact",
      "keywords": ["email", "outreach", "awesome", "submission"],
      "file_patterns": ["*.py", "*.json", "templates/**"],
      "priority": "low"
    },
    "remotion": {
      "dest": "~/Dev/remotion",
      "keywords": ["video", "scene", "remotion", "promo"],
      "file_patterns": ["src/**", "public/**"],
      "priority": "low"
    }
  }
}
