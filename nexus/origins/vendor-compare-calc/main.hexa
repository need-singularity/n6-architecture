// === Section 1: Vendor Scorecard ===
println("")
println("─── VENDOR SCORECARD ───")
println("")

println("║ " + pad_r("Vendor", 8) + "│ " + pad_r("Chip", 16) + "│ " + pad_l("Params", 6) + " │ " + pad_l("EXACT", 5) + " │ " + pad_l("Score", 6) + " │ " + pad_r("Top Formula", 22) + " ║")
println("╠" + repeat_str("═", 9) + "╪" + repeat_str("═", 17) + "╪" + repeat_str("═", 8) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 8) + "╪" + repeat_str("═", 23) + "╣")

let mut grand_exact = 0
let mut grand_total = 0

let mut ci = 0
while ci < len(chips) {
    let chip = chips[ci]
    let et = count_exact(chip)
    let exact = et[0]
    let total = et[1]
    grand_exact = grand_exact + exact
    grand_total = grand_total + total

    let score = pct_str(exact, total)

    // Find top formula (first param with formula)
    let mut top = "---"
    let params = chip[3]
    let mut pi = 0
    while pi < len(params) {
        let p = params[pi]
        if to_string(p[2]) != "" {
            let fd = find_formula_display(to_int(p[1]))
            if fd != "" { top = fd }
            else { top = to_string(p[2]) }
            pi = len(params)
        }
        pi = pi + 1
    }

    println("║ " + pad_r(vendor_names[to_int(chip[0])], 8) + "│ " + pad_r(chip[1], 16) + "│ " + pad_l(to_string(total), 6) + " │ " + pad_l(to_string(exact), 5) + " │ " + pad_l(score, 6) + " │ " + pad_r(top, 22) + " ║")
    ci = ci + 1
}

// === Section 2: Formula Frequency ===
println("")
println("─── FORMULA FREQUENCY (cross-vendor reuse) ───")
println("")

println("║ " + pad_r("Formula", 22) + "│ " + pad_l("Value", 5) + " │ " + pad_r("NVIDIA", 6) + " │ " + pad_r("AMD", 5) + " │ " + pad_r("Google", 6) + " │ " + pad_r("AWS", 5) + " │ " + pad_r("Intel", 5) + " │ " + pad_r("Apple", 5) + " │ " + pad_l("Count", 5) + " ║")
println("╠" + repeat_str("═", 23) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 8) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 8) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 7) + "╣")

// Build hits
let mut hits = []
let mut fi = 0
while fi < len(formulas) {
    let f = formulas[fi]
    let fval = f[2]
    let fdisplay = f[1]
    let mut v0 = 0
    let mut v1 = 0
    let mut v2 = 0
    let mut v3 = 0
    let mut v4 = 0
    let mut v5 = 0
    let mut ci2 = 0
    while ci2 < len(chips) {
        let c = chips[ci2]
        let vid = c[0]
        let cparams = c[3]
        let mut pi2 = 0
        while pi2 < len(cparams) {
            let p = cparams[pi2]
            if to_string(p[2]) != "" {
                if to_string(p[1]) == fval {
                    let vid_int = to_int(vid)
                    if vid_int == 0 { v0 = 1 }
                    if vid_int == 1 { v1 = 1 }
                    if vid_int == 2 { v2 = 1 }
                    if vid_int == 3 { v3 = 1 }
                    if vid_int == 4 { v4 = 1 }
                    if vid_int == 5 { v5 = 1 }
                }
            }
            pi2 = pi2 + 1
        }
        ci2 = ci2 + 1
    }
    let cnt = v0 + v1 + v2 + v3 + v4 + v5
    if cnt > 0 {
        hits = hits + [[fdisplay, fval, to_string(v0), to_string(v1), to_string(v2), to_string(v3), to_string(v4), to_string(v5), to_string(cnt)]]
    }
    fi = fi + 1
}

// Sort by count desc, then value asc (bubble sort)
let mut si = 0
while si < len(hits) {
    let mut sj = 0
    while sj < len(hits) - 1 - si {
        let a = hits[sj]
        let b = hits[sj + 1]
        let mut swap = 0
        if to_int(b[8]) > to_int(a[8]) { swap = 1 }
        if to_int(b[8]) == to_int(a[8]) {
            if to_int(a[1]) > to_int(b[1]) { swap = 1 }
        }
        if swap == 1 {
            hits[sj] = b
            hits[sj + 1] = a
        }
        sj = sj + 1
    }
    si = si + 1
}

let mut hi = 0
while hi < len(hits) {
    let h = hits[hi]
    println("║ " + pad_r(h[0], 22) + "│ " + pad_l(to_string(h[1]), 5) + " │ " + pad_r(check_mark(h[2]), 6) + " │ " + pad_r(check_mark(h[3]), 5) + " │ " + pad_r(check_mark(h[4]), 6) + " │ " + pad_r(check_mark(h[5]), 5) + " │ " + pad_r(check_mark(h[6]), 5) + " │ " + pad_r(check_mark(h[7]), 5) + " │ " + pad_l(to_string(h[8]), 5) + " ║")
    hi = hi + 1
}

// === Section 3: Vendor Convergence Summary ===
println("")
println("─── VENDOR CONVERGENCE SUMMARY ───")
println("")

println("║ " + pad_r("Vendor", 10) + "│ " + pad_l("EXACT", 5) + " │ " + pad_l("Total", 5) + " │ " + pad_l("Score", 8) + " │ " + pad_r("Strongest Chip", 30) + " ║")
println("╠" + repeat_str("═", 11) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 7) + "╪" + repeat_str("═", 10) + "╪" + repeat_str("═", 31) + "╣")

let mut vi = 0
while vi < 6 {
    let vs = vendor_score(vi)
    let vexact = vs[0]
    let vtotal = vs[1]
    let vscore = pct_str(vexact, vtotal)

    let mut best_name = "---"
    let mut best_score = -1
    let mut ci3 = 0
    while ci3 < len(chips) {
        let c = chips[ci3]
        if c[0] == to_string(vi) {
            let et2 = count_exact(c)
            let mut t = et2[1]
            if t == 0 { t = 1 }
            let s = (et2[0] * 100) / t
            if s > best_score {
                best_score = s
                best_name = c[1]
            }
        }
        ci3 = ci3 + 1
    }

    println("║ " + pad_r(vendor_names[vi], 10) + "│ " + pad_l(to_string(vexact), 5) + " │ " + pad_l(to_string(vtotal), 5) + " │ " + pad_l(vscore, 8) + " │ " + pad_r(best_name, 30) + " ║")
    vi = vi + 1
}

