// N6 Cross-Vendor Chip Comparison Calculator
// ============================================
// Compares ALL major chip vendors against n=6 arithmetic constants.
// Original: tools/vendor-compare-calc/main.rs

let N = 6
let PHI = 2
let TAU = 4
let SIGMA = 12
let SOPFR = 5
let MU = 1
let J2 = 24
let SIGMA_SQ = 144
let SIGMA_MU = SIGMA - MU
let SIGMA_PHI = SIGMA - PHI
let SIGMA_TAU = SIGMA - TAU
let PHI_POW_TAU = 16
let TWO_POW_SOPFR = 32

fn pad_r(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = r + " " }
    r
}

fn pad_l(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = " " + r }
    r
}

fn pad_c(s, w) {
    let total_pad = w - len(s)
    if total_pad < 1 { s }
    else {
        let left = total_pad / 2
        let right = total_pad - left
        let mut r = ""
        let mut i = 0
        while i < left { r = r + " "
            i = i + 1
        }
        r = r + s
        i = 0
        while i < right { r = r + " "
            i = i + 1
        }
        r
    }
}

fn repeat_str(ch, n) {
    let mut r = ""
    let mut i = 0
    while i < n { r = r + ch
        i = i + 1
    }
    r
}

// --- Formula Registry ---
let mut formulas = []
formulas = formulas + [["n", "n", to_string(N)]]
formulas = formulas + [["phi", "φ", to_string(PHI)]]
formulas = formulas + [["n/phi", "n/φ", to_string(N / PHI)]]
formulas = formulas + [["tau", "τ", to_string(TAU)]]
formulas = formulas + [["sopfr", "sopfr", to_string(SOPFR)]]
formulas = formulas + [["sigma-tau", "σ-τ", to_string(SIGMA_TAU)]]
formulas = formulas + [["sigma-phi", "σ-φ", to_string(SIGMA_PHI)]]
formulas = formulas + [["sigma-mu", "σ-μ", to_string(SIGMA_MU)]]
formulas = formulas + [["sigma", "σ", to_string(SIGMA)]]
formulas = formulas + [["phi^tau", "φ^τ", to_string(PHI_POW_TAU)]]
formulas = formulas + [["J_2", "J₂", to_string(J2)]]
formulas = formulas + [["2^sopfr", "2^sopfr", to_string(TWO_POW_SOPFR)]]
formulas = formulas + [["2^tau", "2^τ", "16"]]
formulas = formulas + [["phi^tau*sopfr", "φ^τ·sopfr", to_string(PHI_POW_TAU * SOPFR)]]
formulas = formulas + [["phi^tau*(sigma-phi)", "φ^τ·(σ-φ)", to_string(PHI_POW_TAU * SIGMA_PHI)]]
formulas = formulas + [["sigma*(sigma-mu)", "σ·(σ-μ)", to_string(SIGMA * SIGMA_MU)]]
formulas = formulas + [["sigma*(sigma-tau)", "σ·(σ-τ)", to_string(SIGMA * SIGMA_TAU)]]
formulas = formulas + [["sigma*phi^tau", "σ·φ^τ", to_string(SIGMA * PHI_POW_TAU)]]
formulas = formulas + [["sigma*J_2", "σ·J₂", to_string(SIGMA * J2)]]
formulas = formulas + [["sigma^2", "σ²", to_string(SIGMA_SQ)]]
formulas = formulas + [["sigma^2*n/phi", "σ²·n/φ", to_string(SIGMA_SQ * N / PHI)]]
formulas = formulas + [["2^(sigma-tau)", "2^(σ-τ)", "256"]]
formulas = formulas + [["2^sopfr*(sigma-sopfr)", "2^sopfr·(σ-sopfr)", to_string(TWO_POW_SOPFR * (SIGMA - SOPFR))]]
formulas = formulas + [["sigma*n", "σ·n", to_string(SIGMA * N)]]
formulas = formulas + [["sigma*sopfr", "σ·sopfr", to_string(SIGMA * SOPFR)]]

fn find_formula_display(value) {
    let mut i = 0
    let mut result = ""
    let val_str = to_string(value)
    while i < len(formulas) {
        let f = formulas[i]
        if to_string(f[2]) == val_str { result = f[1]
            i = len(formulas)
        }
        i = i + 1
    }
    result
}

// Vendor IDs
let VENDOR_NVIDIA = 0
let VENDOR_AMD = 1
let VENDOR_GOOGLE = 2
let VENDOR_AWS = 3
let VENDOR_INTEL = 4
let VENDOR_APPLE = 5
let vendor_names = ["NVIDIA", "AMD", "Google", "AWS", "Intel", "Apple"]

// --- Chip Database ---
// 형식: [vendor_id_str, name, year_str, params]
// params 형식: [param_name, value_str, formula_key]
let mut chips = []
chips = chips + [[to_string(VENDOR_NVIDIA), "A100", "2020", [["SMs", "108", ""], ["HBM GB", "80", "phi^tau*sopfr"], ["HBM stacks", "5", "sopfr"]]]]
chips = chips + [[to_string(VENDOR_NVIDIA), "AD102", "2022", [["Full SMs", "144", "sigma^2"], ["GPCs", "12", "sigma"]]]]
chips = chips + [[to_string(VENDOR_NVIDIA), "H100", "2022", [["SMs", "132", "sigma*(sigma-mu)"], ["HBM GB", "80", "phi^tau*sopfr"], ["HBM stacks", "6", "n"], ["NVLink", "18", ""]]]]
chips = chips + [[to_string(VENDOR_NVIDIA), "B200", "2024", [["SMs (2-die)", "160", "phi^tau*(sigma-phi)"], ["HBM GB", "192", "sigma*phi^tau"], ["HBM stacks", "8", "sigma-tau"]]]]
chips = chips + [[to_string(VENDOR_NVIDIA), "B300", "2025", [["SMs (2-die)", "160", "phi^tau*(sigma-phi)"], ["HBM GB", "288", "sigma*J_2"], ["HBM stacks", "12", "sigma"], ["NVLink gens", "5", "sopfr"]]]]
chips = chips + [[to_string(VENDOR_NVIDIA), "R100", "2026", [["SMs", "224", "2^sopfr*(sigma-sopfr)"], ["HBM GB", "288", "sigma*J_2"], ["HBM stacks", "8", "sigma-tau"]]]]
chips = chips + [[to_string(VENDOR_AMD), "MI250X", "2022", [["CUs", "220", ""], ["HBM GB", "128", ""]]]]
chips = chips + [[to_string(VENDOR_AMD), "MI300X", "2023", [["CUs", "304", ""], ["XCDs", "8", "sigma-tau"], ["HBM GB", "192", "sigma*phi^tau"], ["HBM stacks", "8", "sigma-tau"]]]]
chips = chips + [[to_string(VENDOR_AMD), "MI350X", "2025", [["CUs", "256", "2^(sigma-tau)"], ["HBM GB", "288", "sigma*J_2"], ["Chiplets", "8", "sigma-tau"], ["CU/chiplet", "32", "2^sopfr"]]]]
chips = chips + [[to_string(VENDOR_AMD), "MI400", "2026", [["HBM GB", "432", "sigma^2*n/phi"]]]]
chips = chips + [[to_string(VENDOR_GOOGLE), "TPU v5e", "2023", [["HBM GB", "16", "phi^tau"]]]]
chips = chips + [[to_string(VENDOR_GOOGLE), "TPU v7 Ironwood", "2025", [["HBM GB", "192", "sigma*phi^tau"], ["HBM stacks", "8", "sigma-tau"], ["TCs", "2", "phi"], ["SCs", "4", "tau"], ["Pod chips", "256", "2^(sigma-tau)"]]]]
chips = chips + [[to_string(VENDOR_AWS), "Trainium2", "2024", [["HBM GB", "96", "sigma*(sigma-tau)"]]]]
chips = chips + [[to_string(VENDOR_AWS), "Trainium3", "2025", [["HBM GB", "144", "sigma^2"]]]]
chips = chips + [[to_string(VENDOR_INTEL), "Arrow Lake", "2024", [["Total cores", "24", "J_2"], ["P-cores", "8", "sigma-tau"], ["E-cores", "16", "2^tau"]]]]
chips = chips + [[to_string(VENDOR_INTEL), "CWF", "2026", [["E-cores", "288", "sigma*J_2"]]]]
chips = chips + [[to_string(VENDOR_APPLE), "M4", "2024", [["CPU cores", "10", "sigma-phi"], ["GPU cores", "10", "sigma-phi"]]]]
chips = chips + [[to_string(VENDOR_APPLE), "M5", "2025", [["CPU cores", "10", "sigma-phi"], ["P-cores", "4", "tau"], ["E-cores", "6", "n"], ["GPU cores", "10", "sigma-phi"]]]]
chips = chips + [[to_string(VENDOR_APPLE), "M5 Pro", "2025", [["P-cores", "12", "sigma"], ["E-cores", "6", "n"], ["GPU cores", "18", ""]]]]

// --- Predictions ---
let mut preds = []
preds = preds + [["R200", to_string(VENDOR_NVIDIA), "SMs", to_string(SIGMA * J2), "sigma*J_2", "σ·J₂", "SM=HBM convergence at 288"]]
preds = preds + [["R200", to_string(VENDOR_NVIDIA), "HBM GB", to_string(SIGMA_SQ * N / PHI), "sigma^2*n/phi", "σ²·n/φ", "HBM ladder: 288->432"]]
preds = preds + [["MI500", to_string(VENDOR_AMD), "HBM GB", to_string(SIGMA * SIGMA * N / PHI), "sigma^2*n/phi", "σ²·n/φ", "MI400=432, MI500 may exceed or match"]]
preds = preds + [["MI500", to_string(VENDOR_AMD), "CUs", to_string(SIGMA * J2), "sigma*J_2", "σ·J₂", "CU ladder: 256->288 via sigma*J_2"]]
preds = preds + [["M6", to_string(VENDOR_APPLE), "CPU cores", to_string(SIGMA), "sigma", "σ", "M5 Pro already 12P, base M6 follows"]]
preds = preds + [["M6", to_string(VENDOR_APPLE), "GPU cores", to_string(SIGMA), "sigma", "σ", "GPU ladder: 10->12 = sigma"]]
preds = preds + [["TPU v8", to_string(VENDOR_GOOGLE), "HBM GB", to_string(SIGMA * J2), "sigma*J_2", "σ·J₂", "TPU v7=192, v8 follows NVIDIA/AMD at 288"]]
preds = preds + [["TPU v8", to_string(VENDOR_GOOGLE), "Pod chips", to_string(SIGMA * J2), "sigma*J_2", "σ·J₂", "Pod: 256->288 = sigma*J_2"]]
preds = preds + [["Trainium4", to_string(VENDOR_AWS), "HBM GB", to_string(SIGMA * J2), "sigma*J_2", "σ·J₂", "Ladder: 96->144->288"]]

// --- Analysis helpers ---
fn count_exact(chip) {
    let params = chip[3]
    let mut total = 0
    let mut exact = 0
    let mut i = 0
    while i < len(params) {
        let p = params[i]
        if to_int(p[1]) > 0 { total = total + 1 }
        if to_string(p[2]) != "" { exact = exact + 1 }
        i = i + 1
    }
    [exact, total]
}

fn vendor_score(vid) {
    let mut exact = 0
    let mut total = 0
    let mut i = 0
    while i < len(chips) {
        let c = chips[i]
        if c[0] == to_string(vid) {
            let et = count_exact(c)
            exact = exact + et[0]
            total = total + et[1]
        }
        i = i + 1
    }
    [exact, total]
}

fn pct_str(exact, total) {
    if total == 0 { "N/A" }
    else { to_string((exact * 100) / total) + "%" }
}

fn check_mark(v) {
    if to_string(v) == "1" { "✓" }
    else { "" }
}

// === Header ===
println("╔" + repeat_str("═", 72) + "╗")
