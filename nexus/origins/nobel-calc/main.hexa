fn pad_r(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = r + " " }
    r
}
fn pad_l(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = " " + r }
    r
}

fn abs_val(x) {
    if x < 0.0 { return 0.0 - x }
    x
}

fn rd2(x) { round(x * 100.0) / 100.0 }
fn rd3(x) { round(x * 1000.0) / 1000.0 }
fn rd4(x) { round(x * 10000.0) / 10000.0 }
fn rd5(x) { round(x * 100000.0) / 100000.0 }
fn rd6(x) { round(x * 1000000.0) / 1000000.0 }
fn rd8(x) { round(x * 100000000.0) / 100000000.0 }
fn rd9(x) { round(x * 1000000000.0) / 1000000000.0 }
fn rd1(x) { round(x * 10.0) / 10.0 }
fn rd0(x) { round(x) }

// Scientific notation: x.xxe-N
fn sci2(x) {
    if x == 0.0 { return "0.00e0" }
    let mut val = abs_val(x)
    let mut exp = 0
    while val >= 10.0 {
        val = val / 10.0
        exp = exp + 1
    }
    while val < 1.0 {
        val = val * 10.0
        exp = exp - 1
    }
    let mut mantissa = round(val * 100.0) / 100.0
    if mantissa >= 10.0 {
        mantissa = mantissa / 10.0
        exp = exp + 1
    }
    let mut sign = ""
    if x < 0.0 { sign = "-" }
    sign + to_string(rd2(mantissa)) + "e" + to_string(exp)
}

fn sci1(x) {
    if x == 0.0 { return "0.0e0" }
    let mut val = abs_val(x)
    let mut exp = 0
    while val >= 10.0 {
        val = val / 10.0
        exp = exp + 1
    }
    while val < 1.0 {
        val = val * 10.0
        exp = exp - 1
    }
    let mut mantissa = round(val * 10.0) / 10.0
    if mantissa >= 10.0 {
        mantissa = mantissa / 10.0
        exp = exp + 1
    }
    let mut sign = ""
    if x < 0.0 { sign = "-" }
    sign + to_string(rd1(mantissa)) + "e" + to_string(exp)
}

fn sci4(x) {
    if x == 0.0 { return "0.0000e0" }
    let mut val = abs_val(x)
    let mut exp = 0
    while val >= 10.0 {
        val = val / 10.0
        exp = exp + 1
    }
    while val < 1.0 {
        val = val * 10.0
        exp = exp - 1
    }
    let mut mantissa = round(val * 10000.0) / 10000.0
    if mantissa >= 10.0 {
        mantissa = mantissa / 10.0
        exp = exp + 1
    }
    let mut sign = ""
    if x < 0.0 { sign = "-" }
    sign + to_string(rd4(mantissa)) + "e" + to_string(exp)
}

fn pass_str(ok) {
    if ok { return "✓" }
    "✗"
}

