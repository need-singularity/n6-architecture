// Build results as parallel arrays — sorted by error
let mut r_names =    ["Koide Q", "1/α", "m_p/m_e", "n_s", "N_eff", "sin²θ₂₃", "J (Jarlskog)", "|V_ub|=r", "sin²θ_W", "|V_cb|/|V_ub|", "m_n/m_p-1", "sin²(2θ₁₃)", "α_s(M_Z)", "sin²θ₁₂", "|V_cb|", "m_t/m_W"]
let mut r_formulas = ["φ²/n = 2/3", "σ(σ-μ)+sopfr+1/P₂", "6π⁵", "27/28 = 1-1/P₂", "n/φ+μ/J₂ = 73/24", "τ/(σ-sopfr) = 4/7", "(37/12)×10⁻⁵", "(n/φ)/P₂² = 3/784", "3/13 = (n/φ)/(σ+μ)", "σ-μ = 11", "1/n! = 1/720", "μ/σ = 1/12", "5/42", "(n/φ)/(σ-φ) = 3/10", "μ/J₂ = 1/24", "(σ+n/φ)/(σ-sopfr)=15/7"]
let mut r_errs =     [koide_err, alpha_err_ppm / 10000.0, 0.0019, ns_err, neff_err, s23_err, j_err, v_ub_err, sw2_err, ratio_err, 0.79, s213_err, alpha_s_err, s12_err, v_cb_err, mt_mw_err]
let mut r_sources =  ["BT-24", "BT-20", "H-CP-7", "BT-22", "BT-21", "BT-21", "BT-23", "BT-23", "BT-20", "BT-23", "H-CP-61", "BT-21", "BT-20", "BT-21", "BT-23", "BT-25"]

// Bubble sort by error
let r_len = len(r_names)
let mut i = 0
while i < r_len - 1 {
    let mut j_idx = 0
    while j_idx < r_len - 1 - i {
        let next_idx = j_idx + 1
        if r_errs[j_idx] > r_errs[next_idx] {
            let tmp_n = r_names[j_idx]
            r_names[j_idx] = r_names[next_idx]
            r_names[next_idx] = tmp_n

            let tmp_f = r_formulas[j_idx]
            r_formulas[j_idx] = r_formulas[next_idx]
            r_formulas[next_idx] = tmp_f

            let tmp_e = r_errs[j_idx]
            r_errs[j_idx] = r_errs[next_idx]
            r_errs[next_idx] = tmp_e

            let tmp_s = r_sources[j_idx]
            r_sources[j_idx] = r_sources[next_idx]
            r_sources[next_idx] = tmp_s
        }
        j_idx = j_idx + 1
    }
    i = i + 1
}

println("  " + pad_r("Constant", 16) + " " + pad_r("Formula", 28) + " " + pad_l("Error", 10) + " " + pad_l("Source", 8))
println("  " + "─".repeat(66))
let mut idx = 0
while idx < r_len {
    let err_val = r_errs[idx]
    let mut err_str = ""
    if err_val < 0.01 {
        err_str = pad_l(to_string(rd2(err_val * 10000.0)) + " ppm", 10)
    } else {
        err_str = pad_l(to_string(rd3(err_val)) + "%", 10)
    }
    println("  " + pad_r(r_names[idx], 16) + " " + pad_r(r_formulas[idx], 28) + " " + err_str + " " + pad_l(r_sources[idx], 8))
    idx = idx + 1
}

// STATISTICAL SUMMARY
println("")
println("══════════════════════════════════════════════════════════")
println("  STATISTICAL SUMMARY")
println("══════════════════════════════════════════════════════════")
println("")

println("  Total checks: " + to_string(total))
println("  Matches (<2%): " + to_string(exact))
let success_rate = exact * 100.0 / total
println("  Success rate: " + to_string(rd0(success_rate)) + "%")
println("")

// Combined p-value estimate
let p_bt20 = 2.3 * pow(10.0, -4.0)
let p_bt21 = 1.3 * pow(10.0, -3.0)
let p_bt22 = 0.002
let p_bt23 = 3.6 * pow(10.0, -4.0)
let p_bt24 = 0.1
let p_bt25 = 1.1 * pow(10.0, -3.0)

println("  p-values (with selection bias correction):")
println("    BT-20 (Gauge Trinity):     " + sci2(p_bt20))
println("    BT-21 (PMNS Trident):      " + sci2(p_bt21))
println("    BT-22 (Inflation):          " + sci2(p_bt22))
println("    BT-23 (CKM Hierarchy):      " + sci2(p_bt23))
println("    BT-24 (Koide):              " + sci1(p_bt24) + " (but 9 ppm!)")
println("    BT-25 (Genetic Code):       " + sci2(p_bt25))
println("")

// Grand total with BT-19
let p_bt19 = 4.3 * pow(10.0, -5.0)
let p_grand = p_bt19 * p_bt20 * p_bt21 * p_bt22 * p_bt23 * p_bt24 * p_bt25
println("  Including BT-19 (GUT hierarchy, p ≈ " + sci1(p_bt19) + "):")
println("    Grand combined: " + sci2(p_grand))
// 1/p_grand is too large for round(), so use sci notation approach
let inv_p = 1.0 / p_grand
println("    = 1 in " + to_string(inv_p))
println("")

