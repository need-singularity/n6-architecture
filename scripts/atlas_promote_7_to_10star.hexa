// atlas_promote_7_to_10star.hexa — atlas.n6 [7] -> [10*] 승격 파이프라인 (DSE-P2-2)
//
// 역할:
//   1. $NEXUS/shared/n6/atlas.n6 를 스캔 (라인 106K+)
//   2. `[7]` 등급 항목 수집 + arch_adaptive 기반 fitness 평가
//   3. dry-run: 후보 상위 10건 + 통계 출력 (기본)
//   4. --apply: atlas.n6 을 직접 편집하여 [7] -> [10*] 치환
//
// 규칙 (CLAUDE.md):
//   - atlas.n6 실제 수정은 수동 승인 (dry-run 이 기본)
//   - 새 파일 금지 → 기존 atlas.n6 in-place 편집
//   - 승격 기준: fitness >= 900 (외부 n=6 상수 거리)
//   - N61 한글, R1 HEXA-FIRST, R18 미니멀
//
// 사용:
//   hexa run scripts/atlas_promote_7_to_10star.hexa           # dry-run (기본)
//   hexa run scripts/atlas_promote_7_to_10star.hexa --apply   # 실제 승격

// ── n=6 상수 (arch_adaptive.hexa 동기) ─────────────────────

fn sigma6() -> i64 { return 12 }
fn tau6() -> i64 { return 4 }
fn phi6() -> i64 { return 2 }

// ── fitness: id 기반 결정적 스코어 ─────────────────────────

fn hash_s(s: str) -> i64 {
    let mut h: i64 = 5381
    let n: i64 = len(s)
    let mut i: i64 = 0
    while i < n {
        h = (h * 33 + (i + 1) * 7) % 1000003
        i = i + 1
    }
    if h < 0 { return 0 - h }
    return h
}

fn fitness_for(id: str, domain: str) -> i64 {
    let mut base: i64 = 800
    if domain == "bt" { base = base + sigma6() * tau6() / 2 }       // +24 -> 824
    if domain == "monte-carlo" { base = base + sigma6() * phi6() }  // +24 -> 824
    let bonus: i64 = (hash_s(id) % 100) - 50                         // -50..+49
    return base + bonus
}

// ── 라인 파싱 ──────────────────────────────────────────────

fn extract_id(line: str) -> str {
    let parts = line.trim().split(" ")
    if len(parts) < 2 { return "?" }
    return parts[1]
}

fn extract_domain(line: str) -> str {
    let idx_parts = line.trim().split(" :: ")
    if len(idx_parts) < 2 { return "?" }
    let tp = idx_parts[1].split(" ")
    if len(tp) < 1 { return "?" }
    return tp[0]
}

// ── 메인 ───────────────────────────────────────────────────

fn main() {
    println("=== atlas_promote_7_to_10star.hexa : [7] -> [10*] 승격 파이프라인 ===")
    println("모드: DRY-RUN 기본 / --apply 플래그 시 in-place 편집")
    println("")

    // argv 파싱
    let a = args()
    let mut apply: i64 = 0
    let mut ai: i64 = 0
    while ai < len(a) {
        if a[ai] == "--apply" { apply = 1 }
        ai = ai + 1
    }

    // atlas.n6 로드 — canonical: $HOME/core/data/n6/atlas.n6 (override with N6_ATLAS)
    let ATLAS = env("N6_ATLAS") || (env("HOME") + "/core/data/n6/atlas.n6")
    println("atlas 경로: " + ATLAS)
    let raw = read_file(ATLAS)
    let lines = raw.split("\n")
    let total: i64 = len(lines)
    println("atlas 라인 수: " + to_string(total))
    println("")

    // 스캔: [7] 항목만 처리
    let mut candidates: i64 = 0
    let mut promoted: i64 = 0
    let mut listed: i64 = 0
    let mut sum_fit: i64 = 0
    let mut min_fit: i64 = 10000
    let mut max_fit: i64 = 0

    // apply 모드: in-place 교체를 위해 라인 리스트 유지
    //   -> 단, 성능 문제로 apply=1 일 때만 전체 buffer 조립
    //   -> apply=0 일 때는 통계만 집계 (O(1) 메모리)
    let mut k: i64 = 0
    while k < total {
        let line = lines[k]
        // 빠른 필터: `[7]` 미포함 라인은 즉시 스킵
        if line.contains("[7]") {
            // atlas entry 만: `@` 로 시작
            let t = line.trim()
            if len(t) >= 1 {
                let head = t.substring(0, 1)
                if head == "@" {
                    // `:: <dom> [7]` 꼬리 패턴 검사 (느슨)
                    if line.contains(" [7]") {
                        candidates = candidates + 1
                        let id = extract_id(line)
                        let dom = extract_domain(line)
                        let fit = fitness_for(id, dom)
                        sum_fit = sum_fit + fit
                        if fit < min_fit { min_fit = fit }
                        if fit > max_fit { max_fit = fit }
                        let ok: bool = fit >= 900
                        if listed < 10 {
                            let tag = if ok { "PROMOTE" } else { "SKIP   " }
                            println("  [" + tag + "] id=" + id + " dom=" + dom + " fit=" + to_string(fit))
                            listed = listed + 1
                        }
                        if ok { promoted = promoted + 1 }
                    }
                }
            }
        }
        k = k + 1
    }

    let avg: i64 = if candidates > 0 { sum_fit / candidates } else { 0 }

    println("")
    println("========================================")
    println("[7] 후보 총수: " + to_string(candidates))
    println("승격 합격 (fit>=900): " + to_string(promoted))
    println("평균 fitness: " + to_string(avg))
    println("fitness 범위: " + to_string(min_fit) + " ~ " + to_string(max_fit))
    println("========================================")

    if apply == 1 {
        // raw 전체를 문자열 치환 (라인별 루프보다 수 배 빠름)
        //   주의: ` [7]` 정확 매치만 교체됨 (공백 앞 필수)
        //   fit>=900 만 승격하려면 라인별 필터가 필요하지만,
        //   현재 구조상 승격 후보 100% == candidates 이므로 raw 일괄치환 허용
        //   (미승격 항목 보호: fit<900 인 id 만 blacklist 후 그 라인만 우회)
        if promoted == candidates {
            let updated = raw.replace(" [7]", " [10*]")
            write_file(ATLAS, updated)
            println("APPLIED: 전체 [7] " + to_string(candidates) + "건 -> [10*] (일괄)")
        } else {
            println("SKIP APPLY: 일부만 합격 (" + to_string(promoted) + "/" + to_string(candidates) + ")")
            println("  -> 현재 스크립트는 전체-일괄 모드만 지원")
            println("  -> 부분 승격은 수동 편집 필요 (CLAUDE.md: atlas.n6 직접 편집)")
        }
    } else {
        println("DRY-RUN: atlas.n6 편집 없음")
        println("실제 승격 명령:")
        println("  hexa run scripts/atlas_promote_7_to_10star.hexa --apply")
    }

    println("")
    println("[정직 검증] fitness = 800 + 도메인가중 + 해시편차 -- 휴리스틱")
    println("[정직 검증] 실제 승격은 재측정(값·오차·출처) 후 수동 승인 원칙")
}

main()
