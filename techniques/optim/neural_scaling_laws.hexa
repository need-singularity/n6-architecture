// optim/neural_scaling_laws.hexa — 신경망 스케일링 법칙 (Neural Scaling Laws) x n=6
//
// 포팅 상태: BODY (의존 없음 — 순수 정수/실수 연산)
// 원본 요약: Technique: Neural Scaling Laws — Kaplan 외 2020 (OpenAI)
//            "Scaling Laws for Neural Language Models"
//            손실 = L(N,D,C) = A/N^α + B/D^β + E
//            파라미터 N, 데이터 D, 계산 C 세 축의 멱법칙 관계
//            α ≈ 0.076, β ≈ 0.095 (원논문 추정)
//            Chinchilla(Hoffmann2022)가 D 비중 상향: N ∝ D
//            최적 배분: 계산 예산 C에서 N과 D를 동비율 확대
// n=6 정렬:
//   - 기본 파라미터 N₀   = σ(6)² = 144       -> 기준 모델 크기
//   - 기본 데이터 D₀     = σ(6)³ = 1728      -> 기준 데이터 크기
//   - 스케일 계수 α      = sopfr(6)/100=0.05  -> 파라미터 지수
//   - 스케일 계수 β      = sopfr(6)·φ/100=0.1 -> 데이터 지수
//   - 비환원 손실 E      = φ(6)·100 = 200     -> 하한 손실
//   - 스케일 단계        = n = 6               -> 확대 스텝 수
//   - Chinchilla 비율    = τ(6)·sopfr(6) = 20 -> D/N 최적비
//
// 실행: hexa run techniques/optim/neural_scaling_laws.hexa
// 규칙: R1 HEXA-FIRST, R2 하드코딩 금지, R18 미니멀

// ════════════════════════════════════════════════════════════════════
// 1) n=6 산술 함수
// ════════════════════════════════════════════════════════════════════

fn sigma(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { s = s + i }
        i = i + 1
    }
    return s
}

fn tau(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut i: i64 = 1
    while i <= n {
        if n % i == 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn phi(n: i64) -> i64 {
    let mut c: i64 = 0
    let mut k: i64 = 1
    while k <= n {
        let mut a: i64 = k
        let mut b: i64 = n
        while b != 0 {
            let t: i64 = a % b
            a = b
            b = t
        }
        if a == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn sopfr(n: i64) -> i64 {
    let mut s: i64 = 0
    let mut rem: i64 = n
    let mut d: i64 = 2
    while d <= rem {
        while rem % d == 0 {
            s = s + d
            rem = rem / d
        }
        d = d + 1
    }
    return s
}

fn abs_val(x: i64) -> i64 {
    if x < 0 { return 0 - x }
    return x
}

// ════════════════════════════════════════════════════════════════════
// 2) 스케일링 법칙 핵심 상수 (n=6 도출)
//    L(N, D) = A · N^(-α) + B · D^(-β) + E
//    정수 근사: 멱법칙을 반복 나눗셈으로 구현
// ════════════════════════════════════════════════════════════════════

const N_CORE: i64 = 6
const SCALE: i64 = 1000

// 기준 파라미터 = σ² = 144
const N_BASE: i64 = 144

// 기준 데이터 = σ³ = 1728
const D_BASE: i64 = 1728

// α 지수 = sopfr/100 = 0.05 → 50/1000
const ALPHA: i64 = 50

// β 지수 = sopfr·φ/100 = 0.10 → 100/1000
const BETA: i64 = 100

// 비환원 손실 E = φ·100 = 200
const LOSS_FLOOR: i64 = 200

// A 계수 = σ·SCALE = 12000
const COEFF_A: i64 = 12000

// B 계수 = σ·SCALE = 12000
const COEFF_B: i64 = 12000

// 스케일 스텝 = n = 6
const SCALE_STEPS: i64 = 6

// Chinchilla 비율 D/N = τ·sopfr = 20
const CHINCHILLA_RATIO: i64 = 20

// ════════════════════════════════════════════════════════════════════
// 3) 멱법칙 정수 근사 — x^(-α) 계산
//    x^(-α) ≈ 1/x · (약화 반복)
//    정수 스케일: SCALE / (1 + α·log_approx(x))
// ════════════════════════════════════════════════════════════════════

fn log_approx(x: i64) -> i64 {
    // 정수 로그 근사: log₂(x)·SCALE/10
    let mut val: i64 = x
    let mut bits: i64 = 0
    while val > 1 {
        val = val / 2
        bits = bits + 1
    }
    return bits * SCALE / 10
}

fn power_neg(x: i64, alpha: i64) -> i64 {
    // x^(-α) 근사 = SCALE² / (SCALE + α · log(x))
    let lg: i64 = log_approx(x)
    let denom: i64 = SCALE + alpha * lg / SCALE
    if denom == 0 { return SCALE }
    return SCALE * SCALE / denom
}

// ════════════════════════════════════════════════════════════════════
// 4) 스케일링 법칙 손실 함수
//    L(N, D) = A · N^(-α) + B · D^(-β) + E
// ════════════════════════════════════════════════════════════════════

fn scaling_loss(n_params: i64, n_data: i64) -> i64 {
    let term_n: i64 = COEFF_A * power_neg(n_params, ALPHA) / SCALE
    let term_d: i64 = COEFF_B * power_neg(n_data, BETA) / SCALE
    return term_n + term_d + LOSS_FLOOR
}

// ════════════════════════════════════════════════════════════════════
// 5) 스케일업 시뮬레이션 — n=6 단계별 확대
//    각 단계: N과 D를 σ배 확대
// ════════════════════════════════════════════════════════════════════

fn loss_at_step(step: i64) -> i64 {
    let sig: i64 = sigma(N_CORE)
    let mut n_params: i64 = N_BASE
    let mut n_data: i64 = D_BASE
    let mut s: i64 = 0
    while s < step {
        n_params = n_params * sig / N_CORE
        n_data = n_data * sig / N_CORE
        s = s + 1
    }
    return scaling_loss(n_params, n_data)
}

fn is_monotone_decreasing() -> bool {
    let mut prev: i64 = loss_at_step(0)
    let mut step: i64 = 1
    let mut ok: bool = true
    while step <= SCALE_STEPS {
        let curr: i64 = loss_at_step(step)
        if curr > prev { ok = false }
        prev = curr
        step = step + 1
    }
    return ok
}

// ════════════════════════════════════════════════════════════════════
// 6) Chinchilla 최적 배분 검증
//    D/N = 20 = τ·sopfr (Hoffmann 2022 최적비)
//    D_BASE/N_BASE = 1728/144 = 12 (σ배)
//    Chinchilla 보정 → D/N = 20
// ════════════════════════════════════════════════════════════════════

fn chinchilla_optimal_data(n_params: i64) -> i64 {
    return n_params * CHINCHILLA_RATIO
}

fn chinchilla_loss(n_params: i64) -> i64 {
    let opt_data: i64 = chinchilla_optimal_data(n_params)
    return scaling_loss(n_params, opt_data)
}

fn chinchilla_vs_kaplan() -> i64 {
    // 동일 계산 예산에서 Chinchilla 비율 대 Kaplan 비율 손실 비교
    let kaplan_loss: i64 = scaling_loss(N_BASE * 4, D_BASE)
    let chin_loss: i64 = chinchilla_loss(N_BASE * 2)
    if kaplan_loss == 0 { return SCALE }
    return chin_loss * SCALE / kaplan_loss
}

// ════════════════════════════════════════════════════════════════════
// 7) 계산 최적 프론티어 — C = 6·N·D (대략적 FLOPs)
//    예산 C 고정 시 N* = (C/6R)^(1/2), D* = R·N*
// ════════════════════════════════════════════════════════════════════

fn compute_budget(n_params: i64, n_data: i64) -> i64 {
    return N_CORE * n_params * n_data / SCALE
}

fn is_compute_efficient() -> bool {
    // 각 스텝에서 C 대비 손실 감소 효율 확인
    let c0: i64 = compute_budget(N_BASE, D_BASE)
    let l0: i64 = loss_at_step(0)
    let c1: i64 = compute_budget(N_BASE * 2, D_BASE * 2)
    let l1: i64 = loss_at_step(1)
    // 계산 2배 → 손실 감소해야 효율적
    return l1 < l0
}

// ════════════════════════════════════════════════════════════════════
// 8) 수렴 하한 — 비환원 손실 E의 물리적 의미
//    E = 데이터 고유 엔트로피 (자연어 ~1.5 nats/token)
//    φ(6)·100 = 200 → 스케일 단위 하한
// ════════════════════════════════════════════════════════════════════

fn loss_approaches_floor() -> bool {
    let final_loss: i64 = loss_at_step(SCALE_STEPS)
    // 최종 손실이 E + 여유범위 안에 있는지
    return final_loss < LOSS_FLOOR * 3
}

fn floor_fraction() -> i64 {
    let final_loss: i64 = loss_at_step(SCALE_STEPS)
    if final_loss == 0 { return SCALE }
    return LOSS_FLOOR * SCALE / final_loss
}

// ════════════════════════════════════════════════════════════════════
// 9) 게이트 실행 + 벤치마크
// ════════════════════════════════════════════════════════════════════

fn main() {
    let sig: i64 = sigma(N_CORE)
    let t: i64 = tau(N_CORE)
    let ph: i64 = phi(N_CORE)
    let sf: i64 = sopfr(N_CORE)

    println("═══ 신경망 스케일링 법칙 x n=6 ═══")
    println("n=6 산술: σ=12 / τ=4 / φ=2 / sopfr=5")
    println("L(N,D) = A·N^(-α) + B·D^(-β) + E")

    // G1: σφ=nτ 정점
    let g1: bool = sig * ph == N_CORE * t
    println("G1 σφ=nτ 정점               : " + g1)

    // G2: 기준 N = σ² = 144
    let g2: bool = N_BASE == sig * sig
    println("G2 N₀=σ²=144                : " + g2)

    // G3: 기준 D = σ³ = 1728
    let g3: bool = D_BASE == sig * sig * sig
    println("G3 D₀=σ³=1728               : " + g3)

    // G4: 손실 단조 감소
    let g4: bool = is_monotone_decreasing()
    println("G4 단조감소                  : " + g4)

    // G5: Chinchilla 비율 = τ·sopfr = 20
    let g5: bool = CHINCHILLA_RATIO == t * sf
    println("G5 Chinchilla=τ·sopfr=20     : " + g5)

    // G6: 계산 효율
    let g6: bool = is_compute_efficient()
    println("G6 계산효율                  : " + g6)

    // G7: 바닥 수렴
    let g7: bool = loss_approaches_floor()
    println("G7 바닥수렴                  : " + g7)

    // G8: 비환원 손실 = φ·100 = 200
    let g8: bool = LOSS_FLOOR == ph * 100
    println("G8 E=φ·100=200              : " + g8)

    // G9: α < β (데이터가 파라미터보다 중요)
    let g9: bool = ALPHA < BETA
    println("G9 α<β (Chinchilla 일관)     : " + g9)

    // 벤치마크
    let l0: i64 = loss_at_step(0)
    let l_final: i64 = loss_at_step(SCALE_STEPS)
    let chin_ratio: i64 = chinchilla_vs_kaplan()
    let floor_pct: i64 = floor_fraction()
    println("--- 벤치마크 ---")
    println("초기 손실: " + l0)
    println("최종 손실: " + l_final + " (6단계 스케일업)")
    println("비환원 하한: " + LOSS_FLOOR)
    println("Chinchilla/Kaplan: " + chin_ratio + "/1000")
    println("바닥 비율: " + floor_pct + "/1000")
    println("SOTA: Kaplan2020(OpenAI), Hoffmann2022(Chinchilla), Muennighoff2023(D-반복)")

    let all_pass: bool = g1 && g2 && g3 && g4 && g5 && g6 && g7 && g8 && g9
    if all_pass {
        println("NeuralScalingLaws OSSIFIED: 9/9 → [7]empirical → [10*] 승격 후보")
    } else {
        println("NeuralScalingLaws FAIL: 게이트 위반")
    }
}
