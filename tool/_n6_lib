# ────────────────────────────────────────────────────────────
# Phase 3.12 — falsification preservation
# ────────────────────────────────────────────────────────────
scan_falsification() {
  local out="reports/n6_falsification.json"
  local result
  result=$(python3 - <<'PY'
from math import gcd
def sigma(n): return sum(i for i in range(1,n+1) if n%i==0)
def tau(n):   return sum(1 for i in range(1,n+1) if n%i==0)
def phi(n):   return sum(1 for k in range(1,n+1) if gcd(k,n)==1)
def check(n):
    return sigma(n)*phi(n) == n*tau(n)
print(f"{int(check(28))}|{int(check(496))}|{int(check(8128))}")
PY
  )
  local n28=$(echo "$result" | cut -d'|' -f1)
  local n496=$(echo "$result" | cut -d'|' -f2)
  local n8128=$(echo "$result" | cut -d'|' -f3)
  local n28_falsified=true;   [ "$n28" = "1" ] && n28_falsified=false
  local n496_falsified=true;  [ "$n496" = "1" ] && n496_falsified=false
  local n8128_falsified=true; [ "$n8128" = "1" ] && n8128_falsified=false
  local alarm=false
  [ "$n28" = "1" ] && alarm=true
  [ "$n496" = "1" ] && alarm=true
  [ "$n8128" = "1" ] && alarm=true
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_falsification/1",
  "ts": "$(ts)",
  "cases": [
    {"n": 28,   "type": "perfect_number", "still_fails": $n28_falsified},
    {"n": 496,  "type": "perfect_number", "still_fails": $n496_falsified},
    {"n": 8128, "type": "perfect_number", "still_fails": $n8128_falsified}
  ],
  "critical_alarm": $alarm,
  "status": "$([ "$alarm" = "true" ] && echo RED || echo GREEN)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

