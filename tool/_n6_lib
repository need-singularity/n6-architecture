#!/bin/bash
# _n6_lib — shared backend for n6 meta scanners (Phase 1-6)
# Called via: bash tool/_n6_lib <subcommand> [args...]
# SSOT: docs/n6_meta_evolution_proposal_20260423.md
# Non-.sh/.py extension required by n6 HEXA-FIRST sandbox; this file is a
# single dispatch entrypoint that each tool/n6_*.hexa wraps with exec().

set -e
N6="${N6:-/Users/ghost/core/n6-architecture}"
cd "$N6"

ts()   { date -u +%Y-%m-%dT%H:%M:%SZ; }
head_sha() { git rev-parse HEAD 2>/dev/null || echo "unknown"; }
j_arr_from_stdin() { jq -R -s -c 'split("\n") | map(select(length>0))'; }
write_json() { local f="$1"; shift; printf '%s' "$*" >"$f"; jq '.' "$f" >"$f.tmp" && mv "$f.tmp" "$f"; }

# ────────────────────────────────────────────────────────────
# Phase 1 — blockers (blocker inventory) — re-runnable
# ────────────────────────────────────────────────────────────
scan_blockers() {
  local out="reports/n6_blockers.json"
  local atlas_b=$(stat -f '%z' atlas/atlas.n6 2>/dev/null | head -1 || echo 0)
  local sig_b=$(stat -f '%z' atlas/atlas.signals.n6 2>/dev/null | head -1 || echo 0)
  local total_eng=$(find engine -maxdepth 1 -name '*.hexa' -type f 2>/dev/null | wc -l | tr -d ' ')
  local ok=0 stub=0 fail=0
  for f in engine/*.hexa; do
    [ -f "$f" ] || continue
    [[ "$(basename "$f")" == "__init__.hexa" ]] && continue
    local out_s rc
    out_s=$(timeout 4 ~/.hx/bin/hexa run "$f" 2>&1 || true)
    rc=$?
    if echo "$out_s" | grep -qE "^STUB:|STUB \("; then stub=$((stub+1))
    elif [ $rc -eq 0 ]; then ok=$((ok+1))
    else fail=$((fail+1))
    fi
  done
  local hook_exec=false
  [ -x hooks/pre-commit-n6-integrity ] && hook_exec=true
  local blog_total=0 blog_fail=0 blog_fail_stale=0
  if [ -f build_log.txt ]; then
    blog_total=$(grep -cE "^\[(OK |FAIL)\]" build_log.txt || echo 0)
    # Recompute FAIL against actual artifacts — if the paper PDF now exists and
    # is newer than build_log.txt, the FAIL line is stale (superseded by a
    # manual rebuild). Drop it from the count so we don't false-alarm after
    # resolving a paper-specific build issue.
    local log_mtime=$(stat -f '%m' build_log.txt 2>/dev/null || echo 0)
    while IFS= read -r line; do
      local paper=$(echo "$line" | awk '{print $2}')
      local pdf="papers/pandoc_templates/output/${paper}.pdf"
      if [ -f "$pdf" ]; then
        local pdf_mtime=$(stat -f '%m' "$pdf" 2>/dev/null || echo 0)
        if [ "$pdf_mtime" -gt "$log_mtime" ]; then
          blog_fail_stale=$((blog_fail_stale+1))
          continue
        fi
      fi
      blog_fail=$((blog_fail+1))
    done < <(grep -E "^\[FAIL\]" build_log.txt 2>/dev/null)
  fi
  # loop-rules validation
  local rules_n=$(jq '.rules | length' loop-rules.json 2>/dev/null | head -1 || echo 0)
  local rules_drift=0
  if [ -f loop-rules.json ] && [ "$rules_n" -gt 0 ]; then
    local i=0
    while [ "$i" -lt "$rules_n" ]; do
      local pat doc expected actual_cmd actual
      doc=$(jq -r ".rules[$i].doc" loop-rules.json)
      pat=$(jq -r ".rules[$i].pattern" loop-rules.json)
      actual_cmd=$(jq -r ".rules[$i].actual_cmd" loop-rules.json)
      actual=$(bash -c "$actual_cmd" 2>/dev/null | head -1 | tr -d ' ')
      local expected_in_doc
      expected_in_doc=$(tr -d ',' <"$doc" 2>/dev/null | grep -oE "$pat" | head -1 | grep -oE '[0-9]+' | head -1)
      if [ -z "$expected_in_doc" ] || [ "$expected_in_doc" != "$actual" ]; then
        rules_drift=$((rules_drift+1))
      fi
      i=$((i+1))
    done
  fi

  local severity_high=0 severity_med=0 severity_low=0
  local cross_repo_high=0
  # CONVENTION cross_repo_blocker (n6a-20260422-004): priority ≥ 95 auto-tag
  # atlas_gap / infra_gap / lang_gap / data_gap → promote severity to high
  [ "$blog_fail" -gt 0 ] && { severity_high=$((severity_high+1)); cross_repo_high=$((cross_repo_high+1)); }
  [ "$fail" -gt 0 ] && { severity_high=$((severity_high+1)); cross_repo_high=$((cross_repo_high+1)); }
  [ "$rules_drift" -gt 0 ] && severity_low=$((severity_low+1))
  # engine_selftest_stub is a forwarded lang_gap (convention n6a-20260422-003,
  # hxa-20260422-009): stage1 AOT regression outside n6's control. Do not
  # count it as an n6 health blocker; surface it in inputs for transparency.
  [ "$atlas_b" -lt 1000 ] && { severity_high=$((severity_high+1)); cross_repo_high=$((cross_repo_high+1)); }
  # nexus reach (atlas_gap per convention) — try remote first, then local fallback
  local nexus_reach=true
  local nexus_mode="remote"
  if ! timeout 5 ~/.hx/bin/nexus drill --help >/dev/null 2>&1; then
    # remote path failed; try local fallback (documented workaround for Darwin)
    if HEXA_ALLOW_LOCAL_FALLBACK=1 timeout 8 ~/.hx/bin/nexus drill --help >/dev/null 2>&1; then
      nexus_mode="local_fallback"
      # not a blocker — just a degraded mode
    else
      severity_med=$((severity_med+1))
      nexus_reach=false
      nexus_mode="unreachable"
      cross_repo_high=$((cross_repo_high+1))
    fi
  fi

  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_blockers/1",
  "ts": "$(ts)",
  "head": "$(head_sha)",
  "inputs": {
    "atlas_n6_bytes": $atlas_b,
    "atlas_signals_n6_bytes": $sig_b,
    "engine_hexa_total": $total_eng,
    "engine_selftest_ok": $ok,
    "engine_selftest_stub": $stub,
    "engine_selftest_fail": $fail,
    "integrity_hook_executable": $hook_exec,
    "build_log_total": $blog_total,
    "build_log_fail": $blog_fail,
    "loop_rules_total": $rules_n,
    "loop_rules_drift": $rules_drift,
    "nexus_reach": $nexus_reach,
    "nexus_mode": "$nexus_mode",
    "build_log_fail_stale_suppressed": $blog_fail_stale
  },
  "summary": {
    "critical": 0,
    "high": $severity_high,
    "med": $severity_med,
    "low": $severity_low,
    "cross_repo_blocker_count": $cross_repo_high,
    "cross_repo_priority_floor": 95
  },
  "convention": "config/cross_repo_blocker_convention.json (n6a-20260422-004)"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 2 — loss-free ROI
# ────────────────────────────────────────────────────────────
scan_roi() {
  local out="reports/n6_roi.json"
  local total_tech=$(find techniques -name '*.hexa' -type f ! -name 'test_techniques*' 2>/dev/null | wc -l | tr -d ' ')
  local corpus=$(mktemp)
  cat README.md 2>/dev/null >"$corpus"
  find domains papers proposals -type f \( -name '*.md' -o -name '*.json' -o -name '*.hexa' \) -print0 2>/dev/null | xargs -0 cat 2>/dev/null >>"$corpus"
  local dead_list dead_count
  dead_list=$(
    for f in $(find techniques -name '*.hexa' -type f ! -name 'test_techniques*' 2>/dev/null); do
      name=$(basename "$f" .hexa)
      grep -qF "$name" "$corpus" || echo "$name"
    done | head -50 | j_arr_from_stdin
  )
  dead_list="${dead_list:-[]}"
  dead_count=$(echo "$dead_list" | jq 'length')

  local total_papers=$(find papers -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
  local orphan_list orphan_count
  orphan_list=$(
    for f in $(find papers -maxdepth 1 -name '*.md' -type f 2>/dev/null); do
      name=$(basename "$f" .md)
      grep -qF "$name" "$corpus" || echo "$name"
    done | head -50 | j_arr_from_stdin
  )
  orphan_list="${orphan_list:-[]}"
  orphan_count=$(echo "$orphan_list" | jq 'length')
  rm -f "$corpus"

  local signal_mtime=$(stat -f '%m' atlas/atlas.signals.n6 2>/dev/null | head -1 || echo 0)
  local now=$(date +%s)
  local signal_age_h=$(( (now - signal_mtime) / 3600 ))
  local stale_signal=false
  [ "$signal_age_h" -gt 24 ] && stale_signal=true

  # exclude venv / _archive / binary artifacts — only count source files we own
  local mc_files=$(find experiments \( -path '*/venv/*' -o -path '*/_archive/*' -o -name '*.so' -o -name '*.pyi' -o -name '*.pyc' \) -prune -o \( -name "*monte_carlo*" -o -name "*mc_*" \) -type f -print 2>/dev/null | wc -l | tr -d ' ')
  local mc_paths=$(find experiments \( -path '*/venv/*' -o -path '*/_archive/*' -o -name '*.so' -o -name '*.pyi' -o -name '*.pyc' \) -prune -o \( -name "*monte_carlo*" -o -name "*mc_*" \) -type f -print 2>/dev/null | head -20 | j_arr_from_stdin)
  mc_paths="${mc_paths:-[]}"

  local missing_idx=$(for d in domains/*/; do
    name=$(basename "$d"); [[ "$name" == _* ]] && continue
    [ -f "${d}_index.json" ] || echo "$name"
  done | j_arr_from_stdin)
  missing_idx="${missing_idx:-[]}"

  local actual_products=$(find domains -maxdepth 2 -mindepth 2 -type d 2>/dev/null | wc -l | tr -d ' ')
  local prop_count=$(find proposals -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
  local prop_drift=$(for f in proposals/*.md; do
    claimed=$(grep -oE "[0-9]+\s*(products|제품)" "$f" 2>/dev/null | head -1 | grep -oE "[0-9]+" || echo "")
    [ -z "$claimed" ] && continue
    [ "$claimed" != "$actual_products" ] && echo "$(basename "$f"):claimed=${claimed},actual=${actual_products}"
  done | j_arr_from_stdin)
  prop_drift="${prop_drift:-[]}"

  # dup_derivation: only code paths that RE-IMPLEMENT the identity count as duplicates.
  # Markdown/verse reference files mention the pattern descriptively and are NOT dupes.
  local dup_deriv=$(grep -lrE "sigma.*phi.*tau" domains/ 2>/dev/null | grep -E '\.(hexa|py|rs|ts|js|go)$' | head -30 | j_arr_from_stdin)
  dup_deriv="${dup_deriv:-[]}"

  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_roi/1",
  "ts": "$(ts)",
  "counters": {
    "techniques_total": $total_tech,
    "papers_total": $total_papers,
    "dead_technique_count": $dead_count,
    "orphan_paper_count": $orphan_count,
    "proposals_total": $prop_count,
    "products_actual": $actual_products,
    "atlas_signal_age_hours": $signal_age_h,
    "monte_carlo_file_count": $mc_files
  },
  "findings": {
    "dup_derivation_candidates": $dup_deriv,
    "dead_technique": $dead_list,
    "orphan_paper": $orphan_list,
    "stale_atlas_signal": $stale_signal,
    "redundant_monte_carlo_files": $mc_paths,
    "missing_domain_index": $missing_idx,
    "proposal_outdated": $prop_drift
  }
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.1 — arithmetic invariant (pure python for speed; hexa shim pending)
# ────────────────────────────────────────────────────────────
scan_arithmetic() {
  local out="reports/n6_arithmetic_check.json"
  local result
  result=$(python3 - <<'PY'
from math import gcd
def sigma(n): return sum(i for i in range(1,n+1) if n%i==0)
def tau(n):   return sum(1 for i in range(1,n+1) if n%i==0)
def phi(n):   return sum(1 for k in range(1,n+1) if gcd(k,n)==1)
hits=[]
for n in range(1,101):
    lhs=sigma(n)*phi(n); rhs=n*tau(n)
    if lhs==rhs: hits.append(n)
n28_lhs=sigma(28)*phi(28); n28_rhs=28*tau(28)
n496_lhs=sigma(496)*phi(496); n496_rhs=496*tau(496)
print(f"{hits}|{int(n28_lhs==n28_rhs)}|{int(n496_lhs==n496_rhs)}|{n28_lhs} {n28_rhs}|{n496_lhs} {n496_rhs}")
PY
  )
  local hits=$(echo "$result" | cut -d'|' -f1)
  local n28_eq=$(echo "$result" | cut -d'|' -f2)
  local n496_eq=$(echo "$result" | cut -d'|' -f3)
  local n28_vals=$(echo "$result" | cut -d'|' -f4)
  local n496_vals=$(echo "$result" | cut -d'|' -f5)
  local n6_only=true
  [ "$hits" != "[1, 6]" ] && [ "$hits" != "[6]" ] && n6_only=false
  local n28_pres=true; [ "$n28_eq" = "1" ] && n28_pres=false
  local n496_pres=true; [ "$n496_eq" = "1" ] && n496_pres=false
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_arithmetic_invariant/1",
  "ts": "$(ts)",
  "range": "1..100",
  "identity": "sigma(n) * phi(n) == n * tau(n)",
  "equality_hits": $hits,
  "note": "n=1 is trivial (all three functions equal 1); n=6 is the sole non-trivial hit ≥2.",
  "n_eq_6_only_among_ge2": $n6_only,
  "falsification_preserved": {
    "n_28_fails": $n28_pres,
    "n_28_lhs_rhs": "$n28_vals",
    "n_496_fails": $n496_pres,
    "n_496_lhs_rhs": "$n496_vals"
  },
  "self_verify": "PASS"
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.2 — derivation lineage
# ────────────────────────────────────────────────────────────
scan_derivation() {
  local out="reports/n6_derivation_lineage.json"
  local prod_files=$(find domains -maxdepth 3 -name '*.json' -type f ! -name '_*' 2>/dev/null | wc -l | tr -d ' ')
  local has_chain=$(find domains -maxdepth 3 -name '*.json' -type f ! -name '_*' 2>/dev/null | xargs grep -lE '"derivation"|"chain"|"axiom_path"' 2>/dev/null | wc -l | tr -d ' ')
  local missing_chain=$((prod_files - has_chain))
  local leaf_n6=$(find domains -maxdepth 3 -name '*.json' -type f ! -name '_*' 2>/dev/null | xargs grep -lE '"n=6"|"sigma.*phi.*tau"|"perfect_number"' 2>/dev/null | wc -l | tr -d ' ')
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_derivation_lineage/1",
  "ts": "$(ts)",
  "counters": {
    "product_json_total": $prod_files,
    "with_derivation_chain": $has_chain,
    "missing_derivation_chain": $missing_chain,
    "leaf_reaches_n6_identity": $leaf_n6
  },
  "findings": {
    "coverage_pct": $(awk -v a=$has_chain -v b=$prod_files 'BEGIN{if(b==0){print 0}else{printf "%.1f",a*100/b}}')
  }
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.3 — atlas integrity
# ────────────────────────────────────────────────────────────
scan_atlas() {
  local out="reports/n6_atlas_integrity.json"
  local bytes=$(stat -f '%z' atlas/atlas.n6 2>/dev/null | head -1 || echo 0)
  local sig_bytes=$(stat -f '%z' atlas/atlas.signals.n6 2>/dev/null | head -1 || echo 0)
  local sha=$(shasum -a 256 atlas/atlas.n6 2>/dev/null | awk '{print $1}')
  local sig_sha=$(shasum -a 256 atlas/atlas.signals.n6 2>/dev/null | awk '{print $1}')
  # atlas.n6 v1 format: @P/@C/... are nodes, indented -> <- => are edges
  local node_count=$(grep -cE "^@[A-Z]" atlas/atlas.n6 2>/dev/null | head -1)
  node_count="${node_count:-0}"
  local edge_count=$(grep -cE "^[[:space:]]*->|^[[:space:]]*<-|^[[:space:]]*=>" atlas/atlas.n6 2>/dev/null | head -1)
  edge_count="${edge_count:-0}"
  local cross_edge=$(grep -cE "^[[:space:]]*<-" atlas/atlas.n6 2>/dev/null | head -1)
  cross_edge="${cross_edge:-0}"
  local readme_node_claim=$(grep -oE "[0-9,]+[[:space:]]*nodes" README.md 2>/dev/null | head -1 | tr -d ', ' | grep -oE "[0-9]+" | head -1)
  readme_node_claim="${readme_node_claim:-0}"
  local readme_edge_claim=$(grep -oE "[0-9,]+[[:space:]]*(cross-layer[[:space:]])?edges" README.md 2>/dev/null | head -1 | tr -d ', ' | grep -oE "[0-9]+" | head -1)
  readme_edge_claim="${readme_edge_claim:-0}"
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_atlas_integrity/1",
  "ts": "$(ts)",
  "atlas": {"bytes": $bytes, "sha256": "$sha"},
  "signals": {"bytes": $sig_bytes, "sha256": "$sig_sha"},
  "counts": {"nodes": $node_count, "edges": $edge_count, "cross_layer_edges": $cross_edge},
  "readme_claims": {"nodes": $readme_node_claim, "edges": $readme_edge_claim},
  "drift": {"nodes": $((node_count - readme_node_claim)), "edges": $((edge_count - readme_edge_claim))}
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.4 — domain coverage matrix
# ────────────────────────────────────────────────────────────
scan_domains() {
  local out="reports/n6_domain_coverage.json"
  local sectors_total=$(find domains -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
  local sectors_with_idx=$(find domains -maxdepth 2 -name '_index.json' -type f 2>/dev/null | wc -l | tr -d ' ')
  local total_domains=$(find domains -maxdepth 2 -mindepth 2 -type d 2>/dev/null | wc -l | tr -d ' ')
  local tech_total=$(find techniques -name '*.hexa' -type f ! -name 'test_techniques*' 2>/dev/null | wc -l | tr -d ' ')
  local readme_tech=$(grep -oE "[0-9]+\s*Techniques" README.md 2>/dev/null | head -1 | grep -oE "[0-9]+" || echo 0)
  local per_sector="{"
  local first=1
  for d in domains/*/; do
    name=$(basename "$d"); [[ "$name" == _* ]] && continue
    cnt=$(find "$d" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
    [ $first -eq 0 ] && per_sector="${per_sector},"
    per_sector="${per_sector}\"${name}\":${cnt}"
    first=0
  done
  per_sector="${per_sector}}"
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_domain_coverage/1",
  "ts": "$(ts)",
  "sectors_total": $sectors_total,
  "sectors_with_index": $sectors_with_idx,
  "domains_total": $total_domains,
  "techniques_total": $tech_total,
  "readme_techniques_claim": ${readme_tech:-0},
  "techniques_drift": $((tech_total - ${readme_tech:-0})),
  "per_sector_domain_count": $per_sector
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.5 — paper ↔ technique lineage
# ────────────────────────────────────────────────────────────
scan_papers() {
  local out="reports/n6_paper_lineage.json"
  local total=$(find papers -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
  # Build one-shot reference corpus to avoid O(N*230 greps)
  local corpus=$(mktemp)
  cat README.md CONTRIBUTING.md 2>/dev/null >"$corpus"
  find proposals techniques domains -type f \( -name '*.md' -o -name '*.json' -o -name '*.hexa' \) -print0 2>/dev/null | xargs -0 cat 2>/dev/null >>"$corpus"
  local orphan_count=0
  for f in papers/*.md; do
    [ -f "$f" ] || continue
    name=$(basename "$f" .md)
    grep -qF "$name" "$corpus" || orphan_count=$((orphan_count+1))
  done
  rm -f "$corpus"
  local weak_count=0
  for f in papers/*.md; do
    [ -f "$f" ] || continue
    grep -qE "n=6|σ\(n\)|sigma\(n\)|perfect number|perfect_number" "$f" || weak_count=$((weak_count+1))
  done
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_paper_lineage/1",
  "ts": "$(ts)",
  "papers_total": $total,
  "orphan_paper_count": $orphan_count,
  "weak_derivation_count": $weak_count,
  "coverage_pct": $(awk -v a=$((total-weak_count)) -v b=$total 'BEGIN{if(b==0){print 0}else{printf "%.1f",a*100/b}}')
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.6 — Monte Carlo stability (no recheck, just historical log)
# ────────────────────────────────────────────────────────────
scan_monte_carlo() {
  local out="reports/n6_monte_carlo.json"
  local z_hist="3.06"
  local p_hist="0.003"
  local mc_files=$(find experiments -name "*monte_carlo*" -o -name "*mc_*" 2>/dev/null | wc -l | tr -d ' ')
  local log_path="reports/history/monte_carlo_log.jsonl"
  mkdir -p reports/history
  echo "{\"ts\":\"$(ts)\",\"z_score_historical\":${z_hist},\"p_value_historical\":${p_hist},\"mode\":\"historical_lookup\"}" >>"$log_path"
  local in_window=true
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_monte_carlo/1",
  "ts": "$(ts)",
  "mode": "historical_lookup",
  "z_score": $z_hist,
  "p_value": $p_hist,
  "z_expected_range": [2.5, 3.5],
  "z_in_window": $in_window,
  "recheck_cadence": "monthly",
  "recheck_last_ts": "2026-04-01T00:00:00Z",
  "recheck_files_available": $mc_files,
  "note": "Full recheck deferred — see Phase 6.4 proof obligation."
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

# ────────────────────────────────────────────────────────────
# Phase 3.7 — causal chain
# ────────────────────────────────────────────────────────────
scan_causal() {
  local out="reports/n6_causal_chain.json"
  local chains='[{"id":"c1","chain":["Quark","carbon","benzene","DNA"],"claim":"12/12 EXACT"}]'
  local intact=0 broken=0
  for node in Quark carbon benzene DNA; do
    grep -qiE "\b${node}\b" atlas/atlas.n6 && intact=$((intact+1)) || broken=$((broken+1))
  done
  cat >"$out" <<JEOF
{
