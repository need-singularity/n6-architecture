# ────────────────────────────────────────────────────────────
# Phase 3.10 — loop rule execution
# ────────────────────────────────────────────────────────────
scan_loop_rules() {
  local out="reports/n6_loop_rules.json"
  local n=$(jq '.rules | length' loop-rules.json 2>/dev/null | head -1 || echo 0)
  local results="["
  local i=0
  local pass=0 drift=0
  while [ "$i" -lt "$n" ]; do
    local doc pat actual_cmd label actual expected_in_doc status
    doc=$(jq -r ".rules[$i].doc" loop-rules.json)
    pat=$(jq -r ".rules[$i].pattern" loop-rules.json)
    actual_cmd=$(jq -r ".rules[$i].actual_cmd" loop-rules.json)
    label=$(jq -r ".rules[$i].label" loop-rules.json)
    actual=$(bash -c "$actual_cmd" 2>/dev/null | head -1 | tr -d ' ')
    expected_in_doc=$(tr -d ',' <"$doc" 2>/dev/null | grep -oE "$pat" | head -1 | grep -oE '[0-9]+' | head -1)
    if [ -n "$expected_in_doc" ] && [ "$expected_in_doc" = "$actual" ]; then
      status="match"; pass=$((pass+1))
    else
      status="drift"; drift=$((drift+1))
    fi
    [ $i -gt 0 ] && results="${results},"
    results="${results}{\"idx\":${i},\"label\":\"${label}\",\"doc\":\"${doc}\",\"actual\":\"${actual}\",\"doc_claim\":\"${expected_in_doc}\",\"status\":\"${status}\"}"
    i=$((i+1))
  done
  results="${results}]"
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_loop_rules/1",
  "ts": "$(ts)",
  "rules_total": $n,
  "pass": $pass,
  "drift": $drift,
  "rules": $results
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

