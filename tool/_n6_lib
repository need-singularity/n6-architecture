# ────────────────────────────────────────────────────────────
# Phase 3.8 — external citation drift
# ────────────────────────────────────────────────────────────
scan_citations() {
  local out="reports/n6_external_citation_drift.json"
  local drifts="["
  local first=1
  # Products: live domain count is the stand-in (no standalone products.json in this repo)
  local actual_products=$(find domains -maxdepth 2 -mindepth 2 -type d 2>/dev/null | wc -l | tr -d ' ')
  local actual_domains="$actual_products"
  local actual_techniques=$(find techniques -name '*.hexa' -type f ! -name 'test_techniques*' 2>/dev/null | wc -l | tr -d ' ')
  local actual_papers=$(find papers -maxdepth 1 -name '*.md' -type f 2>/dev/null | wc -l | tr -d ' ')
  for f in README.md CONTRIBUTING.md $(find proposals -maxdepth 1 -name '*.md' -type f 2>/dev/null); do
    [ -f "$f" ] || continue
    for kw in products domains techniques papers; do
      case "$kw" in
        products)   actual_v="$actual_products" ;;
        domains)    actual_v="$actual_domains" ;;
        techniques) actual_v="$actual_techniques" ;;
        papers)     actual_v="$actual_papers" ;;
      esac
      # Require at least one space between the number and the keyword so we
      # only capture deliberate claim statements ("209 products"), not glommed
      # breakthrough shorthand in tables ("20domains", "6domains", "10domains").
      claimed=$(grep -oE "[0-9]+[[:space:]]+${kw}" "$f" 2>/dev/null | head -1 | grep -oE "[0-9]+" | head -1)
      [ -z "$claimed" ] && continue
      if [ "$claimed" != "$actual_v" ]; then
        [ $first -eq 0 ] && drifts="${drifts},"
        drifts="${drifts}{\"file\":\"$f\",\"kw\":\"${kw}\",\"claimed\":${claimed},\"actual\":${actual_v}}"
        first=0
      fi
    done
  done
  drifts="${drifts}]"
  cat >"$out" <<JEOF
{
  "schema": "n6-architecture/n6_external_citation_drift/1",
  "ts": "$(ts)",
  "actual": {"products": $actual_products, "domains": $actual_domains, "techniques": $actual_techniques, "papers": $actual_papers},
  "drift_entries": $drifts,
  "drift_count": $(echo "$drifts" | jq 'length')
}
JEOF
  jq '.' "$out" >"$out.tmp" && mv "$out.tmp" "$out"
  echo "OK: $out"
}

