let total_combos = e_count * p_count * a_count * c_count * f_count

println("================================================================")
println("  N6 Material Synthesis DSE")
println("  궁극의 물질합성 — 소재 x 공정 x 조립기 x 제어 x 시스템")
println("================================================================")
println("")
println("  N6 Core: sigma(" + to_string(SIGMA) + ")·phi(" + to_string(PHI) + ") = n(" + to_string(N) + ")·tau(" + to_string(TAU) + ")")
println("           " + to_string(SIGMA) + "·" + to_string(PHI) + " = " + to_string(N) + "·" + to_string(TAU) + " = " + to_string(SIGMA * PHI))
println("")

// Build candidate ID strings
fn join_ids(arr, cnt) {
    let mut r = ""
    let mut i = 0
    while i < cnt {
        if i > 0 { r = r + "," }
        r = r + arr[i]
        i = i + 1
    }
    r
}

println("  후보군:")
println("    소재(Element):   " + join_ids(e_id, e_count) + " candidates (" + to_string(e_count) + ")")
println("    공정(Process):   " + join_ids(p_id, p_count) + " candidates (" + to_string(p_count) + ")")
println("    조립기(Assembler): " + join_ids(a_id, a_count) + " candidates (" + to_string(a_count) + ")")
println("    제어(Control):   " + join_ids(c_id, c_count) + " candidates (" + to_string(c_count) + ")")
println("    시스템(Factory): " + join_ids(f_id, f_count) + " candidates (" + to_string(f_count) + ")")
println("")
println("  총 조합 수: " + to_string(e_count) + "x" + to_string(p_count) + "x" + to_string(a_count) + "x" + to_string(c_count) + "x" + to_string(f_count) + " = " + to_string(total_combos))
println("")

// ============================================================
// Enumerate all 3600 combinations - parallel arrays
// ============================================================
let mut r_ei = []
let mut r_pi = []
let mut r_ai = []
let mut r_ci = []
let mut r_fi = []
let mut r_n6pct = []
let mut r_perf = []
let mut r_pwr = []
let mut r_cost = []
let mut r_total = []
let mut r_count = 0

let mut ei = 0
while ei < e_count {
    let mut pi = 0
    while pi < p_count {
        let mut ai = 0
        while ai < a_count {
            let mut ci = 0
            while ci < c_count {
                let mut fi = 0
                while fi < f_count {
                    let n6_product = e_n6[ei] * p_n6[pi] * a_n6[ai] * c_n6[ci] * f_n6[fi]
                    let n6_exact_pct = n6_product * 100.0
                    let perf = (e_perf[ei] + p_perf[pi] + a_perf[ai] + c_perf[ci] + f_perf[fi]) / 5.0
                    let pwr = (e_pwr[ei] + p_pwr[pi] + a_pwr[ai] + c_pwr[ci] + f_pwr[fi]) / 5.0
                    let cost = (e_cost[ei] + p_cost[pi] + a_cost[ai] + c_cost[ci] + f_cost[fi]) / 5.0
                    let total_score = 0.35 * n6_exact_pct + 0.25 * perf + 0.20 * pwr + 0.20 * cost

                    r_ei = r_ei + [ei]
                    r_pi = r_pi + [pi]
                    r_ai = r_ai + [ai]
                    r_ci = r_ci + [ci]
                    r_fi = r_fi + [fi]
                    r_n6pct = r_n6pct + [n6_exact_pct]
                    r_perf = r_perf + [perf]
                    r_pwr = r_pwr + [pwr]
                    r_cost = r_cost + [cost]
                    r_total = r_total + [total_score]
                    r_count = r_count + 1

                    fi = fi + 1
                }
                ci = ci + 1
            }
            ai = ai + 1
        }
        pi = pi + 1
    }
    ei = ei + 1
}

// ============================================================
// Sort by total_score descending (selection sort via index array)
// ============================================================
let mut sort_idx = []
let mut si = 0
while si < r_count {
    sort_idx = sort_idx + [si]
    si = si + 1
}

si = 0
while si < r_count {
    let mut best = si
    let mut sj = si + 1
    while sj < r_count {
        if r_total[sort_idx[sj]] > r_total[sort_idx[best]] {
            best = sj
        }
        sj = sj + 1
    }
    if best != si {
        let tmp = sort_idx[si]
        sort_idx[si] = sort_idx[best]
        sort_idx[best] = tmp
    }
    si = si + 1
}

// ============================================================
// Find Pareto frontier
// ============================================================
let mut pareto = []
let mut pareto_count = 0

let mut ii = 0
while ii < r_count {
    let mut dominated = false
    let mut jj = 0
    while jj < r_count {
        if ii != jj {
            let an6 = r_n6pct[jj]
            let ap = r_perf[jj]
            let aw = r_pwr[jj]
            let ac = r_cost[jj]
            let bn6 = r_n6pct[ii]
            let bp = r_perf[ii]
            let bw = r_pwr[ii]
            let bc = r_cost[ii]

            let mut all_geq = true
            let mut any_gt = false

            if an6 < bn6 { all_geq = false }
            if ap < bp { if all_geq { all_geq = false } }
            if aw < bw { if all_geq { all_geq = false } }
            if ac < bc { if all_geq { all_geq = false } }

            if all_geq {
                if an6 > bn6 { any_gt = true }
                if ap > bp { any_gt = true }
                if aw > bw { any_gt = true }
                if ac > bc { any_gt = true }
            }

            if all_geq {
                if any_gt { dominated = true }
            }
        }
        if dominated { jj = r_count }
        if dominated == false { jj = jj + 1 }
    }
    if dominated == false {
        pareto = pareto + [ii]
        pareto_count = pareto_count + 1
    }
    ii = ii + 1
}

// ============================================================
// TOP 20 TABLE
// ============================================================
println("================================================================================================================================")
println("  TOP 20 CONFIGURATIONS (by total score)")
println("================================================================================================================================")
println("")
println(row12(pad_l("Rank", 4), pad_l("소재", 14), pad_l("공정", 14), pad_l("조립기", 14), pad_l("제어", 14), pad_l("시스템", 14), pad_l("n6_EX%", 7), pad_l("성능", 5), pad_l("전력", 5), pad_l("비용", 5), pad_l("종합", 6), pad_l("PF", 3)))
println("  -----+----------------+----------------+----------------+----------------+----------------+---------+-------+-------+-------+--------+----")

let mut rank = 0
while rank < 20 {
    let idx = sort_idx[rank]
    let r_e = r_ei[idx]
    let r_p = r_pi[idx]
    let r_a = r_ai[idx]
    let r_c = r_ci[idx]
    let r_f = r_fi[idx]

    // Check if this index is in pareto
    let mut is_pareto = ""
    let mut pk = 0
    while pk < pareto_count {
        if pareto[pk] == idx { is_pareto = "*" }
        pk = pk + 1
    }

    println(row12(pad_l(to_string(rank + 1), 4), pad_l(e_name[r_e], 14), pad_l(p_name[r_p], 14), pad_l(a_name[r_a], 14), pad_l(c_name[r_c], 14), pad_l(f_name[r_f], 14), pad_l(fmt1(r_n6pct[idx]), 6) + "%", pad_l(fmt1(r_perf[idx]), 5), pad_l(fmt1(r_pwr[idx]), 5), pad_l(fmt1(r_cost[idx]), 5), pad_l(fmt2(r_total[idx]), 6), pad_l(is_pareto, 3)))

    rank = rank + 1
}

// ============================================================
// PARETO FRONTIER
// ============================================================
println("")
println("================================================================")
println("  PARETO FRONTIER (" + to_string(pareto_count) + " non-dominated solutions)")
println("================================================================")
println("")
println(row11(pad_l("#", 4), pad_l("소재", 14), pad_l("공정", 14), pad_l("조립기", 14), pad_l("제어", 14), pad_l("시스템", 14), pad_l("n6_EX%", 7), pad_l("성능", 5), pad_l("전력", 5), pad_l("비용", 5), pad_l("종합", 6)))
println("  -----+----------------+----------------+----------------+----------------+----------------+---------+-------+-------+-------+--------")

// Sort pareto indices by total_score descending
let mut p_sort = []
let mut psi = 0
while psi < pareto_count {
    p_sort = p_sort + [pareto[psi]]
    psi = psi + 1
}

psi = 0
while psi < pareto_count {
    let mut best = psi
    let mut psj = psi + 1
    while psj < pareto_count {
        if r_total[p_sort[psj]] > r_total[p_sort[best]] {
            best = psj
        }
        psj = psj + 1
    }
    if best != psi {
        let tmp = p_sort[psi]
        p_sort[psi] = p_sort[best]
        p_sort[best] = tmp
    }
    psi = psi + 1
}

let mut pri = 0
while pri < pareto_count {
    let idx = p_sort[pri]
    let r_e = r_ei[idx]
    let r_p = r_pi[idx]
    let r_a = r_ai[idx]
    let r_c = r_ci[idx]
    let r_f = r_fi[idx]

    println(row11(pad_l(to_string(pri + 1), 4), pad_l(e_name[r_e], 14), pad_l(p_name[r_p], 14), pad_l(a_name[r_a], 14), pad_l(c_name[r_c], 14), pad_l(f_name[r_f], 14), pad_l(fmt1(r_n6pct[idx]), 6) + "%", pad_l(fmt1(r_perf[idx]), 5), pad_l(fmt1(r_pwr[idx]), 5), pad_l(fmt1(r_cost[idx]), 5), pad_l(fmt2(r_total[idx]), 6)))

    pri = pri + 1
}

// ============================================================
// STATISTICS
// ============================================================
println("")
println("================================================================")
println("  STATISTICS")
