println("  DSE 완료 — " + to_string(total_combos) + " 조합 전수 탐색, Pareto " + to_string(pareto_count) + " 최적 경로 도출")
println("  sigma(" + to_string(SIGMA) + ")·phi(" + to_string(PHI) + ") = n(" + to_string(N) + ")·tau(" + to_string(TAU) + ") = " + to_string(SIGMA * PHI) + " -- n=6 is unique")
