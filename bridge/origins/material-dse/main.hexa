// N6 Material Synthesis DSE (HEXA port)
// Original: tools/material-dse/main.rs
// 소재 x 공정 x 조립기 x 제어 x 시스템 전수 조합 탐색기

// N6 constants
let N = 6.0
let PHI = 2.0
let TAU = 4.0
let SIGMA = 12.0
let SOPFR = 5.0
let MU = 1.0
let J2 = 24.0

// Helper functions
fn pad_r(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = r + " " }
    r
}
fn pad_l(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = " " + r }
    r
}
fn fmt1(x) {
    let v = round(x * 10.0) / 10.0
    let mut s = to_string(v)
    if s.contains(".") == false { s = s + ".0" }
    s
}
fn fmt2(x) {
    let v = round(x * 100.0) / 100.0
    let mut s = to_string(v)
    if s.contains(".") == false { s = s + ".00" }
    s
}
fn repeat_char(c, n) {
    let mut r = ""
    let mut i = 0
    while i < n {
        r = r + c
        i = i + 1
    }
    r
}

// Build a table row with | separators
fn row12(a, b, c, d, e, f, g, h, i, j, k, l) {
    "  " + a + " | " + b + " | " + c + " | " + d + " | " + e + " | " + f + " | " + g + " | " + h + " | " + i + " | " + j + " | " + k + " | " + l
}
fn row11(a, b, c, d, e, f, g, h, i, j, k) {
    "  " + a + " | " + b + " | " + c + " | " + d + " | " + e + " | " + f + " | " + g + " | " + h + " | " + i + " | " + j + " | " + k
}
fn best_line(label, eid, pid, aid, cid, fid, val) {
    "    " + label + eid + "+" + pid + "+" + aid + "+" + cid + "+" + fid + " = " + val
}

// ============================================================
// Level 1: Element (5 candidates)
// ============================================================
let e_id   = ["E1", "E2", "E3", "E4", "E5"]
let e_name = ["Carbon_Z6", "Silicon_Z14", "TransitionMetal", "NobleMetal", "Ceramic"]
let e_n6   = [1.0, 0.7, 0.8, 0.6, 0.5]
let e_perf = [95.0, 85.0, 80.0, 90.0, 75.0]
let e_pwr  = [70.0, 75.0, 65.0, 60.0, 80.0]
let e_cost = [60.0, 90.0, 50.0, 20.0, 70.0]
let e_count = 5

