println("    Max n6_EXACT:    " + fmt1(max_n6) + "%")
println("    Min n6_EXACT:    " + fmt1(min_n6) + "%")
println("    Avg n6_EXACT:    " + fmt1(avg_n6) + "%")
println("    n6 > 50%:        " + to_string(above50) + " (" + fmt1(above50 * 100.0 / total_combos) + "% of total)")
println("    n6 > 30%:        " + to_string(above30) + " (" + fmt1(above30 * 100.0 / total_combos) + "% of total)")
println("    n6 > 10%:        " + to_string(above10) + " (" + fmt1(above10 * 100.0 / total_combos) + "% of total)")

// Best per objective
