let a_perf = [95.0, 98.0, 80.0, 85.0, 90.0, 92.0]
let a_pwr  = [40.0, 70.0, 90.0, 65.0, 50.0, 75.0]
let a_cost = [30.0, 25.0, 60.0, 50.0, 45.0, 35.0]
let a_count = 6

