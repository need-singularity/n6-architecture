// Top-50 distribution by level
fn count_top50(sort_arr, r_idx_arr, target_val, r_cnt) {
    let mut cnt = 0
    let mut i = 0
    let lim = if r_cnt < 50 { r_cnt } else { 50 }
    while i < lim {
        let idx = sort_arr[i]
        if r_idx_arr[idx] == target_val { cnt = cnt + 1 }
        i = i + 1
    }
    cnt
}

println("  Top-50 element distribution:")
let mut di = 0
while di < e_count {
    let cnt = count_top50(sort_idx, r_ei, di, r_count)
    let bar = repeat_char("#", cnt)
    println("    " + e_id[di] + " " + pad_l(e_name[di], 14) + ": " + pad_l(to_string(cnt), 2) + " " + bar)
    di = di + 1
}

println("")
