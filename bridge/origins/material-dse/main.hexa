let mut max_n6 = 0.0
let mut min_n6 = 100.0
let mut sum_n6 = 0.0
let mut above50 = 0
let mut above30 = 0
let mut above10 = 0

let mut sti = 0
while sti < r_count {
    let v = r_n6pct[sti]
    if v > max_n6 { max_n6 = v }
    if v < min_n6 { min_n6 = v }
    sum_n6 = sum_n6 + v
    if v > 50.0 { above50 = above50 + 1 }
    if v > 30.0 { above30 = above30 + 1 }
    if v > 10.0 { above10 = above10 + 1 }
    sti = sti + 1
}
let avg_n6 = sum_n6 / r_count

println("")
println("  Total combinations explored:  " + to_string(total_combos))
println("  Pareto-optimal solutions:     " + to_string(pareto_count))
println("")
