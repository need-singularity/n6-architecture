    if r_perf[bi] > r_perf[best_perf_idx] { best_perf_idx = bi }
    if r_pwr[bi] > r_pwr[best_pwr_idx] { best_pwr_idx = bi }
    if r_cost[bi] > r_cost[best_cost_idx] { best_cost_idx = bi }
    bi = bi + 1
}

let best_total_idx = sort_idx[0]

println(best_line("Best n6_EXACT:  ", e_id[r_ei[best_n6_idx]], p_id[r_pi[best_n6_idx]], a_id[r_ai[best_n6_idx]], c_id[r_ci[best_n6_idx]], f_id[r_fi[best_n6_idx]], fmt1(r_n6pct[best_n6_idx]) + "%"))
println(best_line("Best Perf:      ", e_id[r_ei[best_perf_idx]], p_id[r_pi[best_perf_idx]], a_id[r_ai[best_perf_idx]], c_id[r_ci[best_perf_idx]], f_id[r_fi[best_perf_idx]], fmt1(r_perf[best_perf_idx])))
println(best_line("Best Power:     ", e_id[r_ei[best_pwr_idx]], p_id[r_pi[best_pwr_idx]], a_id[r_ai[best_pwr_idx]], c_id[r_ci[best_pwr_idx]], f_id[r_fi[best_pwr_idx]], fmt1(r_pwr[best_pwr_idx])))
println(best_line("Best Cost:      ", e_id[r_ei[best_cost_idx]], p_id[r_pi[best_cost_idx]], a_id[r_ai[best_cost_idx]], c_id[r_ci[best_cost_idx]], f_id[r_fi[best_cost_idx]], fmt1(r_cost[best_cost_idx])))
println(best_line("Best Total:     ", e_id[r_ei[best_total_idx]], p_id[r_pi[best_total_idx]], a_id[r_ai[best_total_idx]], c_id[r_ci[best_total_idx]], f_id[r_fi[best_total_idx]], fmt2(r_total[best_total_idx])))

