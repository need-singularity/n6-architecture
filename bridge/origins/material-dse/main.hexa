let p_name = ["ALD", "MBE", "CVD", "Mechanosynthesis", "Electrochemistry", "SelfAssembly"]
let p_n6   = [0.9, 0.7, 0.6, 0.8, 0.7, 1.0]
let p_perf = [90.0, 95.0, 80.0, 98.0, 75.0, 85.0]
let p_pwr  = [70.0, 50.0, 75.0, 60.0, 80.0, 90.0]
let p_cost = [75.0, 40.0, 85.0, 30.0, 80.0, 70.0]
let p_count = 6

// ============================================================
// Level 3: Assembler (6 candidates)
// ============================================================
let a_id   = ["A1", "A2", "A3", "A4", "A5", "A6"]
let a_name = ["STM_tip", "MolecularAsm", "DNA_origami", "OpticalTweezer", "FocusedIonBeam", "NanobotSwarm"]
