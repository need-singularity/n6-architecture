println("    공정:   " + proc_name[blp_i] + " (" + to_string(proc_n6m[blp_i]) + "/" + to_string(proc_n6t[blp_i]) + ")")
println("    코어:   " + core_name[blc_i] + " (" + to_string(core_n6m[blc_i]) + "/" + to_string(core_n6t[blc_i]) + ")")
println("    칩:     " + chip_name[blb_i] + " (" + to_string(chip_n6m[blb_i]) + "/" + to_string(chip_n6t[blb_i]) + ")")
