// Print candidates
fn join_arr(arr, cnt) {
    let mut r = ""
    let mut i = 0
    while i < cnt {
        if i > 0 { r = r + ", " }
        r = r + arr[i]
        i = i + 1
    }
    r
}

println("  후보군:")
println("    소재:   " + join_arr(mat_name, mat_count) + " (" + to_string(mat_count) + ")")
println("    공정:   " + join_arr(proc_name, proc_count) + " (" + to_string(proc_count) + ")")
println("    코어:   " + join_arr(core_name, core_count) + " (" + to_string(core_count) + ")")
println("    칩:     " + join_arr(chip_name, chip_count) + " (" + to_string(chip_count) + ")")
println("    시스템: " + join_arr(sys_name, sys_count) + " (" + to_string(sys_count) + ")")
println("")

let total_combos = mat_count * proc_count * core_count * chip_count * sys_count
println("  총 조합: " + format_comma(total_combos))

// ============================================================
// Enumerate all compatible combinations
// ============================================================
let mut r_mi = []
let mut r_pi = []
let mut r_ci = []
let mut r_bi = []
let mut r_si = []
let mut r_n6pct = []
let mut r_perf = []
let mut r_tcost = []
let mut r_cscore = []
let mut r_safety = []
let mut r_life = []
let mut r_maturity = []
let mut r_pareto = []
let mut rcount = 0

let mut mi = 0
while mi < mat_count {
    let mut pi = 0
    while pi < proc_count {
        // Compatibility: Na-ion only with Na-HardCarbon
        let mut mat_proc_ok = true
        if mat_name[mi] == "Na-ion" {
            if proc_name[pi] != "Na-HardCarbon" { mat_proc_ok = false }
        }
        if proc_name[pi] == "Na-HardCarbon" {
            if mat_name[mi] != "Na-ion" { mat_proc_ok = false }
        }
        // Li-S only with Si-SSB
        if mat_name[mi] == "Li-S" {
            if proc_name[pi] != "Si-SSB" { mat_proc_ok = false }
        }
        // Si-SSB not with Na-ion
        if proc_name[pi] == "Si-SSB" {
            if mat_name[mi] == "Na-ion" { mat_proc_ok = false }
        }

        if mat_proc_ok {
            let mut cci = 0
            while cci < core_count {
                let mut bi = 0
                while bi < chip_count {
                    let mut si = 0
                    while si < sys_count {
                        // More compatibility checks
                        let mut ok = true
                        // Minimal BMS not for high voltage
                        if chip_name[bi] == "Minimal-4ch" {
                            if sys_name[si] == "400V-EV" { ok = false }
                            if sys_name[si] == "800V-EV" { ok = false }
                            if sys_name[si] == "Grid-MW" { ok = false }
                        }
                        // 18650 impractical for 800V
                        if core_name[cci] == "18650" {
                            if sys_name[si] == "800V-EV" { ok = false }
                        }

                        if ok {
                            // Score
                            let n6_exact = mat_n6m[mi] + proc_n6m[pi] + core_n6m[cci] + chip_n6m[bi] + sys_n6m[si]
                            let n6_total = mat_n6t[mi] + proc_n6t[pi] + core_n6t[cci] + chip_n6t[bi] + sys_n6t[si]
                            let n6_pct = n6_exact * 1.0 / (n6_total * 1.0) * 100.0

                            let perf = (mat_ed[mi] * proc_cap[pi] * core_emult[cci]) / (500.0 * 3.0 * 1.30)

                            let total_cost = mat_cost[mi] + proc_cost[pi] + core_mcost[cci] + chip_cost[bi] + sys_cost[si]
                            let cost_score = 1.0 / total_cost

                            let safety = mat_safe[mi] * core_therm[cci]

                            let life = mat_cyc[mi] * 1.0 / 4000.0

                            let maturity = proc_mat[pi]

                            let pareto = n6_pct / 100.0 * 0.20 + perf * 0.25 + cost_score * 2.0 * 0.15 + safety * 0.15 + life * 0.15 + maturity * 0.10

                            r_mi = r_mi + [mi]
                            r_pi = r_pi + [pi]
                            r_ci = r_ci + [cci]
                            r_bi = r_bi + [bi]
                            r_si = r_si + [si]
                            r_n6pct = r_n6pct + [n6_pct]
                            r_perf = r_perf + [perf]
                            r_tcost = r_tcost + [total_cost]
                            r_cscore = r_cscore + [cost_score]
                            r_safety = r_safety + [safety]
                            r_life = r_life + [life]
                            r_maturity = r_maturity + [maturity]
                            r_pareto = r_pareto + [pareto]
                            rcount = rcount + 1
                        }

                        si = si + 1
                    }
                    bi = bi + 1
                }
                cci = cci + 1
            }
        }
        pi = pi + 1
    }
    mi = mi + 1
}

println("  호환 조합: " + to_string(rcount) + " (필터 후)")
println("")

// ============================================================
// Find TOP 20 by pareto (iterative max extraction, no full sort)
// ============================================================
let mut top20 = []
let mut top20_count = 0

let mut top_limit = 20
if rcount < 20 { top_limit = rcount }

let mut ti = 0
while ti < top_limit {
    let mut best_idx = -1
    let mut best_val = -999.0
    let mut si2 = 0
    while si2 < rcount {
        if r_pareto[si2] > best_val {
            let mut already = false
            let mut ck = 0
            while ck < top20_count {
                if top20[ck] == si2 { already = true }
                ck = ck + 1
            }
            if already == false {
                best_val = r_pareto[si2]
                best_idx = si2
            }
        }
        si2 = si2 + 1
    }
    top20 = top20 + [best_idx]
    top20_count = top20_count + 1
    ti = ti + 1
}

