let mat_name     = ["LFP",   "NMC811", "NCA",   "LCO",   "Na-ion", "Li-S"]
let mat_cn       = [6,       6,        6,       6,       6,        8]
let mat_n6m      = [4,       3,        3,       4,       3,        5]
let mat_n6t      = [4,       4,        4,       4,       4,        6]
let mat_ed       = [170.0,   280.0,    260.0,   200.0,   140.0,    500.0]
let mat_cyc      = [4000,    1000,     1500,    500,     3000,     300]
let mat_cost     = [0.65,    1.00,     0.95,    1.20,    0.45,     0.55]
let mat_safe     = [0.95,    0.70,     0.72,    0.65,    0.92,     0.50]
let mat_count = 6

