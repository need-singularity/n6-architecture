println("  >=80% EXACT:   " + to_string(above80) + " (" + to_string(rd1(above80 * 1.0 / (rcount * 1.0) * 100.0)) + "%)")
println("  >=60% EXACT:   " + to_string(above60) + " (" + to_string(rd1(above60 * 1.0 / (rcount * 1.0) * 100.0)) + "%)")
