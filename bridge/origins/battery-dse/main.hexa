let mut sum_n6 = 0.0
let mut max_n6 = 0.0
let mut above80 = 0
let mut above60 = 0
let mut sti = 0
while sti < rcount {
    sum_n6 = sum_n6 + r_n6pct[sti]
    if r_n6pct[sti] > max_n6 { max_n6 = r_n6pct[sti] }
    if r_n6pct[sti] >= 80.0 { above80 = above80 + 1 }
    if r_n6pct[sti] >= 60.0 { above60 = above60 + 1 }
    sti = sti + 1
}
let avg_n6 = sum_n6 / (rcount * 1.0)

println("  Compatible combinations: " + to_string(rcount))
