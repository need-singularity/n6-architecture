        best_perf_val = r_perf[bp]
        best_perf_idx = bp
    }
    bp = bp + 1
}

// Best cost (lowest)
let mut best_cost_idx = 0
let mut best_cost_val = r_tcost[0]
let mut bc = 1
while bc < rcount {
    if r_tcost[bc] < best_cost_val {
        best_cost_val = r_tcost[bc]
        best_cost_idx = bc
    }
    bc = bc + 1
}

// Best safety
let mut best_safe_idx = 0
