    let v = proc_n6m[bpi] * 100 / proc_n6t[bpi]
    if v > blp_v {
        blp_v = v
        blp_i = bpi
    }
    bpi = bpi + 1
}
let mut blc_i = 0
let mut blc_v = 0
let mut bci = 0
while bci < core_count {
    let v = core_n6m[bci] * 100 / core_n6t[bci]
    if v > blc_v {
        blc_v = v
        blc_i = bci
    }
    bci = bci + 1
}
let mut blb_i = 0
