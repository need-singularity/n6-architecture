// n6 vs Performance trade-off
// perf rank of best n6 combo = 1 + count of combos with higher perf
let mut best_n6_perf_rank = 1
let mut pri = 0
while pri < rcount {
    if r_perf[pri] > r_perf[best_n6_idx] {
        best_n6_perf_rank = best_n6_perf_rank + 1
    }
    pri = pri + 1
}

// best perf combo's n6 and pareto rank
let best_perf_n6 = r_n6pct[best_perf_idx]
let mut best_perf_pareto_rank = 1
let mut pra = 0
while pra < rcount {
    if r_pareto[pra] > r_pareto[best_perf_idx] {
        best_perf_pareto_rank = best_perf_pareto_rank + 1
    }
    pra = pra + 1
}

println("  n6 vs Performance trade-off:")
