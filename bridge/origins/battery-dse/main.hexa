// HEXA-BATTERY Design Space Exploration (DSE)
// Original: tools/battery-dse/main.rs
// 소재 x 공정 x 코어 x 칩 x 시스템 전수 조합 최적 배터리 설계 도출

// --- helpers ---
fn pad_r(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = r + " " }
    r
}
fn pad_l(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = " " + r }
    r
}
fn rd1(x) { round(x * 10.0) / 10.0 }
fn rd2(x) { round(x * 100.0) / 100.0 }
fn rd3(x) { round(x * 1000.0) / 1000.0 }
fn rd4(x) { round(x * 10000.0) / 10000.0 }

fn format_comma(n) {
    let s = to_string(n)
    let slen = len(s)
    let mut result = ""
    let mut ci = 0
    while ci < slen {
        let pos = slen - 1 - ci
        if ci > 0 {
            if ci % 3 == 0 { result = "," + result }
        }
        // extract char at pos
        let ch = s[pos]
        result = ch + result
        ci = ci + 1
    }
    result
}

// --- N6 constants ---
let N = 6
let PHI = 2
let TAU = 4
let SIGMA = 12
let SOPFR = 5
let J2 = 24

// ============================================================
