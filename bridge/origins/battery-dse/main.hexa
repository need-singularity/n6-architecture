let mut bs = 1
while bs < rcount {
    if r_safety[bs] > best_safe_val {
        best_safe_val = r_safety[bs]
        best_safe_idx = bs
    }
    bs = bs + 1
}

// Best life
let mut best_life_idx = 0
let mut best_life_val = r_life[0]
let mut bl = 1
while bl < rcount {
    if r_life[bl] > best_life_val {
        best_life_val = r_life[bl]
        best_life_idx = bl
    }
    bl = bl + 1
}

// Best maturity
let mut best_matu_idx = 0
let mut best_matu_val = r_maturity[0]
let mut bm = 1
while bm < rcount {
    if r_maturity[bm] > best_matu_val {
        best_matu_val = r_maturity[bm]
        best_matu_idx = bm
    }
    bm = bm + 1
}

println("    Best n6 EXACT:    " + fmt_path(best_n6_idx) + " (" + to_string(rd1(best_n6_val)) + "%)")
let eff_whkg = round(best_perf_val * 500.0 * 3.0 * 1.30)
println("    Best Performance: " + fmt_path(best_perf_idx) + " (" + to_string(round(eff_whkg)) + " Wh/kg effective)")
println("    Best Cost:        " + fmt_path(best_cost_idx) + " ($" + to_string(rd2(best_cost_val)) + " relative)")
println("    Best Safety:      " + fmt_path(best_safe_idx) + " (" + to_string(rd2(best_safe_val)) + ")")
let best_life_cyc = round(best_life_val * 4000.0)
println("    Best Longevity:   " + fmt_path(best_life_idx) + " (" + to_string(round(best_life_cyc)) + " cycles)")
println("    Best Maturity:    " + fmt_path(best_matu_idx) + " (" + to_string(rd2(best_matu_val)) + " TRL)")

