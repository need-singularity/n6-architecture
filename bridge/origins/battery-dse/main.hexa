let sep_line = "  " + "-".repeat(5) + "+" + "-".repeat(10) + "+" + "-".repeat(16) + "+" + "-".repeat(11) + "+" + "-".repeat(17) + "+" + "-".repeat(11) + "+" + "-".repeat(7) + "+" + "-".repeat(7) + "+" + "-".repeat(7) + "+" + "-".repeat(7) + "+" + "-".repeat(7) + "+" + "-".repeat(7)
println(sep_line)

let mut tii = 0
while tii < top20_count {
    let idx = top20[tii]
    let rank = tii + 1
    let n6_str = to_string(rd1(r_n6pct[idx])) + "%"
    println("  " + pad_l(to_string(rank), 4) + " | " + pad_l(mat_name[r_mi[idx]], 8) + " | " + pad_l(proc_name[r_pi[idx]], 14) + " | " + pad_l(core_name[r_ci[idx]], 9) + " | " + pad_l(chip_name[r_bi[idx]], 15) + " | " + pad_l(sys_name[r_si[idx]], 9) + " | " + pad_l(n6_str, 5) + " | " + pad_l(to_string(rd3(r_perf[idx])), 5) + " | " + pad_l(to_string(rd2(r_tcost[idx])), 5) + " | " + pad_l(to_string(rd2(r_safety[idx])), 5) + " | " + pad_l(to_string(rd2(r_life[idx])), 5) + " | " + pad_l(to_string(rd4(r_pareto[idx])), 6))
    tii = tii + 1
}

