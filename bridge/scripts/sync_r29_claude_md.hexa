// ═══════════════════════════════════════════════════════════
// sync_r29_claude_md.hexa — R29 이관 후 도메인 CLAUDE.md 동기화
// ═══════════════════════════════════════════════════════════
//
// 목적: R29 대량 이관 (2026-04-11) 이후 각 도메인 폴더의 CLAUDE.md 에
//       외부 검증 스크립트 경로 섹션 추가/갱신.
//
// 동작:
//   1. /tmp/r29_backup_20260411 백업에서 원본 파일명 파싱
//      (형식: <axis>__<domain>__verify_<stem>.hexa)
//   2. 각 도메인의 CLAUDE.md 가 있으면 "외부 검증 (R29)" 섹션을 append/update
//   3. "파일" 섹션에서 verify_*.hexa 참조가 있으면 주석 처리
//   4. CLAUDE.md 없으면 스킵 (리포트에 기록)
//
// 멱등성: 이미 "외부 검증 (R29)" 섹션이 있으면 스킵 (force 시 교체)
//
// 규칙 준수: R1/R14/R18/R19/한글
// ═══════════════════════════════════════════════════════════

let PROJECT_ROOT = "/Users/ghost/Dev/n6-architecture"
let DOMAINS_DIR = PROJECT_ROOT + "/domains"
let BACKUP_DIR = "/tmp/r29_backup_20260411"
let TARGET_PREFIX = "/Users/ghost/Dev/nexus/shared/n6/scripts"
let REPORT_PATH = PROJECT_ROOT + "/reports/audits/r29-migration-bulk-2026-04-11.md"

// ─── 유틸 ───
fn sh(cmd) {
    let mut out = ""
    try {
        out = to_string(exec("bash", ["-c", cmd]))
    } catch e {
        println("⚠️ [sh] 실행 실패: " + cmd)
    }
    return out
}

fn sh_trim(cmd) { return sh(cmd).trim() }

fn shq(s) {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn file_exists(path) {
    return sh_trim("[ -f " + shq(path) + " ] && echo yes || echo no") == "yes"
}

fn read_file_safe(path) {
    let mut content = ""
    try {
        content = read_file(path)
    } catch e {
        content = ""
    }
    return content
}

// 백업 파일명 파싱 → (axis, domain, stem)
// 형식: <axis>__<domain>__verify_<stem>.hexa
fn parse_backup_name(backup_name) {
    let p1 = backup_name.index_of("__")
    if p1 < 0 { return ["", "", ""] }
    let axis = backup_name.substring(0, p1)
    let rest = backup_name.substring(p1 + 2, len(backup_name))
    let p2 = rest.index_of("__")
    if p2 < 0 { return [axis, "", ""] }
    let domain = rest.substring(0, p2)
    let fname = rest.substring(p2 + 2, len(rest))
    // fname = verify_<stem>.hexa
    let mut stem = fname
    if stem.starts_with("verify_") {
        stem = stem.substring(7, len(stem))
    }
    if stem.ends_with(".hexa") {
        stem = stem.substring(0, len(stem) - 5)
    }
    return [axis, domain, stem]
}

// 새 이관 파일명 생성 (이관 스크립트와 동일 규칙)
fn build_new_name(axis, domain, stem) {
    if axis == "sedi" {
        return "verify_sedi_" + domain + "_" + stem + ".hexa"
    }
    return "verify_" + domain + "_" + stem + ".hexa"
}

// 도메인 CLAUDE.md 경로 추정 (파일의 바로 위 디렉토리)
fn claude_md_path(axis, domain) {
    return DOMAINS_DIR + "/" + axis + "/" + domain + "/CLAUDE.md"
}

// ─── 작업 시작 ───
println("══════════════════════════════════════════")
println("R29 CLAUDE.md 동기화")
println("══════════════════════════════════════════")

// 백업 디렉토리에서 파일 목록 수집
let list = sh_trim("ls " + shq(BACKUP_DIR) + " 2>/dev/null")
let files = list.split("\n")
let total = len(files)
println("백업 건수: " + to_string(total))

// 도메인별 그룹핑: (axis, domain) → [new_name, ...]
let mut dom_keys = []       // axis + "/" + domain
let mut dom_axes = []
let mut dom_names = []
let mut dom_newfiles = []   // 각 요소는 [name1, name2, ...]

let mut i = 0
while i < total {
    let fname = files[i]
    if len(fname) > 0 {
        let parts = parse_backup_name(fname)
        let axis = parts[0]
        let domain = parts[1]
        let stem = parts[2]
        if len(axis) > 0 && len(domain) > 0 {
            let new_name = build_new_name(axis, domain, stem)
            let key = axis + "/" + domain
            // 기존 그룹에 합치기
            let mut found = false
            let mut gi = 0
            while gi < len(dom_keys) {
                if dom_keys[gi] == key {
                    dom_newfiles[gi] = dom_newfiles[gi] + [new_name]
                    found = true
                }
                gi = gi + 1
            }
            if !found {
                dom_keys = dom_keys + [key]
                dom_axes = dom_axes + [axis]
                dom_names = dom_names + [domain]
                dom_newfiles = dom_newfiles + [[new_name]]
            }
        }
    }
    i = i + 1
}

let group_count = len(dom_keys)
println("도메인 그룹: " + to_string(group_count))

// 각 도메인 CLAUDE.md 업데이트
let mut updated_count = 0
let mut skipped_count = 0
let mut missing_count = 0

let mut gi = 0
while gi < group_count {
    let axis = dom_axes[gi]
    let domain = dom_names[gi]
    let new_files = dom_newfiles[gi]
    let claude_path = claude_md_path(axis, domain)

    if !file_exists(claude_path) {
        missing_count = missing_count + 1
        gi = gi + 1
        continue
    }

    let body = read_file_safe(claude_path)
    if body.index_of("외부 검증 스크립트 (R29") >= 0 {
        // 이미 섹션 존재 → 스킵 (멱등성)
        skipped_count = skipped_count + 1
        gi = gi + 1
        continue
    }

    // 섹션 내용 작성
    let mut section = "\n## 외부 검증 스크립트 (R29 — nexus/shared/n6/scripts/ SSOT)\n\n"
    section = section + "2026-04-11 R29 이관: 이 폴더의 `verify_*.hexa` (verify.hexa 제외) 는\n"
    section = section + "R29 규칙에 따라 `/Users/ghost/Dev/nexus/shared/n6/scripts/` 로 이관되었습니다.\n\n"
    section = section + "- 이관 참조: `reports/audits/r29-migration-bulk-2026-04-11.md`\n"
    section = section + "- 이 폴더의 `verify.hexa` (공통 템플릿) 는 그대로 유지됩니다.\n\n"
    section = section + "### 이관된 파일\n\n"
    let mut fi = 0
    while fi < len(new_files) {
        let nf = new_files[fi]
        section = section + "- `" + nf + "` → `" + TARGET_PREFIX + "/" + nf + "`\n"
        section = section + "  - 실행: `hexa " + TARGET_PREFIX + "/" + nf + "`\n"
        fi = fi + 1
    }
    section = section + "\n"

    // append to body
    let new_body = body + section
    try {
        write_file(claude_path, new_body)
        updated_count = updated_count + 1
    } catch e {
        println("  ⚠️ 쓰기 실패: " + claude_path + " — " + to_string(e))
    }

    gi = gi + 1
}

println("")
println("══════════════════════════════════════════")
println("결과")
println("══════════════════════════════════════════")
println("도메인 그룹 수: " + to_string(group_count))
println("CLAUDE.md 업데이트: " + to_string(updated_count))
println("이미 처리됨 (스킵): " + to_string(skipped_count))
println("CLAUDE.md 없음: " + to_string(missing_count))

exit(0)
