// nexus_growth_daemon.hexa — NEXUS-6 성장 데몬 (minimal 실구현)
// 원본: nexus/scripts/nexus_growth_daemon.sh (792줄, git 2d3b0bd9 보존)
// 포팅 전략: 미니멀 핵심만 — measure/pick-weakest/action 은 간소화
//            (python3/cargo/Claude CLI 의존 제거, 로컬 daemon 행동 집중)
// 사이클: measure → weakest dimension pick → dimension action stub → log
// 안전: singleton PID lock / graceful shutdown (shutdown file 체크) / --max-cycles
// CLI: --interval MIN / --max-cycles N / --dimension DIM / --dry-run / --help
// 사용: hexa shared/bin/hexa run bridge/scripts/nexus_growth_daemon.hexa [flags]

// ─── 유틸 ──────────────────────────────────────────────────────────
// hexa 인터프리터 quirk: exec("bash", ["-c", cmd]) 에서 "$$" 등 쉘 확장 무시됨.
// 따라서 단일 인자 exec(cmd) 를 사용 (hexa 런타임이 /bin/sh -c 로 위임).
fn sh(cmd) {
    let mut out = ""
    try {
        out = to_string(exec(cmd))
    } catch e {
        out = ""
    }
    return out
}

fn sh_trim(cmd) {
    return sh(cmd).trim()
}

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn now_utc() -> string {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

fn now_hms() -> string {
    return to_string(exec("date +%H:%M:%S")).trim()
}

fn now_epoch() -> i64 {
    let s = to_string(exec("date +%s")).trim()
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn file_exists_simple(path) -> bool {
    let t = sh_trim("test -f '" + path + "' && echo y || echo n")
    return t == "y"
}

fn dir_exists_simple(path) -> bool {
    let t = sh_trim("test -d '" + path + "' && echo y || echo n")
    return t == "y"
}

fn pid_alive(pid: string) -> bool {
    if len(pid) == 0 { return false }
    let t = sh_trim("kill -0 " + pid + " 2>/dev/null && echo y || echo n")
    return t == "y"
}

fn getpid() -> string {
    // sh -c 'echo $PPID' — exec()가 spawn한 sh의 부모 = daemon 프로세스 PID
    // (이전 버그: exec("echo $$")는 subshell PID 반환 → 즉시 죽어 stale pid file 원인)
    // Mac sh/bash 호환. launchctl 환경에서도 정확한 daemon PID 보장.
    let p = to_string(exec("sh -c 'echo $PPID'")).trim()
    return p
}

fn mkdirp(path) {
    try { exec("mkdir -p '" + path + "'") } catch e {}
}

fn write_atomic(path, content) {
    try { exec("printf '%s' " + shq(content) + " > '" + path + "'") } catch e {}
}

fn append_line(path, line) {
    try { exec("printf '%s\\n' " + shq(line) + " >> '" + path + "'") } catch e {}
}

fn shq(s) {
    let mut out = "'"
    let n = len(s)
    let mut i: i64 = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" { out = out + "'\\''" }
        else { out = out + c }
        i = i + 1
    }
    out = out + "'"
    return out
}

// ─── 경로 상수 ─────────────────────────────────────────────────────
let HOME = env("HOME")
let NEXUS_STATE = HOME + "/.nexus"
let PID_FILE = NEXUS_STATE + "/daemon.pid"
let SHUTDOWN_FLAG = NEXUS_STATE + "/daemon.shutdown"
let DAEMON_LOG = NEXUS_STATE + "/daemon.log"
let GROWTH_LOG = NEXUS_STATE + "/growth_log.jsonl"
let mut NEXUS_ROOT = env("NEXUS")
if len(NEXUS_ROOT) == 0 { NEXUS_ROOT = HOME + "/Dev/nexus" }
let ATLAS_N6 = NEXUS_ROOT + "/shared/n6/atlas.n6"
let N6_ARCH = HOME + "/Dev/n6-architecture"
let SCRIPT_DIR = N6_ARCH + "/bridge/scripts"

// ─── 15 차원 ─────────────────────────────────────────────────────
let DIMENSIONS = [
    "performance", "architecture", "lenses", "modules", "tests",
    "hypotheses", "dse", "experiments", "calculators", "cross_resonance",
    "knowledge_graph", "red_team", "atlas", "documentation", "integration"
]

// ─── CLI 파싱 ─────────────────────────────────────────────────────
let argv = args()
let argc = len(argv)
let mut INTERVAL_MIN: i64 = 5
let mut MAX_CYCLES: i64 = 6
let mut FORCE_DIM = ""
let mut DRY_RUN = false
let mut SKIP_COMMIT = false
let mut SHOW_HELP = false
let mut ai: i64 = 2          // skip [0]=hexa, [1]=script
while ai < argc {
    let a = argv[ai]
    if a == "--interval" {
        if ai + 1 < argc {
            try { INTERVAL_MIN = to_int(argv[ai + 1]) } catch e {}
            ai = ai + 2
        } else { ai = ai + 1 }
    } else if a == "--max-cycles" {
        if ai + 1 < argc {
            try { MAX_CYCLES = to_int(argv[ai + 1]) } catch e {}
            ai = ai + 2
        } else { ai = ai + 1 }
    } else if a == "--dimension" {
        if ai + 1 < argc { FORCE_DIM = argv[ai + 1]; ai = ai + 2 } else { ai = ai + 1 }
    } else if a == "--dry-run" {
        DRY_RUN = true
        ai = ai + 1
    } else if a == "--skip-commit" {
        SKIP_COMMIT = true
        ai = ai + 1
    } else if a == "-h" || a == "--help" {
        SHOW_HELP = true
        ai = ai + 1
    } else {
        // 알 수 없는 옵션은 조용히 무시 (forward compat)
        ai = ai + 1
    }
}

if SHOW_HELP {
    println("NEXUS-6 Universal Growth Daemon (hexa)")
    println("")
    println("Usage: hexa run nexus_growth_daemon.hexa [OPTIONS]")
    println("")
    println("Options:")
    println("  --interval MIN     사이클 간 sleep (기본 5)")
    println("  --max-cycles N     최대 사이클 (기본 6, n=6)")
    println("  --dimension DIM    강제 차원 (15 중 1)")
    println("  --dry-run          측정만, 액션/커밋 없음")
    println("  --skip-commit      액션만, 커밋 없음")
    println("  -h, --help         이 메시지")
    println("")
    println("Dimensions (15):")
    println("  performance architecture lenses modules tests")
    println("  hypotheses dse experiments calculators cross_resonance")
    println("  knowledge_graph red_team atlas documentation integration")
    println("")
    println("Files:")
    println("  PID:      " + PID_FILE)
    println("  Log:      " + DAEMON_LOG)
    println("  Growth:   " + GROWTH_LOG)
    println("  Shutdown: " + SHUTDOWN_FLAG + " (touch to stop gracefully)")
    return 0
}

// ─── 로그 ──────────────────────────────────────────────────────────
fn log_info(msg) {
    let line = "[" + now_hms() + "] INFO:  " + msg
    println(line)
    append_line(DAEMON_LOG, line)
}

fn log_warn(msg) {
    let line = "[" + now_hms() + "] WARN:  " + msg
    println(line)
    append_line(DAEMON_LOG, line)
}

fn log_error(msg) {
    let line = "[" + now_hms() + "] ERROR: " + msg
    eprintln(line)
    append_line(DAEMON_LOG, line)
}

// ─── 싱글톤 락 ──────────────────────────────────────────────────────
mkdirp(NEXUS_STATE)
if file_exists_simple(PID_FILE) {
    let existing = sh_trim("cat '" + PID_FILE + "' 2>/dev/null | tr -d '[:space:]'")
    if len(existing) > 0 && pid_alive(existing) {
        eprintln("ERROR: NEXUS-6 daemon already running (PID " + existing + ")")
        eprintln("  Kill it first: kill " + existing)
        return 1
    } else if len(existing) > 0 {
        log_warn("Stale PID file found (PID " + existing + " dead). Cleaning up.")
        try { exec("rm -f '" + PID_FILE + "'") } catch e {}
    }
}
let MY_PID = getpid()
write_atomic(PID_FILE, MY_PID)

// shutdown flag 는 시작 시 제거 (잔존 방지)
try { exec("bash", ["-c", "rm -f '" + SHUTDOWN_FLAG + "'"]) } catch e {}

// ─── 측정 (미니멀) ──────────────────────────────────────────────────
fn count_file_lines(path) -> i64 {
    if !file_exists_simple(path) { return 0 }
    let s = sh_trim("wc -l < '" + path + "' 2>/dev/null | tr -d ' '")
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn count_files(pattern, root) -> i64 {
    if !dir_exists_simple(root) { return 0 }
    let s = sh_trim("find '" + root + "' -name '" + pattern + "' -type f 2>/dev/null | wc -l | tr -d ' '")
    let mut v: i64 = 0
    try { v = to_int(s) } catch e { v = 0 }
    return v
}

fn measure_simple() -> [i64] {
    // 15차원 메트릭 현재값 (가용 소스만)
    let atlas_lines = count_file_lines(ATLAS_N6)
    let growth_entries = count_file_lines(GROWTH_LOG)
    let hexa_scripts = count_files("*.hexa", SCRIPT_DIR)
    let lens_count = count_files("*.hexa", NEXUS_ROOT + "/shared/lenses")
    let engine_count = count_files("*.hexa", NEXUS_ROOT + "/shared/engine")
    let blowup_count = count_files("*.hexa", NEXUS_ROOT + "/shared/blowup")
    let discovery_count = count_files("*.jsonl", NEXUS_ROOT + "/shared/discovery")
    // 순서는 DIMENSIONS 와 매칭 (15개)
    let mut m: [i64] = []
    m = m.push(hexa_scripts)        // performance (proxy: script count)
    m = m.push(engine_count)         // architecture
    m = m.push(lens_count)           // lenses
    m = m.push(blowup_count)         // modules
    m = m.push(count_file_lines(NEXUS_ROOT + "/shared/harness/lint_log.jsonl"))  // tests
    m = m.push(count_file_lines(NEXUS_ROOT + "/shared/bt/bt_keywords.jsonl"))    // hypotheses
    m = m.push(count_files("*.json", NEXUS_ROOT + "/shared/dse"))                // dse
    m = m.push(count_files("*.hexa", NEXUS_ROOT + "/shared/calc"))               // experiments
    m = m.push(count_files("*.hexa", NEXUS_ROOT + "/shared/calc"))               // calculators
    m = m.push(count_file_lines(NEXUS_ROOT + "/shared/convergence/nexus.json"))  // cross_resonance
    m = m.push(discovery_count)      // knowledge_graph
    m = m.push(count_files("*.jsonl", NEXUS_ROOT + "/shared/harness"))           // red_team (proxy)
    m = m.push(atlas_lines)          // atlas
    m = m.push(count_files("CLAUDE.md", NEXUS_ROOT))                             // documentation
    m = m.push(growth_entries)       // integration (proxy)
    return m
}

// ─── 최약 차원 픽 ──────────────────────────────────────────────────
// 타겟값 대비 gap 비율 가장 큰 차원 선택
fn pick_weakest(metrics: [i64], cycle: i64) -> string {
    // 타겟 (단순화, 원본 대비 축소)
    let targets = [
        10000, 100, 200, 50, 1000,
        150, 322, 50, 50, 100,
        500, 100, 80000, 10, 500
    ]
    let mut best_idx: i64 = 0
    let mut best_gap: f64 = -1.0
    let mut i: i64 = 0
    while i < 15 {
        let t = targets[i]
        let c = metrics[i]
        let mut gap: f64 = 0.0
        if t > 0 {
            let ratio = (c as f64) / (t as f64)
            if ratio < 1.0 { gap = 1.0 - ratio } else { gap = 0.0 }
        }
        if gap > best_gap {
            best_gap = gap
            best_idx = i
        }
        i = i + 1
    }
    // 모두 만점이면 cycle 기반 rotation
    if best_gap <= 0.0 {
        let ri = cycle % 15
        return DIMENSIONS[ri]
    }
    return DIMENSIONS[best_idx]
}

// ─── 차원별 액션 (미니멀 — 외부 스크립트 위임 or 로깅) ─────────────
fn execute_growth(dim: string) -> bool {
    // 각 차원에 대응하는 외부 스크립트가 있으면 호출, 없으면 no-op 성공
    let script_map = [
        "performance|auto_grow.hexa",
        "architecture|grow_architecture.hexa",
        "lenses|grow_lenses.hexa",
        "modules|grow_modules.hexa",
        "tests|grow_tests.hexa",
        "atlas|build_n6_map.hexa"
    ]
    let mut i: i64 = 0
    while i < len(script_map) {
        let entry = script_map[i]
        let parts = entry.split("|")
        if len(parts) == 2 && parts[0] == dim {
            let script_path = SCRIPT_DIR + "/" + parts[1]
            if file_exists_simple(script_path) {
                log_info("  Action: 위임 → " + parts[1])
                // 조용히 실행 (데몬은 논블로킹 요지)
                try { exec("timeout 60 hexa run '" + script_path + "' >/dev/null 2>&1 &") } catch e {
                    log_warn("  Action 호출 실패: " + parts[1])
                    return false
                }
                return true
            }
        }
        i = i + 1
    }
    // 스크립트 없는 차원: 로깅만 (성장 액션 스킵, no-failure)
    log_info("  Action: " + dim + " — 위임 스크립트 없음, 측정만")
    return true
}

// ─── 사이클 로그 ───────────────────────────────────────────────────
fn append_growth_log(cycle: i64, dim: string, action: string, success: bool, metrics: [i64]) {
    let ok = if success { "true" } else { "false" }
    // 15 차원 값 JSON 조립
    let mut metrics_json = ""
    let mut i: i64 = 0
    while i < 15 {
        if i > 0 { metrics_json = metrics_json + "," }
        metrics_json = metrics_json + "\"" + DIMENSIONS[i] + "\":" + to_string(metrics[i])
        i = i + 1
    }
    let line = "{\"timestamp\":\"" + now_utc() + "\",\"cycle\":" + to_string(cycle) +
               ",\"dimension\":\"" + dim + "\",\"action\":\"" + action + "\"" +
               ",\"success\":" + ok + "," + metrics_json + "}"
    append_line(GROWTH_LOG, line)
}

// ─── Graceful shutdown 체크 ───────────────────────────────────────
fn shutdown_requested() -> bool {
    return file_exists_simple(SHUTDOWN_FLAG)
}

// ─── 정리 함수 ──────────────────────────────────────────────────────
fn cleanup() {
    try { exec("rm -f '" + PID_FILE + "'") } catch e {}
    log_info("PID file removed. Shutdown complete.")
}

// ─── 메인 루프 ──────────────────────────────────────────────────────
println("")
println("  +============================================+")
println("  |   NEXUS-6 Universal Growth Daemon (hexa)   |")
println("  |   Max cycles: " + to_string(MAX_CYCLES) + "  Interval: " + to_string(INTERVAL_MIN) + "m          |")
if len(FORCE_DIM) > 0 {
    println("  |   Forced dim: " + FORCE_DIM + "                     |")
}
if DRY_RUN { println("  |   DRY-RUN mode                             |") }
println("  |   PID: " + MY_PID + "                              |")
println("  +============================================+")
println("")

log_info("Daemon started (PID " + MY_PID + ")")

let mut cycle: i64 = 1
let mut consecutive_failures: i64 = 0
let MAX_CONSEC_FAIL: i64 = 3
let mut stopped_early = false

while cycle <= MAX_CYCLES {
    // graceful shutdown check
    if shutdown_requested() {
        log_info("Shutdown flag detected. Exiting gracefully.")
        stopped_early = true
        // flag 자체는 지움 (다음 기동 대비)
        try { exec("rm -f '" + SHUTDOWN_FLAG + "'") } catch e {}
        cycle = MAX_CYCLES + 1
    }
    if !stopped_early {
        println("")
        println("  ========================================")
        println("  Cycle " + to_string(cycle) + " / " + to_string(MAX_CYCLES))
        println("  ========================================")

        // 1. 측정
        log_info("Step 1/4: Measuring dimensions...")
        let metrics = measure_simple()

        // 2. 차원 선택
        let mut dim = ""
        if len(FORCE_DIM) > 0 {
            dim = FORCE_DIM
            log_info("Step 2/4: Forced dimension: " + dim)
        } else {
            dim = pick_weakest(metrics, cycle)
            log_info("Step 2/4: Weakest dimension: " + dim)
        }

        // 3. 액션
        let mut action_ok = true
        if DRY_RUN {
            log_info("Step 3/4: [DRY-RUN] Skipping growth action.")
            append_growth_log(cycle, dim, "dry-run", true, metrics)
        } else {
            log_info("Step 3/4: Executing growth for '" + dim + "'...")
            action_ok = execute_growth(dim)
            if action_ok {
                consecutive_failures = 0
            } else {
                consecutive_failures = consecutive_failures + 1
                log_warn("Consecutive failures: " + to_string(consecutive_failures) + " / " + to_string(MAX_CONSEC_FAIL))
            }
            append_growth_log(cycle, dim, dim, action_ok, metrics)
        }

        // 4. 로그
        log_info("Step 4/4: Cycle logged to " + GROWTH_LOG)

        // 안전 브레이크
        if consecutive_failures >= MAX_CONSEC_FAIL {
            log_error("Safety brake: " + to_string(MAX_CONSEC_FAIL) + " consecutive failures. Stopping.")
            stopped_early = true
            cycle = MAX_CYCLES + 1
        }

        // sleep (interruptible — shutdown 체크 fine-grained)
        if cycle < MAX_CYCLES && !stopped_early {
            let sleep_sec: i64 = INTERVAL_MIN * 60
            log_info("Sleeping " + to_string(INTERVAL_MIN) + "m (" + to_string(sleep_sec) + "s)...")
            // 10초 단위로 분할 sleep (shutdown 반응성)
            let mut slept: i64 = 0
            while slept < sleep_sec && !shutdown_requested() {
                let step: i64 = if (sleep_sec - slept) > 10 { 10 } else { sleep_sec - slept }
                try { exec("sleep " + to_string(step)) } catch e {}
                slept = slept + step
            }
            if shutdown_requested() {
                log_info("Shutdown during sleep. Exiting.")
                stopped_early = true
                try { exec("rm -f '" + SHUTDOWN_FLAG + "'") } catch e {}
                cycle = MAX_CYCLES + 1
            }
        }
    }
    cycle = cycle + 1
}

// ─── 정리 + 종료 ─────────────────────────────────────────────────
println("")
println("  +============================================+")
println("  |   Growth Complete: " + to_string(MAX_CYCLES) + " cycle(s)              |")
println("  |   Failures: " + to_string(consecutive_failures) + "                              |")
println("  +============================================+")
println("")

cleanup()
return 0
