// ============================================================
// CROSS-DSE: top-5 from each domain
// ============================================================
let top_n = 5
let cross_total = top_n * top_n * top_n * top_n

println("")
println("===============================================================")
println("  CROSS-DSE: Energy Integration")
println("===============================================================")
println("  Domain top-" + to_string(top_n) + " winners x 4 domains = " + to_string(cross_total) + " combinations")
println("")

let mut cr_fu = []
let mut cr_sl = []
let mut cr_bt = []
let mut cr_gr = []
let mut cr_n6 = []
let mut cr_score = []

let mut fi = 0
while fi < top_n {
  let mut sli = 0
  while sli < top_n {
    let mut bi = 0
    while bi < top_n {
      let mut gi = 0
      while gi < top_n {
        let tn6 = fu_r_n6[fi] + sl_r_n6[sli] + bt_r_n6[bi] + gr_r_n6[gi]
        let ts = (fu_r_total[fi] + sl_r_total[sli] + bt_r_total[bi] + gr_r_total[gi]) / 4.0

        cr_fu = cr_fu + [fi]
        cr_sl = cr_sl + [sli]
        cr_bt = cr_bt + [bi]
        cr_gr = cr_gr + [gi]
        cr_n6 = cr_n6 + [tn6]
        cr_score = cr_score + [ts]

        gi = gi + 1
      }
      bi = bi + 1
    }
    sli = sli + 1
  }
  fi = fi + 1
}

// Sort cross results
let mut ci = 0
while ci < cross_total - 1 {
  let mut cbest = ci
  let mut cj = ci + 1
  while cj < cross_total {
    if cr_score[cj] > cr_score[cbest] { cbest = cj }
    cj = cj + 1
  }
  if cbest != ci {
    let t1 = cr_fu[ci]
    cr_fu[ci] = cr_fu[cbest]
    cr_fu[cbest] = t1
    let t2 = cr_sl[ci]
    cr_sl[ci] = cr_sl[cbest]
    cr_sl[cbest] = t2
    let t3 = cr_bt[ci]
    cr_bt[ci] = cr_bt[cbest]
    cr_bt[cbest] = t3
    let t4 = cr_gr[ci]
    cr_gr[ci] = cr_gr[cbest]
    cr_gr[cbest] = t4
    let t5 = cr_n6[ci]
    cr_n6[ci] = cr_n6[cbest]
    cr_n6[cbest] = t5
    let t6 = cr_score[ci]
    cr_score[ci] = cr_score[cbest]
    cr_score[cbest] = t6
  }
  ci = ci + 1
}

// Top 10 Cross-DSE
println("  Top 10 Cross-DSE Pareto:")
println("  " + repeat_str("-", 120))

let mut crank = 0
while crank < 10 {
  let fui = cr_fu[crank]
  let slx = cr_sl[crank]
  let bti = cr_bt[crank]
  let gri = cr_gr[crank]

  let fu_path = fu_m_id[fu_r_i0[fui]] + "->" + fu_s_id[fu_r_i3[fui]]
  let sl_path = sl_m_id[sl_r_i0[slx]] + "->" + sl_s_id[sl_r_i3[slx]]
  let bt_path = bt_m_id[bt_r_i0[bti]] + "->" + bt_s_id[bt_r_i3[bti]]
  let gr_path = gr_m_id[gr_r_i0[gri]] + "->" + gr_s_id[gr_r_i3[gri]]

  let exact_str = pad_l(to_string(cr_n6[crank]), 2) + "/20"

  println("  | " + pad_l(to_string(crank + 1), 4) + " | " + pad_c(fu_path, 22) + " | " + pad_c(sl_path, 22) + " | " + pad_c(bt_path, 22) + " | " + pad_c(gr_path, 22) + " | " + exact_str + " | " + fmt4(cr_score[crank]) + " |")

  crank = crank + 1
}
println("  " + repeat_str("-", 120))

