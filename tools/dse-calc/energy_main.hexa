// ============================================================
// Performance functions
// ============================================================
fn fusion_perf(m_pa, m_pb, s_pa, s_pb, g_pa, g_pb) {
  let raw = m_pa * s_pa * g_pa
  let max_p = 22.4 * 0.833 * 1000.0
  let perf = min_val(raw / max_p, 1.0)
  let eff = min_val(s_pa, 1.0)
  let cost_raw = 1.0 - (m_pb * 0.02 + s_pb * 0.5 + g_pb * 0.48)
  let cost = clamp01(cost_raw)
  [perf, eff, cost]
}

fn solar_perf(m_pb, p_pa, p_pb, c_pa, c_pb, g_pa, g_pb) {
  let eff = m_pb + p_pa / 100.0
  let raw = eff * c_pa * (1.0 + g_pa / 100.0)
  let max_p = 0.34 * 144.0 * 1.20
  let perf = min_val(raw / max_p, 1.0)
  let cost = clamp01(m_pb * 0.1 + p_pb * 0.3 + c_pb * 0.2 + g_pb * 0.4)
  [perf, min_val(eff, 1.0), cost]
}

fn battery_perf(m_pa, m_pb, p_pa, p_pb, s_pb) {
  let raw = m_pa * s_pb * p_pa
  let max_p = 3860.0 * 768.0 * 1.5
  let perf = min_val(raw / max_p, 1.0)
  let eff = clamp01((p_pa - 1.0) * 0.5 + 0.7)
  let cost = clamp01(m_pb * 0.4 + p_pb * 0.3 + s_pb * 0.01 * 0.3)
  [perf, eff, cost]
}

fn grid_perf(m_pa, m_pb, p_pb, c_pb, s_pa, s_pb, g_pa, g_pb) {
  let thd_factor = 1.0 - p_pb / 100.0
  let raw = s_pa * thd_factor * m_pa * g_pa
  let max_p = 1100.0 * 1.0 * 3.0 * 4.0
  let perf = min_val(raw / max_p, 1.0)
  let eff = min_val(thd_factor, 1.0)
  let cost = clamp01(m_pb * 0.3 + c_pb * 0.2 + s_pb * 0.3 + g_pb * 0.2)
  [perf, eff, cost]
}

