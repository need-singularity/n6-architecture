// N6 Energy DSE — 에너지 통합 설계공간 탐색
// 4 도메인 (Fusion, Solar, Battery, Grid) x 5 레벨 후보 전수탐색
// Original: tools/dse-calc/energy_main.rs

// N6 constants
let N = 6
let SIGMA = 12
let TAU = 4
let PHI = 2
let SOPFR = 5
let J2 = 24
let MU = 1

// Weights
let W_N6 = 0.40
let W_PERF = 0.30
let W_EFF = 0.20
let W_COST = 0.10

// ============================================================
// Helper functions
// ============================================================
fn pad_r(s, w) {
  let mut r = to_string(s)
  while len(r) < w {
    r = r + " "
  }
  r
}

fn pad_l(s, w) {
  let mut r = to_string(s)
  while len(r) < w {
    r = " " + r
  }
  r
}

fn pad_c(s, w) {
  let mut r = to_string(s)
  while len(r) < w {
    if len(r) % 2 == 0 {
      r = r + " "
    } else {
      r = " " + r
    }
  }
  r
}

fn min_val(a, b) {
  if a < b { a } else { b }
}

fn max_val(a, b) {
  if a > b { a } else { b }
}

fn clamp01(v) {
  max_val(0.0, min_val(1.0, v))
}

fn repeat_str(ch, n) {
  let mut r = ""
  let mut i = 0
  while i < n {
    r = r + ch
    i = i + 1
  }
  r
}

fn fmt3(x) {
  let v = round(x * 1000) / 1000
  let mut s = to_string(v)
  // ensure at least X.XXX
  if s == "0" { s = "0.0" }
  if s == "1" { s = "1.0" }
  // find dot position
  let mut has_dot = 0
  let mut di = 0
  while di < len(s) {
    if s[di] == "." { has_dot = 1 }
    di = di + 1
  }
  if has_dot == 0 { s = s + ".0" }
  // pad decimals to 3
  // find dot
  let mut dot_pos = 0
  let mut dk = 0
  while dk < len(s) {
    if s[dk] == "." { dot_pos = dk }
    dk = dk + 1
  }
  let dec_len = len(s) - dot_pos - 1
  if dec_len < 3 { s = s + "0" }
  let dec_len2 = len(s) - dot_pos - 1
  if dec_len2 < 3 { s = s + "0" }
  s
}

fn fmt4(x) {
  let v = round(x * 10000) / 10000
  let mut s = to_string(v)
  if s == "0" { s = "0.0" }
  if s == "1" { s = "1.0" }
  let mut has_dot = 0
  let mut di = 0
  while di < len(s) {
    if s[di] == "." { has_dot = 1 }
    di = di + 1
  }
  if has_dot == 0 { s = s + ".0" }
  let mut dot_pos = 0
  let mut dk = 0
  while dk < len(s) {
    if s[dk] == "." { dot_pos = dk }
    dk = dk + 1
  }
  let dec_len = len(s) - dot_pos - 1
  if dec_len < 4 { s = s + "0" }
  let dec_len2 = len(s) - dot_pos - 1
  if dec_len2 < 4 { s = s + "0" }
  let dec_len3 = len(s) - dot_pos - 1
  if dec_len3 < 4 { s = s + "0" }
  s
}

fn fmt1(x) {
  let v = round(x * 10) / 10
  let mut s = to_string(v)
  if s == "0" { s = "0.0" }
  if s == "1" { s = "1.0" }
  let mut has_dot = 0
  let mut di = 0
  while di < len(s) {
    if s[di] == "." { has_dot = 1 }
    di = di + 1
  }
  if has_dot == 0 { s = s + ".0" }
  s
}

