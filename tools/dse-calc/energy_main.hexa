i0 = 0
while i0 < sl_m_count {
  let mut i1 = 0
  while i1 < sl_p_count {
    let mut i2 = 0
    while i2 < sl_c_count {
      let mut i3 = 0
      while i3 < sl_s_count {
        let mut i4 = 0
        while i4 < sl_g_count {
          let n6c = sl_m_exact[i0] + sl_p_exact[i1] + sl_c_exact[i2] + sl_s_exact[i3] + sl_g_exact[i4]
          let n6s = n6c / 5.0
          let pec = solar_perf(sl_m_pb[i0], sl_p_pa[i1], sl_p_pb[i1], sl_c_pa[i2], sl_c_pb[i2], sl_g_pa[i4], sl_g_pb[i4])
          let ts = W_N6 * n6s + W_PERF * pec[0] + W_EFF * pec[1] + W_COST * pec[2]

          sl_r_i0 = sl_r_i0 + [i0]
          sl_r_i1 = sl_r_i1 + [i1]
          sl_r_i2 = sl_r_i2 + [i2]
          sl_r_i3 = sl_r_i3 + [i3]
          sl_r_i4 = sl_r_i4 + [i4]
          sl_r_n6 = sl_r_n6 + [n6c]
          sl_r_perf = sl_r_perf + [pec[0]]
          sl_r_eff = sl_r_eff + [pec[1]]
          sl_r_cost = sl_r_cost + [pec[2]]
          sl_r_total = sl_r_total + [ts]

          i4 = i4 + 1
        }
        i3 = i3 + 1
      }
      i2 = i2 + 1
    }
    i1 = i1 + 1
  }
  i0 = i0 + 1
}

// Sort solar
si = 0
while si < sl_total - 1 {
  let mut best = si
  let mut sj = si + 1
  while sj < sl_total {
    if sl_r_total[sj] > sl_r_total[best] { best = sj }
    sj = sj + 1
  }
  if best != si {
    let t = sl_r_total[si]
    sl_r_total[si] = sl_r_total[best]
    sl_r_total[best] = t
    let t0 = sl_r_i0[si]
    sl_r_i0[si] = sl_r_i0[best]
    sl_r_i0[best] = t0
    let t1 = sl_r_i1[si]
    sl_r_i1[si] = sl_r_i1[best]
    sl_r_i1[best] = t1
    let t2 = sl_r_i2[si]
    sl_r_i2[si] = sl_r_i2[best]
    sl_r_i2[best] = t2
    let t3 = sl_r_i3[si]
    sl_r_i3[si] = sl_r_i3[best]
    sl_r_i3[best] = t3
    let t4 = sl_r_i4[si]
    sl_r_i4[si] = sl_r_i4[best]
    sl_r_i4[best] = t4
    let tn = sl_r_n6[si]
    sl_r_n6[si] = sl_r_n6[best]
    sl_r_n6[best] = tn
    let tp = sl_r_perf[si]
    sl_r_perf[si] = sl_r_perf[best]
    sl_r_perf[best] = tp
    let te = sl_r_eff[si]
    sl_r_eff[si] = sl_r_eff[best]
    sl_r_eff[best] = te
    let tc = sl_r_cost[si]
    sl_r_cost[si] = sl_r_cost[best]
    sl_r_cost[best] = tc
  }
  si = si + 1
}

