println("+=================================================================+")
println("")
println("  N6 Constants: n=" + to_string(N) + " sigma=" + to_string(SIGMA) + " tau=" + to_string(TAU) + " phi=" + to_string(PHI) + " sopfr=" + to_string(SOPFR) + " J2=" + to_string(J2) + " mu=" + to_string(MU))
println("  Weights: n6=40% perf=30% eff=20% cost=10%")

// ============================================================
// FUSION DSE
// ============================================================
let fu_total = fu_m_count * fu_p_count * fu_c_count * fu_s_count * fu_g_count

println("")
println("===============================================================")
println("  Domain: FUSION (DSE-FU)  ")
println("===============================================================")
println("  Total combinations: " + pad_l(to_string(fu_total), 6))
println("")

let mut fu_r_i0 = []
let mut fu_r_i1 = []
let mut fu_r_i2 = []
let mut fu_r_i3 = []
let mut fu_r_i4 = []
let mut fu_r_n6 = []
let mut fu_r_perf = []
let mut fu_r_eff = []
let mut fu_r_cost = []
let mut fu_r_total = []

let mut i0 = 0
while i0 < fu_m_count {
  let mut i1 = 0
  while i1 < fu_p_count {
    let mut i2 = 0
    while i2 < fu_c_count {
      let mut i3 = 0
      while i3 < fu_s_count {
        let mut i4 = 0
        while i4 < fu_g_count {
          let n6c = fu_m_exact[i0] + fu_p_exact[i1] + fu_c_exact[i2] + fu_s_exact[i3] + fu_g_exact[i4]
          let n6s = n6c / 5.0
          let pec = fusion_perf(fu_m_pa[i0], fu_m_pb[i0], fu_s_pa[i3], fu_s_pb[i3], fu_g_pa[i4], fu_g_pb[i4])
          let ts = W_N6 * n6s + W_PERF * pec[0] + W_EFF * pec[1] + W_COST * pec[2]

          fu_r_i0 = fu_r_i0 + [i0]
          fu_r_i1 = fu_r_i1 + [i1]
          fu_r_i2 = fu_r_i2 + [i2]
          fu_r_i3 = fu_r_i3 + [i3]
          fu_r_i4 = fu_r_i4 + [i4]
          fu_r_n6 = fu_r_n6 + [n6c]
          fu_r_perf = fu_r_perf + [pec[0]]
          fu_r_eff = fu_r_eff + [pec[1]]
          fu_r_cost = fu_r_cost + [pec[2]]
          fu_r_total = fu_r_total + [ts]

          i4 = i4 + 1
        }
        i3 = i3 + 1
      }
      i2 = i2 + 1
    }
    i1 = i1 + 1
  }
  i0 = i0 + 1
}

// Sort fusion (selection sort descending)
let mut si = 0
while si < fu_total - 1 {
  let mut best = si
  let mut sj = si + 1
  while sj < fu_total {
    if fu_r_total[sj] > fu_r_total[best] { best = sj }
    sj = sj + 1
  }
  if best != si {
    let t = fu_r_total[si]
    fu_r_total[si] = fu_r_total[best]
    fu_r_total[best] = t
    let t0 = fu_r_i0[si]
    fu_r_i0[si] = fu_r_i0[best]
    fu_r_i0[best] = t0
    let t1 = fu_r_i1[si]
    fu_r_i1[si] = fu_r_i1[best]
    fu_r_i1[best] = t1
    let t2 = fu_r_i2[si]
    fu_r_i2[si] = fu_r_i2[best]
    fu_r_i2[best] = t2
    let t3 = fu_r_i3[si]
    fu_r_i3[si] = fu_r_i3[best]
    fu_r_i3[best] = t3
    let t4 = fu_r_i4[si]
    fu_r_i4[si] = fu_r_i4[best]
    fu_r_i4[best] = t4
    let tn = fu_r_n6[si]
    fu_r_n6[si] = fu_r_n6[best]
    fu_r_n6[best] = tn
    let tp = fu_r_perf[si]
    fu_r_perf[si] = fu_r_perf[best]
    fu_r_perf[best] = tp
    let te = fu_r_eff[si]
    fu_r_eff[si] = fu_r_eff[best]
    fu_r_eff[best] = te
    let tc = fu_r_cost[si]
    fu_r_cost[si] = fu_r_cost[best]
    fu_r_cost[best] = tc
  }
  si = si + 1
}

// Print Fusion Top 10
println("  Top 10 Pareto:")
println("  " + repeat_str("-", 108))
let mut rank = 0
while rank < 10 {
  println("  | " + pad_l(to_string(rank + 1), 4) + " | " + pad_c(fu_m_id[fu_r_i0[rank]], 16) + " | " + pad_c(fu_p_id[fu_r_i1[rank]], 14) + " | " + pad_c(fu_c_id[fu_r_i2[rank]], 14) + " | " + pad_c(fu_s_id[fu_r_i3[rank]], 14) + " | " + pad_c(fu_g_id[fu_r_i4[rank]], 14) + " | " + to_string(fu_r_n6[rank]) + "/5  | " + fmt3(fu_r_total[rank]) + " | " + fmt3(fu_r_perf[rank]) + " | " + fmt3(fu_r_eff[rank]) + " |")
  rank = rank + 1
}
println("  " + repeat_str("-", 108))

// Fusion statistics
let fu_f = fu_total * 1.0
let mut fu_cnt5 = 0
let mut fu_cnt4 = 0
let mut fu_cnt3 = 0
let mut fsi = 0
while fsi < fu_total {
  if fu_r_n6[fsi] == 5 { fu_cnt5 = fu_cnt5 + 1 }
  if fu_r_n6[fsi] >= 4 { fu_cnt4 = fu_cnt4 + 1 }
  if fu_r_n6[fsi] >= 3 { fu_cnt3 = fu_cnt3 + 1 }
  fsi = fsi + 1
}
println("")
println("  Statistics:")
println("    100% EXACT (5/5): " + pad_l(fmt1(fu_cnt5 / fu_f * 100.0), 6) + "% (" + to_string(fu_cnt5) + " combinations)")
println("    >=80% EXACT (4/5): " + pad_l(fmt1(fu_cnt4 / fu_f * 100.0), 6) + "% (" + to_string(fu_cnt4) + " combinations)")
println("    >=60% EXACT (3/5): " + pad_l(fmt1(fu_cnt3 / fu_f * 100.0), 6) + "% (" + to_string(fu_cnt3) + " combinations)")

