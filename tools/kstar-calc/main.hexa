println("    " + pad_r("Year", 4) + " " + pad_l("Duration", 8) + " " + pad_l("n=6", 8) + "  " + pad_r("Description", 20) + " " + "Match")
println("    " + repeat_str("─", 70))

let ms_year = [2008, 2010, 2016, 2018, 2019, 2020, 2021, 2023, 2024, 2025, 2026]
let ms_dur  = [0.0, 0.1, 1.0, 1.5, 8.0, 20.0, 30.0, 100.0, 300.0, 400.0, 600.0]
let ms_desc = ["첫 플라즈마", "H-mode 달성", "1억도 도달", "고성능 모드", "8초 유지", "20초 유지", "30초 유지", "100초 돌파", "300초 세계기록", "목표 (계획)", "목표 (계획)"]

let mi = 0
while mi < 11 {
  let yr = ms_year[mi]
  let dur = ms_dur[mi]
  let dur_int = round(dur)
  let n6 = n6_match(dur_int)
  let marker = if n6 != "" { "✅" } else { "" }
  let expr_t = if n6 != "" { n6 } else { "-" }
  println("    " + to_string(yr) + " " + pad_l(fmt1(dur) + "s", 8) + " " + pad_l(expr_t, 8) + "  " + pad_r(ms_desc[mi], 20) + " " + marker)
  mi = mi + 1
}

