// ═══ 가열 시스템 n=6 분석 ═══

println("")
println("  ═══ 가열 시스템 n=6 분석 ═══")
println("")

let h_names = ["NBI", "ECH", "ICH", "Total"]
let h_vals = [8, 1, 6, 15]

let exact_count = 0
let idx = 0
while idx < 4 {
  let v = h_vals[idx]
  let n6 = n6_match(v)
  let marker = if n6 != "" { "✅" } else { "❌" }
  let expr = if n6 != "" { "= " + n6 } else { "-" }
  if n6 != "" { exact_count = exact_count + 1 }
  println("    " + marker + " " + pad_r(h_names[idx], 6) + " = " + pad_l(to_string(v), 3) + " MW  " + expr)
  idx = idx + 1
}

println("")
println("    상세 분해:")
println("    NBI 8 MW = sigma - tau = 12 - 4 = 8")
println("    ECH 1 MW = mu(6) = 1")
println("    ICH 6 MW = n = 6")
println("    합 15 MW = sigma + n/phi = 12 + 3 = 15")
println("")
println("    NBI 빔 수: 3 = n/phi ✅")
println("    NBI 에너지: 120 keV = sigma * 10 = 120 ✅")
println("")
let pct = round(100.0 * exact_count / 4.0)
println("    n=6 매칭: " + to_string(exact_count) + "/4 (" + to_string(pct) + "%)")

// ═══ 코일 시스템 n=6 분석 ═══

println("")
println("  ═══ 코일 시스템 n=6 분석 ═══")
println("")

let c_names = ["TF", "PF", "CS", "IVC"]
let c_actual = [16, 14, 8, 4]
let c_expect = [12, 6, 8, 4]
let c_expr = ["sigma", "n", "sigma-tau", "tau"]

let exact = 0
let ci = 0
while ci < 4 {
  let a = c_actual[ci]
  let e = c_expect[ci]
  let diff = abs(a - e)
  let marker = if a == e { "✅" } else if diff <= 2 { "~" } else { "❌" }
  let status = if a == e { "EXACT" } else if diff <= 2 { "CLOSE" } else { "FAIL" }
  if a == e { exact = exact + 1 }
  println("    " + marker + " " + pad_r(c_names[ci], 4) + " = " + pad_l(to_string(a), 2) + " (n=6 → " + c_expr[ci] + " = " + to_string(e) + ") " + status)
  ci = ci + 1
}

println("")
println("    n=6 매칭: " + to_string(exact) + "/4")
println("")
println("    분석:")
println("    TF 16 ≠ sigma=12: KSTAR는 ITER(18)보다 작지만 여전히 n=6 예측 실패")
println("    PF 14 ≠ n=6: 7쌍 구조, ITER(6)보다 많음")
println("    CS 8 = sigma-tau: 4개 솔레노이드 × 2섹션 = 8 ✅")
println("    IVC 4 = tau: 플라즈마 안정화 코일 정확히 4개 ✅")

// ═══ 플라즈마 형상 n=6 분석 ═══

println("")
println("  ═══ 플라즈마 형상 n=6 분석 ═══")
println("")

let r0_m = 1.8
let a_m = 0.5
let kappa = 2.0
let delta_val = 0.8
let bt_t = 3.5
let ip_ma = 2.0
let pi_val = 3.14159265358979

let a_check = abs(a_m - 0.5) < 0.01
let kappa_check = abs(kappa - 2.0) < 0.05
let delta_check = abs(delta_val - 1.0 / 3.0) < 0.1
let ar = r0_m / a_m
let aspect_check = abs(ar - 3.0) < 0.3

println("    R₀ = " + fmt2(r0_m) + " m  (n=6 예측 없음)")

let a_mark = if a_check { "✅" } else { "~" }
let a_status = if a_check { "EXACT" } else { "CLOSE" }
println("    " + a_mark + " a = " + fmt2(a_m) + " m  (phi/tau = 0.5) " + a_status)

let k_mark = if kappa_check { "✅" } else { "~" }
let k_status = if kappa_check { "EXACT" } else { "CLOSE" }
println("    " + k_mark + " kappa = " + fmt2(kappa) + "    (phi = 2) " + k_status)

let d_mark = if delta_check { "✅" } else { "❌" }
let d_status = if delta_check { "EXACT" } else { "FAIL" }
println("    " + d_mark + " delta = " + fmt2(delta_val) + "    (1/3 = 0.33) " + d_status)

let ar_mark = if aspect_check { "✅" } else { "~" }
let ar_status = if aspect_check { "EXACT" } else { "CLOSE" }
println("    " + ar_mark + " A = " + fmt2(ar) + "    (n/phi = 3) " + ar_status)

let vol = 2.0 * pi_val * r0_m * pi_val * a_m * a_m * kappa
println("")
println("    B_T = " + fmt1(bt_t) + " T")
println("    I_p = " + fmt1(ip_ma) + " MA (phi = 2) ✅ EXACT")
println("    Volume = " + fmt1(vol) + " m³")

