// KSTAR 전용 계산기 — n=6 기반 심층 분석 (HEXA port)
// Original: tools/kstar-calc/main.rs

// ═══════════════════════════════════════════════════════════════
// helpers (no global refs)
// ═══════════════════════════════════════════════════════════════

fn repeat_str(s, n) {
  let r = ""
  let i = 0
  while i < n {
    r = r + s
    i = i + 1
  }
  return r
}

fn pad_r(s, w) {
  let r = to_string(s)
  while len(r) < w {
    r = r + " "
  }
  return r
}

fn pad_l(s, w) {
  let r = to_string(s)
  while len(r) < w {
    r = " " + r
  }
  return r
}

fn fmt0(x) {
  return to_string(round(x))
}

fn fmt1(x) {
  return to_string(round(x * 10.0) / 10.0)
}

fn fmt2(x) {
  return to_string(round(x * 100.0) / 100.0)
}

fn n6_match(v) {
  if v == 1 { return "mu" }
  if v == 2 { return "phi" }
  if v == 3 { return "n/phi" }
  if v == 4 { return "tau" }
  if v == 5 { return "sopfr" }
  if v == 6 { return "n" }
  if v == 7 { return "sigma-sopfr" }
  if v == 8 { return "sigma-tau" }
  if v == 10 { return "n+tau" }
  if v == 12 { return "sigma" }
  if v == 14 { return "sigma+phi" }
  if v == 15 { return "sigma+n/phi" }
  if v == 16 { return "sigma+tau" }
  if v == 18 { return "sigma+n" }
  if v == 20 { return "sigma+sigma-tau" }
  if v == 24 { return "J2" }
  if v == 25 { return "sopfr^2" }
  if v == 36 { return "n^2" }
  if v == 48 { return "sigma*tau" }
  if v == 60 { return "sigma*sopfr" }
  if v == 72 { return "sigma*n" }
  if v == 120 { return "sigma*10" }
  if v == 300 { return "sigma*sopfr^2" }
  if v == 360 { return "sigma*sopfr*n/phi" }
  if v == 600 { return "J2*sopfr^2" }
  return ""
}

