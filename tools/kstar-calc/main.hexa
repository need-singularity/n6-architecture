let d_name    = ["KSTAR", "EAST", "JT-60SA", "ITER", "SPARC"]
let d_country = ["한국", "중국", "일본/EU", "국제", "미국"]
let d_r0      = [1.8, 1.9, 2.96, 6.2, 1.85]
let d_a       = [0.5, 0.5, 1.18, 2.0, 0.57]
let d_kappa   = [2.0, 1.9, 1.95, 1.7, 1.97]
let d_bt      = [3.5, 3.5, 2.25, 5.3, 12.2]
let d_ip      = [2.0, 1.0, 5.5, 15.0, 8.7]
let d_tf      = [16, 16, 18, 18, 18]
let d_pf      = [14, 14, 8, 6, 0]
let d_rec_s   = [300.0, 1066.0, 0.0, 0.0, 0.0]
let d_rec_t   = [100.0, 70.0, 0.0, 0.0, 0.0]
let d_qt      = [0.0, 0.0, 0.0, 10.0, 11.0]
let d_status  = ["운전중", "운전중", "시운전", "건설중", "건설중"]

println("  [기본 스펙 비교]")
println("")
println("    " + pad_r("Device", 10) + " " + pad_r("국가", 6) + " " + pad_l("R₀", 5) + " " + pad_l("a", 5) + " " + pad_l("kappa", 5) + " " + pad_l("B_T", 5) + " " + pad_l("I_p", 5) + " " + pad_l("TF", 4) + " " + pad_l("PF", 4) + " " + pad_l("Record", 8) + " " + pad_l("Status", 8))
println("    " + repeat_str("─", 90))

let di = 0
while di < 5 {
  let record = if d_rec_s[di] > 0.0 { fmt0(d_rec_s[di]) + "s@" + fmt0(d_rec_t[di]) + "M" } else { "-" }
  println("    " + pad_r(d_name[di], 10) + " " + pad_r(d_country[di], 6) + " " + pad_l(fmt2(d_r0[di]), 5) + " " + pad_l(fmt2(d_a[di]), 5) + " " + pad_l(fmt2(d_kappa[di]), 5) + " " + pad_l(fmt1(d_bt[di]), 5) + " " + pad_l(fmt1(d_ip[di]), 5) + " " + pad_l(to_string(d_tf[di]), 4) + " " + pad_l(to_string(d_pf[di]), 4) + " " + pad_l(record, 8) + " " + pad_l(d_status[di], 8))
  di = di + 1
}

// n=6 score comparison
println("")
println("  [n=6 점수 비교]")
println("")
println("    " + pad_r("Device", 10) + " " + pad_l("Score", 6) + " " + pad_r("Matches", 40))
println("    " + repeat_str("─", 60))

let si = 0
while si < 5 {
  let score = 0.0
  let matches = ""

  if abs(d_a[si] - 0.5) < 0.1 {
    score = score + 1.0
    matches = if matches == "" { "a=phi/tau" } else { matches + ", a=phi/tau" }
  }

  if abs(d_kappa[si] - 2.0) < 0.1 {
    score = score + 1.0
    matches = if matches == "" { "kappa=phi" } else { matches + ", kappa=phi" }
  }

  let asp = d_r0[si] / d_a[si]
  if abs(asp - 3.0) < 0.3 {
    score = score + 0.5
    matches = if matches == "" { "A~n/phi" } else { matches + ", A~n/phi" }
  }

  if d_pf[si] == 6 {
    score = score + 1.0
    matches = if matches == "" { "PF=n" } else { matches + ", PF=n" }
  }

  if d_tf[si] == 12 {
    score = score + 1.0
    matches = if matches == "" { "TF=sigma" } else { matches + ", TF=sigma" }
  }

  if abs(d_qt[si] - 10.0) < 0.5 {
    score = score + 1.0
    matches = if matches == "" { "Q=n+tau" } else { matches + ", Q=n+tau" }
  }

  if abs(d_bt[si] - 12.0) < 1.0 {
    score = score + 1.0
    matches = if matches == "" { "B~sigma" } else { matches + ", B~sigma" }
  }

  if abs(d_ip[si] - 2.0) < 0.3 {
    score = score + 0.5
    matches = if matches == "" { "Ip~phi" } else { matches + ", Ip~phi" }
  }

  println("    " + pad_r(d_name[si], 10) + " " + pad_l(fmt1(score), 6) + " " + pad_r(matches, 40))
  si = si + 1
}

