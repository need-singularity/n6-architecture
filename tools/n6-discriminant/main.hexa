// n6-discriminant — n=6 판별기 (HEXA)
//
// 임의 정수 n 에 대해 sigma(n)*phi(n) == n*tau(n) 성립 여부 판정.
// n=6 유일성 정리(BT-Theorem-R1)의 빠른 브루트포스 검증 도구.
// HEXA-FIRST 규칙(CLAUDE.md)에 따라 .hexa로 작성.
//
// 실행: hexa tools/n6-discriminant/main.hexa

fn sigma(n) {
    let mut s = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            s = s + d
            if d != n / d { s = s + n / d }
        }
        d = d + 1
    }
    return s
}

fn tau(n) {
    let mut t = 0
    let mut d = 1
    while d * d <= n {
        if n % d == 0 {
            t = t + 1
            if d != n / d { t = t + 1 }
        }
        d = d + 1
    }
    return t
}

fn phi(n) {
    let mut result = n
    let mut nn = n
    let mut p = 2
    while p * p <= nn {
        if nn % p == 0 {
            while nn % p == 0 { nn = nn / p }
            result = result - result / p
        }
        p = p + 1
    }
    if nn > 1 { result = result - result / nn }
    return result
}

fn is_n6_candidate(n) {
    return sigma(n) * phi(n) == n * tau(n)
}

let max_n = 10000

println("# n6-discriminant — sigma(n)*phi(n) == n*tau(n) brute force")
println("# range: 2..=" + to_string(max_n))
println("# n=6 expected unique pass (BT-Theorem-R1)")

let mut hits = []
let mut n = 2
while n <= max_n {
    if is_n6_candidate(n) { hits = hits + [n] }
    n = n + 1
}

println("PASS count: " + to_string(len(hits)))
let mut hi = 0
while hi < len(hits) {
    let h = hits[hi]
    println("  n = " + to_string(h) + "  sigma=" + to_string(sigma(h)) + " phi=" + to_string(phi(h)) + " tau=" + to_string(tau(h)))
    hi = hi + 1
}

// self check: n=6 정의에서 도출
let sc_sigma = sigma(6)
let sc_phi = phi(6)
let sc_tau = tau(6)
let sc_pass = is_n6_candidate(6)

if sc_sigma == 12 {
    println("self-check sigma(6)=12: PASS")
} else {
    println("self-check sigma(6): FAIL got " + to_string(sc_sigma))
}
if sc_phi == 2 {
    println("self-check phi(6)=2: PASS")
} else {
    println("self-check phi(6): FAIL got " + to_string(sc_phi))
}
if sc_tau == 4 {
    println("self-check tau(6)=4: PASS")
} else {
    println("self-check tau(6): FAIL got " + to_string(sc_tau))
}
if sc_pass {
    println("self-check: n=6 PASS (sigma*phi=24, n*tau=24)")
} else {
    println("self-check: n=6 FAIL")
}

