    expr = expr + ["sigma_sq"]
    claimed = claimed + [144.0]
    expr = expr + ["sopfr*2^n"]
    claimed = claimed + [320.0]

    // Powers
    expr = expr + ["sigma^2"]
    claimed = claimed + [144.0]
    expr = expr + ["sigma^3"]
    claimed = claimed + [1728.0]
    expr = expr + ["sigma^4"]
    claimed = claimed + [20736.0]
    expr = expr + ["phi^tau"]
    claimed = claimed + [16.0]
    expr = expr + ["2^n"]
    claimed = claimed + [64.0]
    expr = expr + ["2^sigma"]
    claimed = claimed + [4096.0]
    expr = expr + ["2^sopfr"]
    claimed = claimed + [32.0]
    expr = expr + ["2^(sigma-tau)"]
    claimed = claimed + [256.0]
    expr = expr + ["2^(sigma-sopfr)"]
    claimed = claimed + [128.0]
    expr = expr + ["phi^n"]
    claimed = claimed + [64.0]
    expr = expr + ["J2^2"]
    claimed = claimed + [576.0]
    expr = expr + ["sigma^2*tau"]
    claimed = claimed + [576.0]

    // Combined powers
    expr = expr + ["sigma^2-phi"]
    claimed = claimed + [142.0]
    expr = expr + ["sigma^2-n/phi"]
    claimed = claimed + [141.0]
    expr = expr + ["sigma^2+tau"]
    claimed = claimed + [148.0]
    expr = expr + ["sigma^2-sigma"]
    claimed = claimed + [132.0]
    expr = expr + ["phi^tau*sopfr"]
    claimed = claimed + [80.0]
    expr = expr + ["sigma*phi^tau"]
    claimed = claimed + [192.0]
    expr = expr + ["(sigma-phi)^tau"]
    claimed = claimed + [10000.0]
    expr = expr + ["(sigma-phi)^2*tau"]
    claimed = claimed + [400.0]
    expr = expr + ["(sigma-phi)^3"]
    claimed = claimed + [1000.0]
    expr = expr + ["(sigma-phi)^(n/phi)"]
    claimed = claimed + [1000.0]
    expr = expr + ["(sigma-phi)^(-tau)"]
