    expr = expr + ["(sigma+n/phi)/(sigma-sopfr)"]
    claimed = claimed + [2.142857]
    expr = expr + ["1/n"]
    claimed = claimed + [0.166667]
    expr = expr + ["1/e"]
    claimed = claimed + [0.367879]
    expr = expr + ["phi/(sigma-phi)^phi"]
    claimed = claimed + [0.02]

    // Adam / LLM
    expr = expr + ["1-1/(J2-tau)"]
    claimed = claimed + [0.95]
    expr = expr + ["1-1/(sigma-phi)"]
    claimed = claimed + [0.9]
    expr = expr + ["10^(-(sigma-tau))"]
    claimed = claimed + [0.00000001]
    expr = expr + ["R(6)"]
    claimed = claimed + [1.0]
    expr = expr + ["ln(4/3)"]
    claimed = claimed + [0.2877]
    expr = expr + ["tau^2/(n/phi)^3"]
    claimed = claimed + [0.592593]
    expr = expr + ["1/(sigma-phi)^(n/phi)"]
    claimed = claimed + [0.001]

    // Cosmology
    expr = expr + ["1-mu/P2"]
    claimed = claimed + [0.964286]
    expr = expr + ["sigma/sigma(P2)^2"]
    claimed = claimed + [0.003827]
    expr = expr + ["(n/phi+mu/sigma)*10^(-sopfr)"]
    claimed = claimed + [0.0000308333]

    // Egyptian
    expr = expr + ["sigma^2*sigma*J2"]
    claimed = claimed + [41472.0]
    expr = expr + ["sigma^2*tau/2"]
    claimed = claimed + [288.0]
    expr = expr + ["sigma^2*240W"]
    claimed = claimed + [34560.0]

    // Fine structure
    expr = expr + ["sigma(sigma-mu)+sopfr+mu/P2"]
    claimed = claimed + [137.035714]

    // J2 identity
    expr = expr + ["tau*sopfr"]
    claimed = claimed + [20.0]

    [expr, claimed]
}

// Lookup: find expected value for an expression key
fn lookup_val(names, vals, key) {
    let mut i = 0
    while i < len(names) {
        if names[i] == key {
            return vals[i]
        }
        i = i + 1
    }
    -999999.0
}

// === Main ===
println("=== N6 Atlas Verifier (HEXA) ===")
println("Mode: embedded test rows (sandbox — no file I/O)")
println("")

let lu = build_lookup()
let lu_names = lu[0]
let lu_vals = lu[1]

let test = build_test_rows()
let t_expr = test[0]
let t_claimed = test[1]

let total_rows = len(t_expr)
let mut evaluated = 0
let mut skipped = 0
let mut exact_count = 0
let mut close_count = 0
let mut weak_count = 0
let mut fail_count = 0

// Result arrays
let mut r_expr = []
let mut r_expected = []
let mut r_actual = []
let mut r_grade = []

let mut idx = 0
while idx < total_rows {
    let key = t_expr[idx]
    let claimed = t_claimed[idx]
    let expected = lookup_val(lu_names, lu_vals, key)

    if expected == -999999.0 {
        skipped = skipped + 1
        idx = idx + 1
        continue
    }

    let g = grade(expected, claimed)
    r_expr = r_expr + [key]
    r_expected = r_expected + [expected]
    r_actual = r_actual + [claimed]
    r_grade = r_grade + [g]
    evaluated = evaluated + 1

    if g == "EXACT" {
        exact_count = exact_count + 1
    } else if g == "CLOSE" {
        close_count = close_count + 1
    } else if g == "WEAK" {
        weak_count = weak_count + 1
    } else {
        fail_count = fail_count + 1
    }

    idx = idx + 1
}

println("Total test rows: " + to_string(total_rows))
println("Evaluated:       " + to_string(evaluated))
println("Skipped:         " + to_string(skipped))
println("")

let denom = if evaluated > 0 { evaluated } else { 1 }
let exact_pct = rd2(100.0 * exact_count / denom)
let close_pct = rd2(100.0 * close_count / denom)
let weak_pct = rd2(100.0 * weak_count / denom)
let fail_pct = rd2(100.0 * fail_count / denom)

println("--- Summary ---")
println("  EXACT : " + to_string(exact_count) + " (" + to_string(exact_pct) + "%)")
println("  CLOSE : " + to_string(close_count) + " (" + to_string(close_pct) + "%)")
println("  WEAK  : " + to_string(weak_count) + " (" + to_string(weak_pct) + "%)")
println("  FAIL  : " + to_string(fail_count) + " (" + to_string(fail_pct) + "%)")
println("")

// Show non-EXACT entries
let mut has_non_exact = false
let mut ni = 0
while ni < evaluated {
    if r_grade[ni] != "EXACT" {
        has_non_exact = true
    }
    ni = ni + 1
}

if has_non_exact {
    println("--- Non-EXACT entries ---")
    println(pad_r("Expression", 40) + pad_l("Expected", 14) + pad_l("Actual", 14) + "  Grade")
    println("-".repeat(40) + "-".repeat(14) + "-".repeat(14) + "  ------")
    let mut j = 0
    while j < evaluated {
        if r_grade[j] != "EXACT" {
            println(pad_r(r_expr[j], 40) + pad_l(to_string(rd6(r_expected[j])), 14) + pad_l(to_string(rd6(r_actual[j])), 14) + "  " + r_grade[j])
        }
        j = j + 1
    }
} else {
    println("All " + to_string(evaluated) + " evaluated expressions are EXACT.")
}

// Show failures prominently
if fail_count > 0 {
    println("")
    println("!!! " + to_string(fail_count) + " FAILURES detected !!!")
    let mut k = 0
    while k < evaluated {
        if r_grade[k] == "FAIL" {
            let exp = r_expected[k]
            let act = r_actual[k]
            let d2 = if abs(exp) > pow(10.0, -30.0) { abs(exp) } else { pow(10.0, -30.0) }
            let rel_pct = rd2(abs((act - exp) / d2) * 100.0)
            println("  " + r_expr[k] + " -- expected " + to_string(exp) + ", got " + to_string(act) + " (err " + to_string(rel_pct) + "%)")
        }
        k = k + 1
    }
}
