// atlas-verifier — N6 Atlas Constants Auto-Verifier (HEXA port)
// Original: tools/atlas-verifier/main.rs
// Sandbox: no file I/O — embeds representative test rows inline

let N = 6.0
let PHI = 2.0
let TAU = 4.0
let SIGMA = 12.0
let J2 = 24.0
let SOPFR = 5.0
let MU = 1.0
let E_CONST = 2.718281828459045

fn pad_r(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = r + " " }
    r
}
fn pad_l(s, w) {
    let mut r = to_string(s)
    while len(r) < w { r = " " + r }
    r
}
fn rd2(x) { round(x * 100.0) / 100.0 }
fn rd4(x) { round(x * 10000.0) / 10000.0 }
fn rd6(x) { round(x * 1000000.0) / 1000000.0 }

fn grade(expected, actual) {
    if expected == 0.0 {
        if actual == 0.0 { return "EXACT" }
    }
    let denom = abs(expected)
    let d = if denom > pow(10.0, -30.0) { denom } else { pow(10.0, -30.0) }
    let rel_err = abs((actual - expected) / d)
    if rel_err < 0.0001 {
        "EXACT"
    } else if rel_err < 0.05 {
        "CLOSE"
    } else if rel_err < 0.20 {
        "WEAK"
    } else {
        "FAIL"
    }
}

// Build lookup: (expression_name, expected_value) pairs
// This replaces Rust HashMap — linear scan is fine for ~100 entries
fn build_lookup() {
    let mut names = []
    let mut vals = []

    // Base
    names = names + ["sigma"]
    vals = vals + [SIGMA]
    names = names + ["tau"]
    vals = vals + [TAU]
    names = names + ["phi"]
    vals = vals + [PHI]
    names = names + ["sopfr"]
    vals = vals + [SOPFR]
    names = names + ["J2"]
    vals = vals + [J2]
    names = names + ["mu"]
    vals = vals + [MU]
    names = names + ["n"]
    vals = vals + [N]

    // Simple arithmetic
    names = names + ["sigma-tau"]
    vals = vals + [SIGMA - TAU]
    names = names + ["sigma-phi"]
    vals = vals + [SIGMA - PHI]
    names = names + ["sigma-mu"]
    vals = vals + [SIGMA - MU]
    names = names + ["sigma+mu"]
    vals = vals + [SIGMA + MU]
    names = names + ["sigma-sopfr"]
    vals = vals + [SIGMA - SOPFR]
    names = names + ["J2-tau"]
    vals = vals + [J2 - TAU]
    names = names + ["J2+phi"]
    vals = vals + [J2 + PHI]
    names = names + ["sigma+n/phi"]
    vals = vals + [SIGMA + N / PHI]
    names = names + ["n/phi"]
    vals = vals + [N / PHI]

    // Products
    names = names + ["sigma*tau"]
    vals = vals + [SIGMA * TAU]
    names = names + ["sigma*n"]
    vals = vals + [SIGMA * N]
    names = names + ["sigma*phi"]
    vals = vals + [SIGMA * PHI]
    names = names + ["sigma*sopfr"]
    vals = vals + [SIGMA * SOPFR]
    names = names + ["sigma*J2"]
    vals = vals + [SIGMA * J2]
    names = names + ["sigma*(sigma-phi)"]
    vals = vals + [SIGMA * (SIGMA - PHI)]
    names = names + ["sigma*(sigma-tau)"]
    vals = vals + [SIGMA * (SIGMA - TAU)]
    names = names + ["sigma*(sigma-1)/2"]
    vals = vals + [SIGMA * (SIGMA - 1.0) / 2.0]
    names = names + ["sigma*(sigma-tau)*2^n"]
    vals = vals + [SIGMA * (SIGMA - TAU) * pow(2.0, N)]
    names = names + ["sopfr*phi"]
    vals = vals + [SOPFR * PHI]
    names = names + ["sopfr*(sigma-phi)"]
    vals = vals + [SOPFR * (SIGMA - PHI)]
    names = names + ["sigma*tau*(sigma-phi)"]
    vals = vals + [SIGMA * TAU * (SIGMA - PHI)]
    names = names + ["sigma*sopfr*tau"]
    vals = vals + [SIGMA * SOPFR * TAU]
    names = names + ["J2*(sigma-phi)"]
    vals = vals + [J2 * (SIGMA - PHI)]
    names = names + ["sigma*n+phi"]
    vals = vals + [SIGMA * N + PHI]
    names = names + ["sigma_sq"]
    vals = vals + [SIGMA * SIGMA]
    names = names + ["sopfr*2^n"]
    vals = vals + [SOPFR * pow(2.0, N)]

    // Powers
    names = names + ["sigma^2"]
    vals = vals + [SIGMA * SIGMA]
    names = names + ["sigma^3"]
    vals = vals + [pow(SIGMA, 3.0)]
    names = names + ["sigma^4"]
    vals = vals + [pow(SIGMA, 4.0)]
    names = names + ["phi^tau"]
    vals = vals + [pow(PHI, TAU)]
    names = names + ["2^n"]
    vals = vals + [pow(2.0, N)]
    names = names + ["2^sigma"]
    vals = vals + [pow(2.0, SIGMA)]
    names = names + ["2^sopfr"]
    vals = vals + [pow(2.0, SOPFR)]
    names = names + ["2^(sigma-tau)"]
    vals = vals + [pow(2.0, SIGMA - TAU)]
    names = names + ["2^(sigma-sopfr)"]
    vals = vals + [pow(2.0, SIGMA - SOPFR)]
    names = names + ["phi^n"]
    vals = vals + [pow(PHI, N)]
    names = names + ["J2^2"]
    vals = vals + [J2 * J2]
    names = names + ["sigma^2*tau"]
    vals = vals + [SIGMA * SIGMA * TAU]

    // Combined powers
    names = names + ["sigma^2-phi"]
    vals = vals + [SIGMA * SIGMA - PHI]
    names = names + ["sigma^2-n/phi"]
    vals = vals + [SIGMA * SIGMA - N / PHI]
    names = names + ["sigma^2+tau"]
    vals = vals + [SIGMA * SIGMA + TAU]
    names = names + ["sigma^2-sigma"]
    vals = vals + [SIGMA * SIGMA - SIGMA]
    names = names + ["phi^tau*sopfr"]
    vals = vals + [pow(PHI, TAU) * SOPFR]
    names = names + ["sigma*phi^tau"]
    vals = vals + [SIGMA * pow(PHI, TAU)]
    names = names + ["(sigma-phi)^tau"]
    vals = vals + [pow(SIGMA - PHI, TAU)]
    names = names + ["(sigma-phi)^2*tau"]
    vals = vals + [pow(SIGMA - PHI, 2.0) * TAU]
    names = names + ["(sigma-phi)^3"]
    vals = vals + [pow(SIGMA - PHI, 3.0)]
    names = names + ["(sigma-phi)^(n/phi)"]
    vals = vals + [pow(SIGMA - PHI, N / PHI)]
    names = names + ["(sigma-phi)^(-tau)"]
    vals = vals + [pow(SIGMA - PHI, 0.0 - TAU)]
    names = names + ["tau*(sigma-phi)"]
    vals = vals + [TAU * (SIGMA - PHI)]

    // Ratios
    names = names + ["tau^2/sigma"]
    vals = vals + [TAU * TAU / SIGMA]
    names = names + ["phi/tau"]
    vals = vals + [PHI / TAU]
    names = names + ["tau/(n/phi)"]
    vals = vals + [TAU / (N / PHI)]
    names = names + ["tau/(sigma-sopfr)"]
    vals = vals + [TAU / (SIGMA - SOPFR)]
    names = names + ["mu/sigma"]
    vals = vals + [MU / SIGMA]
    names = names + ["mu/J2"]
    vals = vals + [MU / J2]
    names = names + ["phi^2/n"]
    vals = vals + [PHI * PHI / N]
    names = names + ["sigma/(sigma-phi)"]
    vals = vals + [SIGMA / (SIGMA - PHI)]
    names = names + ["(sigma-mu)/(sigma-phi)"]
    vals = vals + [(SIGMA - MU) / (SIGMA - PHI)]
    names = names + ["1/(sigma-phi)"]
    vals = vals + [1.0 / (SIGMA - PHI)]
    names = names + ["phi/(sigma-phi)"]
    vals = vals + [PHI / (SIGMA - PHI)]
    names = names + ["(n/phi)/(sigma-phi)"]
    vals = vals + [(N / PHI) / (SIGMA - PHI)]
    names = names + ["(n/phi)/(sigma+mu)"]
    vals = vals + [(N / PHI) / (SIGMA + MU)]
    names = names + ["(n/phi)/(sigma-phi)^phi"]
    vals = vals + [(N / PHI) / pow(SIGMA - PHI, PHI)]
    names = names + ["sopfr/((sigma-sopfr)*n)"]
    vals = vals + [SOPFR / ((SIGMA - SOPFR) * N)]
    names = names + ["(sigma+n/phi)/phi"]
    vals = vals + [(SIGMA + N / PHI) / PHI]
    names = names + ["(sigma+n/phi)/(sigma-sopfr)"]
    vals = vals + [(SIGMA + N / PHI) / (SIGMA - SOPFR)]
    names = names + ["1/n"]
    vals = vals + [1.0 / N]
    names = names + ["1/e"]
    vals = vals + [1.0 / E_CONST]
    names = names + ["phi/(sigma-phi)^phi"]
    vals = vals + [PHI / pow(SIGMA - PHI, PHI)]

    // Adam / LLM
    names = names + ["1-1/(J2-tau)"]
    vals = vals + [1.0 - 1.0 / (J2 - TAU)]
    names = names + ["1-1/(sigma-phi)"]
    vals = vals + [1.0 - 1.0 / (SIGMA - PHI)]
    names = names + ["10^(-(sigma-tau))"]
    vals = vals + [pow(10.0, 0.0 - (SIGMA - TAU))]
    names = names + ["R(6)"]
    vals = vals + [SIGMA * PHI / (N * TAU)]
    names = names + ["ln(4/3)"]
    vals = vals + [0.28768207]
    names = names + ["tau^2/(n/phi)^3"]
    vals = vals + [TAU * TAU / pow(N / PHI, 3.0)]
    names = names + ["1/(sigma-phi)^(n/phi)"]
    vals = vals + [1.0 / pow(SIGMA - PHI, N / PHI)]

    // Cosmology
    names = names + ["1-mu/P2"]
    vals = vals + [1.0 - MU / 28.0]
    names = names + ["sigma/sigma(P2)^2"]
    vals = vals + [SIGMA / (56.0 * 56.0)]
    names = names + ["(n/phi+mu/sigma)*10^(-sopfr)"]
    vals = vals + [(N / PHI + MU / SIGMA) * pow(10.0, 0.0 - SOPFR)]

    // Egyptian
    names = names + ["sigma^2*sigma*J2"]
    vals = vals + [SIGMA * SIGMA * SIGMA * J2]
    names = names + ["sigma^2*tau/2"]
    vals = vals + [SIGMA * SIGMA * TAU / 2.0]
    names = names + ["sigma^2*240W"]
    vals = vals + [SIGMA * SIGMA * 240.0]

    // Fine structure
    names = names + ["sigma(sigma-mu)+sopfr+mu/P2"]
    vals = vals + [SIGMA * (SIGMA - MU) + SOPFR + MU / 28.0]

    // J2 identities
    names = names + ["J2-tau=tau*sopfr"]
    vals = vals + [J2 - TAU]
    names = names + ["tau*sopfr"]
    vals = vals + [TAU * SOPFR]

    [names, vals]
}

// Embedded test rows: [expression_key, claimed_value]
// Representative sample covering all categories from atlas-constants.md
