    let mut expr = []
    let mut claimed = []

    // Base
    expr = expr + ["sigma"]
    claimed = claimed + [12.0]
    expr = expr + ["tau"]
    claimed = claimed + [4.0]
    expr = expr + ["phi"]
    claimed = claimed + [2.0]
    expr = expr + ["sopfr"]
    claimed = claimed + [5.0]
    expr = expr + ["J2"]
    claimed = claimed + [24.0]
    expr = expr + ["mu"]
    claimed = claimed + [1.0]
    expr = expr + ["n"]
    claimed = claimed + [6.0]

    // Arithmetic
    expr = expr + ["sigma-tau"]
    claimed = claimed + [8.0]
    expr = expr + ["sigma-phi"]
    claimed = claimed + [10.0]
    expr = expr + ["sigma-mu"]
    claimed = claimed + [11.0]
    expr = expr + ["sigma+mu"]
    claimed = claimed + [13.0]
    expr = expr + ["sigma-sopfr"]
    claimed = claimed + [7.0]
    expr = expr + ["J2-tau"]
    claimed = claimed + [20.0]
    expr = expr + ["J2+phi"]
    claimed = claimed + [26.0]
    expr = expr + ["sigma+n/phi"]
    claimed = claimed + [15.0]
    expr = expr + ["n/phi"]
    claimed = claimed + [3.0]

    // Products
    expr = expr + ["sigma*tau"]
    claimed = claimed + [48.0]
    expr = expr + ["sigma*n"]
    claimed = claimed + [72.0]
    expr = expr + ["sigma*phi"]
    claimed = claimed + [24.0]
    expr = expr + ["sigma*sopfr"]
    claimed = claimed + [60.0]
    expr = expr + ["sigma*J2"]
    claimed = claimed + [288.0]
    expr = expr + ["sigma*(sigma-phi)"]
    claimed = claimed + [120.0]
    expr = expr + ["sigma*(sigma-tau)"]
    claimed = claimed + [96.0]
    expr = expr + ["sigma*(sigma-1)/2"]
    claimed = claimed + [66.0]
    expr = expr + ["sigma*(sigma-tau)*2^n"]
    claimed = claimed + [6144.0]
    expr = expr + ["sopfr*phi"]
    claimed = claimed + [10.0]
    expr = expr + ["sopfr*(sigma-phi)"]
    claimed = claimed + [50.0]
    expr = expr + ["sigma*tau*(sigma-phi)"]
