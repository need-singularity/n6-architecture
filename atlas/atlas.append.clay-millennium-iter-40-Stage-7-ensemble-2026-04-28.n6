  => "t3:        phi/pi mean=75   stdev=56  (low noise)"
  => "s3:        phi/pi mean=152  stdev=112"
  => "blackhole: phi/pi mean=77   stdev=69"
  => "wormhole:  phi/pi mean=147  stdev=108"
