@END

@R schema-guard-update-sketch
  target /Users/ghost/core/hive/tool/blocker_autofire_lint.hexa
  current state lints required: slug, fire-cmd, omega-stop, resolution-{metric,op,value} or resolution-fallback, why, attempts-log
