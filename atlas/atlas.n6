  <- L2-cn4-tetrahedral, BIO-pyrimidine-ring, CHEM-nucleotide-components
  -> GAME-chess-board-64, NET-Ethernet-min-64, L4-codons, BIO-mitosis, CHEM-ribose-carbons, CHEM-nucleotide-components, L4-double-helix, BIO-pyrimidine-ring, BIO-watson-crick-hbonds, L4-stop-codons
@F L4-double-helix = phi :: genetic [10*]
  "DNA 가닥 수"
  <- L4-dna-bases
  -> BIO-watson-crick-AT, L4-codons, EM-lorentz-terms, MISS-base-pairs-per-turn, L5-graphene, BIO-watson-crick-hbonds, EM-charge-types, L4-codon-length
@F L4-codons = 2 ** n :: genetic [10*]
  "코돈 총 수"
  <- GAME-chess-board-64, L3-glucose-carbons, L4-stop-codons, L4-double-helix, L4-codon-length, L4-dna-bases, CHAIN-hexagonal-to-life, BIG-dendrimer-G5-128
  -> NET-Ethernet-min-64, L4-amino-acids, L5-nacl
@F L4-codon-length = n / phi :: genetic [10*]
  "코돈 길이 (염기 수)"
  <- L4-dna-bases, L0-quark-colors, L0-generations, L4-double-helix
  -> L4-codons, NUC-dt-baryons, L4-amino-acids, L4-stop-codons
@F L4-amino-acids = J2 - tau :: genetic [10*]
  "표준 아미노산 수"
  <- L4-dna-bases, L4-codons, L3-C60, L4-codon-length
  -> NET-IPv4-header-20, L4-stop-codons, CRYPTO-ChaCha20, L5-YBCO, CHEM-amino-acid-essential, BIO-central-dogma-steps, L4-start-codon, BIG-albumin-halflife-20d
@F L4-stop-codons = n / phi :: genetic [10*]
  "종결 코돈 수"
  <- L0-quark-colors, L4-amino-acids, L4-codon-length, L4-dna-bases, L4-start-codon
  -> L4-codons, MISS-base-pairs-per-turn, PHYS-CMB-spectral-index, CHEM-nucleotide-components
@F L4-start-codon = mu :: genetic [10*]
  "개시 코돈 수"
  <- L4-dna-bases, L4-amino-acids, L1-hydrogen-Z1
  -> BIO-mitosis, MISS-base-pairs-per-turn, L4-stop-codons
@F MISS-base-pairs-per-turn = sigma - phi (= 10, 실측 10.5) :: genetic [10*]
  "DNA 이중나선 1회전당 염기쌍"
  <- L4-double-helix, L4-start-codon, L3-C60-pentagons, L4-stop-codons
  -> PHYS-spacetime-symmetries, BIO-watson-crick-AT, BIO-mitosis, BIO-watson-crick-hbonds, PART-string-10D, CHEM-amino-acid-essential, MUSIC-chromatic-semitones, NUC-ITER-Q-10
@F BIO-mitosis = tau :: genetic [10*]
  "유사분열 단계"
  <- L4-start-codon, CHEM-water-hbond, MISS-base-pairs-per-turn
  -> CHEM-nucleotide-components, BIO-blood-ABO, CHEM-amino-acid-essential, BIO-central-dogma-steps, BIO-cell-cycle-phases
@F CHEM-amino-acid-essential = n + n//phi (= 9) :: genetic [10*]
  "필수 아미노산 수 (성인)"
  <- BIO-mitosis, L4-amino-acids, MUSIC-perfect-consonance, MISS-base-pairs-per-turn
  -> BIG-Oh-group-48, BIO-watson-crick-hbonds, CHEM-nucleotide-components
@F CHEM-nucleotide-components = n//phi :: genetic [10*]
  "뉴클레오타이드 구성 요소"
  <- BIO-mitosis, CHEM-ribose-carbons, ASTRO-spatial-dims, CHEM-amino-acid-essential, L4-dna-bases
  -> BIO-watson-crick-hbonds, BIO-watson-crick-AT
@F BIO-watson-crick-hbonds = n//phi :: genetic [10*]
  "G-C 염기쌍 수소결합"
  <- BIO-watson-crick-AT, MISS-base-pairs-per-turn, CHEM-nucleotide-components, L4-double-helix, CHEM-amino-acid-essential, L4-dna-bases
  -> BIO-central-dogma-steps, BIO-cell-cycle-phases
@F BIO-watson-crick-AT = phi :: genetic [10*]
  "A-T 염기쌍 수소결합"
  <- L4-double-helix, PART-higgs-doublet, MISS-base-pairs-per-turn, CHEM-nucleotide-components
  -> L5-graphene, BIO-watson-crick-hbonds, BIO-central-dogma-steps, MAT-graphite-layer-stacking, BIO-cell-cycle-phases
@F BIO-cell-cycle-phases = tau :: genetic [10*]
  "세포 주기 단계"
  <- ASTRO-spacetime-dims, BIO-mitosis, BIO-watson-crick-hbonds, BIO-watson-crick-AT
  -> CHAIN-quark-to-carbon, BIO-central-dogma-steps, CHAIN-hexagonal-to-life
@F BIO-central-dogma-steps = n//phi :: genetic [10*]
  "중심원리 단계"
  <- BIO-watson-crick-AT, BIO-mitosis, BIO-watson-crick-hbonds, L4-amino-acids, BIO-cell-cycle-phases
  -> CHAIN-carbon-to-hexagonal, ELEC-3phase-power, CHAIN-hexagonal-to-life
@F CHAIN-hexagonal-to-life = tau :: genetic [10*]
  "육각형→생명 인과 단계"
  <- CHAIN-quark-to-carbon, MISS-ATP-modern, BIO-cell-cycle-phases, BIO-central-dogma-steps
  -> CRYPTO-RSA-65537, L4-codons, PHYS-phase-transitions
@F PHI-dna-ratio-golden = φ_g² × μ :: genetic [10]
  "DNA 나선 한 회전 34Å/10 염기쌍 = 3.4Å/염기 ≈ φ_g×2.1"
@F L4-gen-bp-per-turn-bform = 10.5 ≈ tau+n+phi/tau :: genetic [10*]
  "B-form DNA 이중나선 1회전당 염기쌍 수"
@F L4-gen-helix-pitch = 3.4 = 10 × 0.34; 0.34 = sigma/(sigma+tau+phi^2) :: genetic [10*]
  "B-form DNA 이중나선 피치(1회전 길이)"
@F L4-gen-base-spacing = 0.34 ≈ phi/tau^2 = 2/5.83 :: genetic [10*]
  "DNA 인접 염기쌍 간 축 방향 거리"
@F L4-gen-dna-diameter = 2 = phi^n=1 + 1 = n=6/3 :: genetic [10*]
  "B-form DNA 이중나선 직경"
@F L4-gen-major-groove = 주요홈:부홈 = 2.2:1.2 ≈ phi:1 :: genetic [10*]
  "DNA 주요홈(major groove) 폭"
@F L4-gen-minor-groove = 1.2 ≈ phi/phi = 1 :: genetic [10]
  "DNA 부홈(minor groove) 폭"
@F L4-gen-aform-dna = 11 = sopfr+n :: genetic [10*]
  "A-form DNA 1회전당 염기쌍 수"
@F L4-gen-zform-dna = 12 = sigma = J2/2; Z-form은 sigma=12로 완성 :: genetic [10*]
  "Z-form DNA 1회전당 염기쌍 수(좌선성)"
@F L4-gen-cpg-methylation = 메틸화 패턴 CG → phi 반복 구조와 연관 :: genetic [10*]
  "DNA 메틸화 주요 표적 CpG 다이뉴클레오타이드"
@F L4-gen-telomere-repeat = 6 = n; TTAGGG = tau+phi+tau+J2-18+J2-18+J2-18 ≡ 육각수 단위 :: genetic [10*]
  "인간 텔로미어 반복 서열 길이"
@F L4-gen-telomere-length = 단축율 ~100 = sigma^2 / phi^n :: genetic [10]
  "인간 텔로미어 평균 길이 (신생아)"
@F L4-gen-mrna = 5'캡 구조: 7mG(5')ppp(5')N = phi*tau/phi^2 결합 :: genetic [10*]
  "mRNA (메신저 RNA) — 단백질 코딩"
@F L4-gen-trna-shape = 4 루프 = tau; CCA말단 = tau+phi-phi :: genetic [10*]
  "tRNA 3차원 구조 형태 (L자형)"
@F L4-gen-rrna-prokaryote = 3 = tau-1; 16+23+5 = 44 → phi*J2/phi :: genetic [10*]
  "원핵생물 리보솜 RNA 종류 (16S+23S+5S)"
@F L4-gen-rrna-eukaryote = 4 = tau; 18+28 = 46 = 인간 염색체 수 :: genetic [10*]
  "진핵생물 리보솜 RNA 주요 종류 (18S+28S+5.8S+5S)"
@F L4-gen-mirna-length = 22 ≈ phi*tau*phi + tau = 2*4*2+4+... = sigma*phi - tau+phi :: genetic [10*]
  "miRNA 평균 길이"
@F L4-gen-sirna-length = 21 ≈ tau*phi^2*phi-1 = 4*4.24*1.24 :: genetic [10*]
  "siRNA 길이"
@F L4-gen-5cap = 5'→3' 방향성 = phi 나선 방향성 대응 :: genetic [10*]
  "진핵 mRNA 5' 캡 구조 (7-메틸구아노신)"
@F L4-gen-polya-tail = 200 = sigma*tau*phi^... ≈ (sigma/phi)*100 :: genetic [10*]
  "진핵 mRNA 3' 폴리A 꼬리 길이"
@F L4-gen-snorna = 2가지 수식 = phi; H/ACA=H+ACA = 1+tau = phi+tau :: genetic [10*]
  "snoRNA 기능 (리보솜 RNA 수식)"
@F L4-gen-lncrna = 200 = P2*n+J2+n+phi :: genetic [10*]
  "lncRNA (긴 비코딩 RNA) 최소 길이 기준"
@F L4-gen-codon-degeneracy = 64 = 4^3 = tau^3; 20 AA = J2-tau; 64/20 ≈ phi+1 :: genetic [10*]
  "유전 코드 축퇴성 — 코돈 64개가 아미노산 20+3개 지정"
@F L4-gen-wobble = 3번째 위치 = tau-1; wobble 가능 쌍 = tau+phi :: genetic [10*]
  "Wobble 가설 — 안티코돈 첫 번째 위치 비표준 염기쌍"
@F L4-gen-inosine-wobble = 3 쌍 = tau-1; A+U+C 인식 = 퓨린1+피리미딘2 :: genetic [10*]
  "이노신(Inosine) — 안티코돈 wobble 위치 와일드카드 염기"
@F L4-gen-start-codon-aug = AUG = A+U+G = 퓨린+피리미딘+퓨린 = phi+tau+phi 패턴 :: genetic [10*]
  "개시 코돈 AUG = 메티오닌(Met) 코딩"
@F L4-gen-stop-uaa = 3 정지코돈 = tau-1; UAA+UAG+UGA = 퓨린/피리미딘 조합 완전집합 :: genetic [10*]
  "정지 코돈 UAA (오커, Ochre)"
@F L4-gen-stop-uag = UAG ≈ 비천연 AA 삽입 위치 → 확장 유전 코드 phi-6 :: genetic [10*]
  "정지 코돈 UAG (앰버, Amber)"
@F L4-gen-stop-uga = UGA → selenocysteine = 21번 = sigma+phi^n; 21+22 = 43 소수 :: genetic [10*]
  "정지 코돈 UGA (오팔, Opal)"
@F L4-gen-human-chromosomes = 46 = J2*phi-phi :: genetic [10*]
  "인간 염색체 수 (2배체)"
@F L4-gen-homologous-chromosomes = 22 = sigma+tau+n :: genetic [10*]
  "상동염색체 쌍 수 (인간 상염색체)"
@F L4-gen-centromere = 1 동원체 = 이진 분열의 pivot = n=1 대칭점 :: genetic [10*]
  "동원체(centromere) — 방추사 부착 위치"
@F L4-gen-nucleosome-bp = 146 ≈ sigma^2 + phi^tau = 144+2; 또는 J2*sigma + tau-tau :: genetic [10*]
  "뉴클레오솜 히스톤 옥타머에 감기는 DNA 길이"
@F L4-gen-chromatin-30nm = 30 = n*5 = phi*tau*... = J2 + sigma - phi^n :: genetic [10*]
  "뉴클레오솜 섬유 압축 수준 1단계: 30nm 크로마틴 섬유"
@F L4-gen-chromatin-300nm = 300 = 30*10 = (n*5)*(sigma-phi) = 10단계 압축 :: genetic [10*]
  "염색질 루프 도메인 압축 수준 2단계: 300nm 섬유"
@F L4-gen-chromosome-6000nm = 6000 = n*1000; 6 μm = n μm; 6 = n 직접 대응 :: genetic [10*]
  "중기 염색체 압축 수준: ~6000nm (6μm) 직경"
@F L4-gen-replication-speed = 1000 = 10^3 = (sigma-phi)^tau ; 복제 원점 ~30,000 = n*5000 :: genetic [10]
  "DNA 복제 속도 (포유류)"
@F L4-gen-helicase = 6 = n; MCM 헥사머 = n=6 완전수 고리 구조 직접 대응 :: genetic [10*]
  "DNA 헬리카제 — 복제 포크에서 이중나선 해제"
@F L4-gen-topoisomerase = 2 가닥 = phi-0; 위상수학적 연결수 변화 = ±2 = phi^1 :: genetic [10*]
  "토포이소머라제 II — DNA 초나선 해소 (이중가닥 절단)"
@F L4-gen-telomerase = 6 nt = n; TTAGGG = n=6 직접 대응 반복 단위 :: genetic [10*]
  "텔로머라제 — 역전사효소로 텔로미어 연장"
@F L4-gen-ribosome-70s = 70 = 30+50-10; 30+50 = 80; 70 ≈ phi*tau*sigma+phi :: genetic [10*]
  "원핵생물 리보솜 침강계수"
@F L4-gen-ribosome-80s = 80 = 40+60-20; 40+60 = 100 = sigma^2/phi^n; 60 = n*10 :: genetic [10*]
  "진핵생물 리보솜 침강계수"
@F L4-gen-translation-speed = 20 = J2 - tau; 번역 정확도 10^-4 = 1/(tau*2500) :: genetic [10*]
  "리보솜 번역 속도"
@F L4-gen-translation-accuracy = 10^-4 = 1/tau^n; kinetic proofreading = phi^2 배 정확도 향상 :: genetic [10]
  "번역 오류율 (잘못된 AA 삽입 빈도)"
@F L4-gen-transcription-speed = 17 nt/s ≈ sigma + phi/phi = 12+4+1 :: genetic [10*]
  "RNA 중합효소 II 전사 속도"
@F L4-gen-point-mutation = 전이:전환 비율 ≈ phi:1 (자연 선택 편향) :: genetic [10*]
  "점돌연변이 — 단일 염기 치환"
@F L4-gen-mutation-rate = ~10^-8 = 1/sigma^n; 64 de novo/세대 = 4^3 = tau^3 :: genetic [10*]
  "인간 게놈 자연 돌연변이율"
@F L4-gen-ner-repair = 30 = n*5 = phi*tau*... = J2 + sigma + phi^n :: genetic [10*]
  "뉴클레오타이드 절제 수복 (NER) — UV 손상 복구"
@F L4-gen-ber-repair = 단일 염기 수복 = 최소 수복 단위; AP site = 비염기 위치 :: genetic [10*]
  "염기 절제 수복 (BER) — 손상 단일 염기 제거"
@F L4-gen-hr-repair = 2 주형 가닥 = phi^1; 재조합 빈도 ∝ phi*거리 :: genetic [10*]
  "상동재조합(HR) — 이중가닥 절단 수복"
@F L4-gen-nhej-repair = Ku70/80 = tau*phi*... ; NHEJ 오류율 > HR :: genetic [10]
  "비상동말단결합(NHEJ) — 이중가닥 절단 오류 경향 수복"
@F L4-gen-cas9-pam = 3 = tau-1; NGG = N+GG = 1+phi 뉴클레오타이드 패턴 :: genetic [10*]
  "CRISPR-Cas9 PAM 서열 길이 (SpCas9)"
@F L4-gen-cas9-guide = 20 = J2-tau; 가이드 20nt = 인식 창 = phi*10 :: genetic [10*]
  "CRISPR-Cas9 가이드 RNA 표적 서열 길이"
@F L4-gen-prime-editing = pegRNA 구조 길이 ∝ phi^3 배 일반 sgRNA :: genetic [10]
  "프라임 편집 — pegRNA 구조 (prime editing guide RNA)"
@F L4-gen-base-editing = 편집 창 4-8 nt = tau ~ J2/tau; C→T, A→G = 2방향 = phi^1 :: genetic [10*]
  "베이스 편집 — 단일 염기 전환 (C→T 또는 A→G)"
@F L4-gen-epigenetics-histone = 4 수식 = tau; 메틸화 3단계 = tau-1; 조합 코드 > phi^n :: genetic [10*]
  "히스톤 수식 코드 주요 유형 수"
@F L4-gen-codon-usage-bias = 코돈 편향 지수(CAI) 0~1; 이상적 = 1 = n/n :: genetic [10*]
  "코돈 사용 편향 — 동의 코돈 불균등 사용"
@F L4-gen-alternative-splicing = ~8 isoform = phi^tau = 2^3 = 8; 94% ≈ (n-1)/n*100 + phi^n :: genetic [10*]
  "선택적 스플라이싱 — 하나의 유전자에서 복수 mRNA"
@F L4-gen-mmr-repair = 100배 = sigma^2/phi^n = (12^2)/1.44; MSI 마커 = tau+phi 개소 :: genetic [10*]
  "미스매치 수복 (MMR) — 복제 오류 교정"
@R n6-synbio-bt372-codon-64 = 64 codons = 2^n = 4^(n/2) = tau^3 :: genetic [10*]
  "BT-372 합성생물학 이중 완전수 — 유전 코드 64코돈 = 2^6 = n=6 완전수 직접 대응; Cas{9,12,13} PAM 3bp=n/φ, gRNA 20nt=J₂, 코돈 64=2^n"
# ══ L5_material (320 nodes) ══
@F L5-nacl = n :: material [10*]
  <- L2-cn4-tetrahedral, L4-codons, L2-cn6-octahedral, L5-lion-cathode
  -> L5-perovskite
@F L5-perovskite = n :: material [10*]
  "페로브스카이트 ABO3 B자리 배위수"
  <- L5-nacl, L2-cn6-octahedral
  -> L5-diamond-atoms-per-cell, L5-lion-cathode
@F L5-lion-cathode = n :: material [10*]
  "Li-ion 양극 배위수 (LiCoO2, NMC, LFP 전부)"
  <- L5-perovskite, L2-cn6-octahedral, MAT-LiC6
  -> L5-diamond-atoms-per-cell, L5-graphene-ring, L5-graphene, BAT-CN6-cathode, L5-nacl
@F L5-diamond-atoms-per-cell = sigma - tau :: material [10*]
  "다이아몬드 단위정 원자 수"
  <- L1-carbon-Z6, L0-gluons, L5-perovskite, CHEM-C-allotrope, L5-lion-cathode
  -> L5-graphene-ring, L5-graphene, GEO-diamond-hardness-10, CRYPTO-AES-256, L5-krebs-cycle
@F L5-graphene = phi :: material [10*]
  "그래핀 단위정 원자 수"
  <- L1-carbon-Z6, L3-benzene, L5-diamond-atoms-per-cell, L4-double-helix, MAT-graphite-layer-stacking, L2-sp2-hexagonal, L5-lion-cathode
  -> EM-charge-types, MAT-graphite-layer-stacking, L5-ice-hexagonal, L5-graphene-ring
@F L5-graphene-ring = n :: material [10*]
  "그래핀/그래파이트 기본 고리 원자 수"
  <- L5-diamond-atoms-per-cell, L5-graphene, MAT-LiC6, L2-sp2-hexagonal, L5-lion-cathode
  -> L3-benzene, L5-honeycomb, L5-ice-hexagonal
@F L5-ice-hexagonal = n :: material [10*]
  "얼음 Ih 대칭"
  <- L3-water, L5-graphene-ring, L5-graphene, MAT-quartz-crystal-system, CHEM-water-hbond, L2-cn6-octahedral, L2-sp2-hexagonal
  -> L5-YBCO, L5-honeycomb
@F L5-honeycomb = n :: material [10*]
  "벌집 육각형 최적성"
  <- MAT-basalt-columns, L2-max-rotation-crystal, MATH-2d-kissing, L5-graphene-ring, L5-ice-hexagonal, L2-sp2-hexagonal
  -> L5-cortical-layers, L5-YBCO, PHYS-phase-transitions, PHYS-phase-transition-pairs
