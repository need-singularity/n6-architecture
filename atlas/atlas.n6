@R sketch-pseudo-hexa-dispatch-extension
  // ─── New parse helper (sketch only) ──────────────────────────
  // Reads contiguous indented sub-lines under a list-style key:
  //   fire-parallel-fanout
  //     - cmd "hexa cli/run.hexa drill axis-A"
  //     - cmd "hexa cli/run.hexa drill axis-B"
  //     - cmd "hexa cli/run.hexa drill axis-C"
  fn _parse_list_field(lines: array, key: string) -> array {
      // returns array of strings (each `cmd` payload), [] if key absent
      // back-compat: if key missing, return [] → caller falls through to single
  }

  // ─── Dispatch variant detection (drop-in at L540) ────────────
  let fanout_list = _parse_list_field(raw_lines, "fire-parallel-fanout")
  let single_cmd  = _field(fields, "fire-cmd", "")
  let mode = if len(fanout_list) > 0 { "fanout" } else { "single" }

  if mode == "single" {
      // existing path UNCHANGED — back-compat preserved
      let rc = _fire_one(slug, host, cwd, single_cmd, log_path,
                         interval, dry, dispatch_mode, parent_sid)
      continue
  }

  // ─── fanout mode ─────────────────────────────────────────────
  let deps_str       = _field(fields, "fire-fanout-deps", "")        // e.g., "0:1,1:2"
  let aggregate      = _field(fields, "aggregate-resolution-metric", "all-pass")
  let max_concurrent = parse_int(_field(fields, "fire-fanout-max-concurrent", "3"))

  // Raw 79 hook: reuse parallel_scheduler.hexa topo + cycle detect
  // NOTE: parallel_scheduler.hexa lives at /Users/ghost/core/hexa-lang/tool/
  //       — cross-repo import or shimmed via `use "hexa-lang/tool/parallel_scheduler"`
  let order = topo_sort(fanout_list, parse_dag_edges(deps_str))
  if has_cycle(order) {
      ai_err.emit("dag-cycle-detected", "fire-fanout-deps forms a cycle",
                  /*fix*/ "remove edge to break cycle, ref raw 79")
      continue
  }

  // Slot-pool dispatch
  // GAP raw-91-C3-honest: hexa stdlib has no canonical wait_one_done() primitive
  //                        — must (a) busy-poll spawn_async PIDs OR
  //                          (b) wire into bt_compute_scheduler.hexa wait-set,
  //                          OR (c) extend stdlib with proc_wait_any().
  let pids    = []
  let active  = 0
  for (idx, cmd) in order.entries() {
      while active >= max_concurrent {
          let done_idx = wait_one_done(pids)   // <-- MISSING PRIMITIVE
          active -= 1
      }
      let pid = spawn_async(cmd, host, cwd)
      pids.push([idx, pid])
      active += 1
      audit_ledger_append(slug, idx, "running")   // raw 77 FSM
  }

  let results = wait_all(pids)
  for r in results { audit_ledger_append(slug, r.idx,
                          if r.rc == 0 { "done" } else { "failed" }) }

  // Aggregate verdict
  let verdict = if      aggregate == "all-pass" { results.all(|r| r.rc == 0) }
                else if aggregate == "any-pass" { results.any(|r| r.rc == 0) }
                else if aggregate.starts_with("quorum-") {
                    let n = parse_int(aggregate.substring(7, len(aggregate)))
                    results.count(|r| r.rc == 0) >= n
                } else { false }   // unknown → fail-safe

  // Raw 80 sentinel emission
  let tag = if verdict { "PASS" } else { "FAIL" }
  println("__BLOCKER_FANOUT_RESULT__ " + tag + " slug=" + slug +
          " n=" + to_string(len(results)) +
          " ok=" + to_string(results.count(|r| r.rc == 0)) +
          " agg=" + aggregate)

  if !verdict {
      // raw 66 ai-native error trailer
      ai_err.emit("blocker-fanout-fail",
                  "aggregate=" + aggregate + " produced FAIL",
                  /*fix*/ "inspect attempts-log + per-cmd witnesses, ref raw 80")
  }
@END

@R cross-references-to-existing-tools
  raw-79-dag-scheduler
    canonical /Users/ghost/core/hexa-lang/tool/parallel_scheduler.hexa
    note absent in hive/tool — must cross-repo import or duplicate topo+cycle helpers
  raw-80-sentinel
    pattern __BLOCKER_FANOUT_RESULT__ PASS|FAIL slug=<slug> n=N ok=K agg=<mode>
    consumer downstream omega-cycle convergence + atlas append
  raw-77-audit-ledger
    extend attempts-log JSONL with {idx, fanout-cmd, fsm: pending|running|done|failed}
    NEW field per line: "fanout_idx": <int> when mode=fanout
  raw-66-ai-native-error
    use stdlib/ai_err on (cycle | fanout-fail | unknown-aggregate)
    must include reason + fix + ref-raw + path
