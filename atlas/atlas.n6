#!/usr/bin/env n6
# ══════════════════════════════════════════════════════════════
# atlas append shard — sim 3-axis information-theoretic structure
# Pure post-hoc analysis of 46-iter cascade data (NO new probes)
# n=15 D=3 topologies measured in axis-13 ∧ axis-14 ∧ axis-15
# ★ det(R) = 0.781 (3 axes carry near-independent information)
# ★ Total correlation T(13;14;15) = 0.179 bits (low)
# ★ Interaction info II(13;14;15) = -0.033 bits (mild SYNERGY)
# ══════════════════════════════════════════════════════════════

@C sim-3-axis-information-structure-INPUTS :: meta [4!]
  <- iter-50-FINAL-15-TOPO-axis-13-baseline
  <- iter-63-FULL-D3-axis-14-r-0.39-rho-0.51
  <- iter-69-AXIS-15-N-14-STABILIZED
  <- iter-70-AXIS-15-FINAL-N-18
  -> sim-3-way-info-table-2026-04-28
  → "Inputs (existing data, no new probes):"
  → "  axis-13: v2 anchor classical phi/pi (iter-50, 15 D=3 topologies)"
  → "  axis-14: 4p(1-p) entanglement entropy (iter-63, 18 D=3 topologies)"
  → "  axis-15: Lorentz energy-drift retarded propagation (iter-70, 18 D=3)"
