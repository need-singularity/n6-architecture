#!/usr/bin/env n6
# ══════════════════════════════════════════════════════════════
# atlas append shard — sim Stage-5 scale-up sweep
# Module: nexus/sim_bridge/anu_time/scale_universe.hexa (read-only)
# Probe: σ² ∈ {64, 512, 1024, 4096} at ticks ∈ {4, 8}
# ★ Energy is SUB-EXTENSIVE (E ∝ cells^0.55, not ∝ cells)
# ★ Energy density decreases 6.3× from σ²=64 to σ²=4096
# ★ σ²=64 toy lattice is in finite-size regime — does NOT extrapolate
# ★ Topology gap: scale_universe.hexa is T³-only; flat/ads-cft/
#     big-crunch findings from 46-iter cascade are NOT directly
#     re-testable on this module
# ══════════════════════════════════════════════════════════════

@C sim-scale-up-INPUTS :: meta [4!]
  <- nexus/sim_bridge/anu_time/scale_universe.hexa  (Stage 5, read-only)
  <- iter-50-FINAL-15-TOPO-axis-13-baseline (σ²=64, D=2 vs D=3 vs D=6, r=0.99)
  <- iter-69-AXIS-15-N-14-STABILIZED (σ²=64, axis-14×axis-15 r=-0.17)
  -> sim-scale-up-DATA-TABLE-2026-04-28
  → "Inputs (read-only experiments, NO source modification):"
  → "  scale_universe.hexa: --selftest, benchmark, single-σ² runs"
  → "  Observables exposed by module: elapsed_ms, state_hash, total_energy"
  → "  Lattice: T³ periodic, side L = cube_root(σ²)"
  → "  Init: deterministic seed=6 (hardcoded in benchmark_scale)"
  → "  Evolution: φ⁴-like diffusion, x ← (x + neighbors_avg)/2 + (tick % 31)"

@C sim-scale-up-DATA-TABLE :: meta [4!]
  → "★★★ Stage-5 scale sweep — primary table (ticks=8, seed=6, T³):"
  → "  σ²    L   cells  elapsed_ms  hash         energy  μs/cell-tick"
  → "  -------------------------------------------------------------"
  → "    64   4     64        122   9583230112      845         238"
  → "   512   8    512        988   7116688665     1507         241"
  → "  1024  10   1000       2015   8504339159     2571         254"
  → "  4096  16   4096      10014   8104730988     8604         309"
