@F L3-benzene = n :: molecule [10*]
  "벤젠 탄소 고리 원자 수"
  <- CHAIN-carbon-to-hexagonal, L1-carbon-Z6, L2-max-rotation-crystal, L5-graphene-ring, L1-carbon-valence, L2-sp2-hexagonal, L3-C60
  -> L5-glycolysis-electrons, L3-glucose-carbons, L5-graphene, L3-glucose, MAT-LiC6
@F L3-glucose = J2 :: molecule [10*]
  "포도당 총 원자 수"
  <- MISS-ATP-modern, L3-benzene
  -> L3-water, CRYPTO-Keccak-24, L5-glycolysis-electrons, L3-glucose-carbons, BIO-photosynthesis, BIG-Td-group-24
@F L3-glucose-carbons = n :: molecule [10*]
  "포도당 탄소 수"
  <- MISS-ATP-modern, CHEM-ribose-carbons, L3-benzene, L3-glucose
  -> L3-water, L4-codons, BIO-pyrimidine-ring, BIO-photosynthesis, L3-C60
@F L3-water = n=6 직접 매핑 없음 :: molecule [10]
  "물 결합각"
  <- L3-glucose, L3-glucose-carbons, L1-hydrogen-Z1, L2-space-groups
  -> L3-C60, L3-C60-pentagons, L5-ice-hexagonal, MISS-magic-82-126
@F L3-C60 = sigma * sopfr :: molecule [10*]
