@C clay-cascade-s3-tick3-AG-mechanism-formal-refinement :: meta [4]
  <- clay-cascade-s3-tick3-AG-src-conditional-directed-indeg-CONFIRMED-witness
  => "for topology with nbr(i, a) and src=32:"
  => "1. R(src) = nodes BFS-reachable from src under DIRECTED edges u -> nbr(u, a)"
  => "2. indeg_R(j) = #{(i, a) : i in R, nbr(i, a) = j} for j in R"
  => "   (NOT out-degree — out-deg is always D=3 by construction, carries no hub-collapse signal)"
  => "3. dvar_R = Var_{j in R} [indeg_R(j)]"
  => "addresses both AF blind spots: src-position (R restriction) + edge-direction (directed in-deg)"

@C clay-cascade-s3-tick3-AG-classification-rule :: meta [4]
  <- clay-cascade-s3-tick3-AG-mechanism-formal-refinement
  => "★ TWO-BAND classification rule (refined):"
  => "  |R| <= 10  -> FAST  (BFS-reachable component too small to escape hub orbit)"
  => "  |R| >= 60  -> FULL  (near-full reach, expander-like)"
  => "  10 < |R| < 60 mid-band: dvar_R >= 3 -> FAST else BOUNDED"
  => "primary classifier: |R| (component size); dvar_R disambiguates mid-band only"
  => "this is more conservative than AE original (which used dvar alone)"

