# ── primary spec witness ────────────────────────────────────
@C raw-45-parallel-fanout-enhancement-spec :: meta [4!]
  <- raw-45-omega-blocker-autofire-current-serial-only
  <- raw-79-parallel-DAG-scheduler-witness
  <- raw-80-execution-sentinel-result-decoding
  <- raw-77-execution-audit-append-only-ledger
